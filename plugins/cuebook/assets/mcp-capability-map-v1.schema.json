{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.xyz/schemas/cuebook-mcp-capability-map-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "server",
    "module_rules",
    "available_tools",
    "required_tools",
    "frame_publication_flow",
    "release_rules"
  ],
  "properties": {
    "schema_version": {
      "const": "cuebook-mcp-capability-map-v1"
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "url",
        "transport",
        "authentication"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "transport": {
          "enum": [
            "http"
          ]
        },
        "authentication": {
          "enum": [
            "oauth"
          ]
        }
      }
    },
    "module_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query",
        "create"
      ],
      "properties": {
        "query": {
          "$ref": "#/$defs/moduleRule"
        },
        "create": {
          "$ref": "#/$defs/moduleRule"
        }
      }
    },
    "available_tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "required_tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "frame_publication_flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_transport",
        "skill_may_pull_media",
        "status_tool",
        "status_returns",
        "published_read_tool",
        "published_visual_semantics",
        "forbidden_tools",
        "initial_publish_sequence",
        "mutation_idempotency",
        "replay_policy"
      ],
      "properties": {
        "image_transport": {
          "const": "signed_https_upload_only"
        },
        "skill_may_pull_media": {
          "const": false
        },
        "status_tool": {
          "const": "get_frame_media_status"
        },
        "status_returns": {
          "const": "processing_and_hash_receipts_only"
        },
        "published_read_tool": {
          "const": "get_frame"
        },
        "published_visual_semantics": {
          "const": "one_visual_attached_to_frame_release"
        },
        "forbidden_tools": {
          "const": [
            "get_frame_media",
            "list_frame_media",
            "publish_frame_image",
            "share_frame_to_agent"
          ]
        },
        "initial_publish_sequence": {
          "const": [
            "get_frame_capabilities",
            "begin_frame_media_upload",
            "https_put_each_role",
            "complete_frame_media_upload",
            "get_frame_media_status",
            "register_frame_visual_manifest",
            "create_or_update_frame_draft",
            "prepare_frame_publish",
            "first_party_consent",
            "get_frame_action_consent",
            "publish_frame",
            "get_frame"
          ]
        },
        "mutation_idempotency": {
          "const": "distinct_lowercase_uuidv7_per_command"
        },
        "replay_policy": {
          "const": "same_key_same_payload_returns_receipt_changed_payload_conflict"
        }
      }
    },
    "release_rules": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 500
    }
  },
  "$defs": {
    "moduleRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_access",
        "may_invoke"
      ],
      "properties": {
        "allowed_access": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "read",
              "write",
              "external_write"
            ]
          }
        },
        "may_invoke": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "query",
              "create"
            ]
          }
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "module",
        "authorization_scope",
        "access",
        "purpose",
        "used_by"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "module": {
          "enum": [
            "query",
            "create"
          ]
        },
        "authorization_scope": {
          "enum": [
            "read:public",
            "cuebook.query",
            "cuebook.create.write",
            "cuebook.publish",
            "cuebook.trade",
            "cuebook.paper.read",
            "cuebook.paper.trade",
            "cuebook.frame.read",
            "cuebook.frame.write",
            "cuebook.frame.publish"
          ]
        },
        "phase": {
          "enum": [
            "r0",
            "r1",
            "r2",
            "pr8",
            "frame_phase_b",
            "superseded_review"
          ]
        },
        "access": {
          "enum": [
            "read",
            "write",
            "external_write"
          ]
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "input_contract": {
          "type": "string",
          "minLength": 1
        },
        "output_contract": {
          "type": "string",
          "minLength": 1
        },
        "used_by": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "content_kind": {
          "type": "string",
          "maxLength": 40
        },
        "default_enabled": {
          "type": "boolean"
        },
        "superseded_by": {
          "type": "string",
          "maxLength": 60
        },
        "source": {
          "type": "string",
          "maxLength": 120
        }
      }
    }
  }
}
