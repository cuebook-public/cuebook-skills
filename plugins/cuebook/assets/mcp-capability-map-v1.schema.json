{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.xyz/schemas/cuebook-mcp-capability-map-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "server",
    "module_rules",
    "available_tools",
    "required_tools",
    "planned_tools",
    "skill_tool_policy",
    "frame_publication_flow",
    "release_rules"
  ],
  "properties": {
    "schema_version": {
      "const": "cuebook-mcp-capability-map-v1"
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "url",
        "transport",
        "authentication"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "transport": {
          "enum": [
            "http"
          ]
        },
        "authentication": {
          "enum": [
            "oauth"
          ]
        }
      }
    },
    "module_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query",
        "create"
      ],
      "properties": {
        "query": {
          "$ref": "#/$defs/moduleRule"
        },
        "create": {
          "$ref": "#/$defs/moduleRule"
        }
      }
    },
    "available_tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "required_tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "planned_tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plannedTool"
      }
    },
    "skill_tool_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_mode",
        "creator_fast_allowlist",
        "focused_on_demand",
        "deep_only",
        "max_cuebook_batches",
        "max_dependency_followups",
        "web_fallback"
      ],
      "properties": {
        "default_mode": {
          "const": "creator_fast"
        },
        "creator_fast_allowlist": {
          "$ref": "#/$defs/toolNameSet"
        },
        "focused_on_demand": {
          "$ref": "#/$defs/toolNameSet"
        },
        "deep_only": {
          "$ref": "#/$defs/toolNameSet"
        },
        "max_cuebook_batches": {
          "const": 1
        },
        "max_dependency_followups": {
          "const": 1
        },
        "web_fallback": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "trigger",
            "max_batches",
            "max_queries",
            "max_sources",
            "source_preference",
            "required_lineage_fields",
            "unsupported_claim_policy"
          ],
          "properties": {
            "trigger": {
              "const": "material_gap_after_cuebook_batch"
            },
            "max_batches": {
              "const": 1
            },
            "max_queries": {
              "const": 3
            },
            "max_sources": {
              "const": 3
            },
            "source_preference": {
              "const": "primary_or_authoritative"
            },
            "required_lineage_fields": {
              "const": [
                "retrieved_via",
                "retrieved_at",
                "locator"
              ]
            },
            "unsupported_claim_policy": {
              "const": "creator_hypothesis_or_omit"
            }
          }
        }
      }
    },
    "frame_publication_flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_transport",
        "skill_may_pull_media",
        "status_tool",
        "status_returns",
        "published_read_tool",
        "published_visual_semantics",
        "client_upload_roles",
        "capture_profiles",
        "delivery_resize_policy",
        "forbidden_tools",
        "initial_publish_sequence",
        "correction_publish_sequence",
        "withdraw_sequence",
        "publish_authorization",
        "action_consent_usage",
        "prepared_publish_required_fields",
        "prepared_correction_publish_required_fields",
        "prepared_publish_omitted_fields",
        "publish_input_omitted_fields",
        "wire_golden",
        "mutation_idempotency",
        "replay_policy"
      ],
      "properties": {
        "image_transport": {
          "const": "signed_https_upload_only"
        },
        "skill_may_pull_media": {
          "const": false
        },
        "status_tool": {
          "const": "get_frame_media_status"
        },
        "status_returns": {
          "const": "processing_and_hash_receipts_only"
        },
        "published_read_tool": {
          "const": "get_frame"
        },
        "published_visual_semantics": {
          "const": "one_visual_attached_to_frame_release"
        },
        "client_upload_roles": {
          "const": ["publication"]
        },
        "capture_profiles": {
          "const": {"publication": {"width": 2488, "height": 1056}}
        },
        "delivery_resize_policy": {
          "const": "frontend_or_edge_transformation_only"
        },
        "forbidden_tools": {
          "const": [
            "get_frame_media",
            "list_frame_media",
            "publish_frame_image",
            "share_frame_to_agent"
          ]
        },
        "initial_publish_sequence": {
          "const": [
            "get_frame_capabilities",
            "begin_frame_media_upload",
            "https_put_publication_master",
            "complete_frame_media_upload",
            "get_frame_media_status",
            "register_frame_visual_manifest",
            "create_or_update_frame_draft",
            "prepare_frame_publish",
            "publish_frame",
            "get_frame"
          ]
        },
        "correction_publish_sequence": {
          "const": [
            "prepare_frame_correction_publish",
            "publish_frame_correction",
            "get_frame"
          ]
        },
        "withdraw_sequence": {
          "const": [
            "prepare_frame_withdraw",
            "first_party_consent",
            "get_frame_action_consent",
            "withdraw_frame"
          ]
        },
        "publish_authorization": {
          "const": "active_frame_publish_grant_and_first_party_publish_action"
        },
        "action_consent_usage": {
          "const": "withdrawal_only"
        },
        "prepared_publish_required_fields": {
          "const": [
            "prepared_hash",
            "publish_token",
            "publish_token_expires_at",
            "preview"
          ]
        },
        "prepared_correction_publish_required_fields": {
          "const": [
            "prepared_hash",
            "publish_token",
            "publish_token_expires_at",
            "preview",
            "base_release_id",
            "expected_economic_hash"
          ]
        },
        "prepared_publish_omitted_fields": {
          "const": [
            "consent_request_id",
            "consent_url",
            "consent_expires_at"
          ]
        },
        "publish_input_omitted_fields": {
          "const": [
            "consent_request_id"
          ]
        },
        "wire_golden": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tool_manifest_sha256",
            "schema_catalog_sha256"
          ],
          "properties": {
            "tool_manifest_sha256": {
              "const": "bf4464c25623d9d44dd16f08dbb51a9cbb91e3062c813ed1c3941403d65289a2"
            },
            "schema_catalog_sha256": {
              "const": "0f654cce42c03e23eab005eb76e092db6a872f5da5377e9af0e05bf126bde299"
            }
          }
        },
        "mutation_idempotency": {
          "const": "distinct_lowercase_uuidv7_per_command"
        },
        "replay_policy": {
          "const": "same_key_same_payload_returns_receipt_changed_payload_conflict"
        }
      }
    },
    "release_rules": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 500
    }
  },
  "$defs": {
    "toolNameSet": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "moduleRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_access",
        "may_invoke"
      ],
      "properties": {
        "allowed_access": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "read",
              "write",
              "external_write"
            ]
          }
        },
        "may_invoke": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "query",
              "create"
            ]
          }
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "module",
        "authorization_scope",
        "access",
        "purpose",
        "used_by"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "module": {
          "enum": [
            "query",
            "create"
          ]
        },
        "authorization_scope": {
          "enum": [
            "read:public",
            "cuebook.paper.read",
            "cuebook.paper.trade",
            "cuebook.frame.read",
            "cuebook.frame.write",
            "cuebook.frame.publish"
          ]
        },
        "phase": {
          "const": "frame_phase_b"
        },
        "access": {
          "enum": [
            "read",
            "write",
            "external_write"
          ]
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "input_contract": {
          "type": "string",
          "minLength": 1
        },
        "output_contract": {
          "type": "string",
          "minLength": 1
        },
        "used_by": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "content_kind": {
          "type": "string",
          "maxLength": 40
        },
        "default_enabled": {
          "type": "boolean"
        },
        "source": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "plannedTool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "module",
        "phase",
        "access",
        "purpose",
        "used_by"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "module": {
          "enum": [
            "query",
            "create"
          ]
        },
        "phase": {
          "const": "planned"
        },
        "access": {
          "enum": [
            "read",
            "write",
            "external_write"
          ]
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "used_by": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        }
      }
    }
  }
}
