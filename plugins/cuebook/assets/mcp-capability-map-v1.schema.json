{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.xyz/schemas/cuebook-mcp-capability-map-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "server", "module_rules", "available_tools", "required_tools", "release_rules"],
  "properties": {
    "schema_version": {"const": "cuebook-mcp-capability-map-v1"},
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "transport", "authentication"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "transport": {"enum": ["http"]},
        "authentication": {"enum": ["oauth"]}
      }
    },
    "module_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query", "create"],
      "properties": {
        "query": {"$ref": "#/$defs/moduleRule"},
        "create": {"$ref": "#/$defs/moduleRule"}
      }
    },
    "available_tools": {"type": "array", "items": {"$ref": "#/$defs/tool"}},
    "required_tools": {"type": "array", "items": {"$ref": "#/$defs/tool"}},
    "release_rules": {
      "type": "object",
      "additionalProperties": {"type": "boolean"}
    }
  },
  "$defs": {
    "moduleRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_access", "may_invoke"],
      "properties": {
        "allowed_access": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["read", "write", "external_write"]}},
        "may_invoke": {"type": "array", "uniqueItems": true, "items": {"enum": ["query", "create"]}}
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "module", "authorization_scope", "access", "purpose", "used_by"],
      "properties": {
        "tool": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "module": {"enum": ["query", "create"]},
        "authorization_scope": {"enum": ["cuebook.query", "cuebook.create.write", "cuebook.publish"]},
        "phase": {"enum": ["r0", "r1", "r2"]},
        "access": {"enum": ["read", "write", "external_write"]},
        "purpose": {"type": "string", "minLength": 1},
        "input_contract": {"type": "string", "minLength": 1},
        "output_contract": {"type": "string", "minLength": 1},
        "used_by": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9-]+$"}}
      }
    }
  }
}
