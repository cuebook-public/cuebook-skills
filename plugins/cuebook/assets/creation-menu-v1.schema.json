{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.xyz/schemas/creation-menu-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_version", "module_id", "default_preset", "steps", "write_actions"],
  "properties": {
    "schema_version": {"const": "creation-menu-v1"},
    "catalog_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "module_id": {"const": "create"},
    "default_preset": {"type": "string", "minLength": 1},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "label", "selection", "minimum", "maximum", "options"],
        "properties": {
          "step_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "label": {"type": "string", "minLength": 1},
          "selection": {"enum": ["single", "multi"]},
          "minimum": {"type": "integer", "minimum": 0},
          "maximum": {"type": "integer", "minimum": 1},
          "options": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["option_id", "label"],
              "properties": {
                "option_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
                "label": {"type": "string", "minLength": 1},
                "skill_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9-]+$"}},
                "mcp_tools": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}},
                "availability": {"enum": ["available", "backend_required"]},
                "default": {"type": "boolean"}
              }
            }
          }
        }
      }
    },
    "write_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action_id", "label", "mcp_tool", "availability", "required_gates"],
        "properties": {
          "action_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "label": {"type": "string", "minLength": 1},
          "mcp_tool": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "availability": {"const": "backend_required"},
          "required_gates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9_]+$"}}
        }
      }
    }
  }
}
