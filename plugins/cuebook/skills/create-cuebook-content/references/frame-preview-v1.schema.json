{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/frame-preview-v1.schema.json",
  "title": "FramePreviewV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "preview_id", "state", "created_at", "creator_view", "query_binding", "generation", "candidates", "selection", "blockers"],
  "properties": {
    "schema_version": {"const": "frame-preview-v1"},
    "preview_id": {"type": "string", "pattern": "^FPREV_[A-Za-z0-9_:-]{6,}$"},
    "state": {"enum": ["ready", "conditional", "selected", "blocked"]},
    "created_at": {"type": "string", "format": "date-time"},
    "creator_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original_text", "subject", "direction", "horizon", "claim", "mechanism", "next_watch"],
      "properties": {
        "original_text": {"type": "string", "minLength": 2, "maxLength": 4000},
        "subject": {"type": "string", "minLength": 1, "maxLength": 80},
        "direction": {"enum": ["long", "short", "outperform", "underperform", "range", "avoid", "watch", "neutral", "explain"]},
        "horizon": {"type": "string", "minLength": 1, "maxLength": 80},
        "claim": {"type": "string", "minLength": 2, "maxLength": 200},
        "mechanism": {"type": "string", "minLength": 2, "maxLength": 240},
        "next_watch": {"type": "string", "minLength": 2, "maxLength": 160}
      }
    },
    "query_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "status", "bundle_refs", "result_refs", "as_of", "warnings", "unavailable_capabilities"],
      "properties": {
        "required": {"type": "boolean"},
        "status": {"enum": ["not_required", "reused", "executed", "partial", "unavailable"]},
        "bundle_refs": {"$ref": "#/$defs/stringSet"},
        "result_refs": {"$ref": "#/$defs/stringSet"},
        "as_of": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
        "warnings": {"$ref": "#/$defs/stringSet"},
        "unavailable_capabilities": {"$ref": "#/$defs/stringSet"}
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "candidate_count"],
      "properties": {
        "mode": {"enum": ["recommended_one", "requested_three"]},
        "candidate_count": {"enum": [1, 3]}
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 0,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "angle", "template_id", "frame", "image_sha256", "evidence_refs", "quality_checks"],
        "properties": {
          "candidate_id": {"type": "string", "pattern": "^FPREV_CAND_[A-Za-z0-9_:-]{4,}$"},
          "angle": {"enum": ["conviction", "evidence", "mechanism"]},
          "template_id": {"enum": ["verdict", "proof", "system"]},
          "frame": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "body", "image_ref", "alt_text"],
            "properties": {
              "title": {"type": "string", "minLength": 2, "maxLength": 32},
              "body": {"type": "string", "minLength": 20, "maxLength": 280},
              "image_ref": {"type": "string", "pattern": "^[^/].*\\.png$"},
              "alt_text": {"type": "string", "minLength": 2, "maxLength": 160}
            }
          },
          "image_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "evidence_refs": {"$ref": "#/$defs/stringSet"},
          "quality_checks": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "uniqueItems": true,
            "items": {"enum": ["creator_ownership", "source_binding", "copy_fit", "image_render"]}
          }
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_candidate_id", "confirmed"],
      "properties": {
        "selected_candidate_id": {"anyOf": [{"type": "null"}, {"type": "string", "pattern": "^FPREV_CAND_[A-Za-z0-9_:-]{4,}$"}]},
        "confirmed": {"type": "boolean"}
      }
    },
    "blockers": {"$ref": "#/$defs/stringSet"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}}
  }
}
