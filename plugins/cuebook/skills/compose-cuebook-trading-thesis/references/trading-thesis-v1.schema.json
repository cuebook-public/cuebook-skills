{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/trading-thesis-v1.schema.json",
  "title": "Cuebook TradingThesisV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "thesis_id",
    "revision",
    "lifecycle_state",
    "timestamps",
    "author",
    "lineage",
    "market",
    "claim",
    "evidence_ledger",
    "reasoning",
    "setup",
    "resolution",
    "disclosure",
    "relations",
    "quality_report"
  ],
  "properties": {
    "schema_version": {"const": "trading-thesis-v1"},
    "thesis_id": {"$ref": "#/$defs/thesisId"},
    "revision": {"type": "integer", "minimum": 1},
    "lifecycle_state": {"enum": ["draft", "conditional", "ready", "frozen"]},
    "timestamps": {"$ref": "#/$defs/timestamps"},
    "author": {"$ref": "#/$defs/author"},
    "lineage": {"$ref": "#/$defs/lineage"},
    "market": {"$ref": "#/$defs/market"},
    "claim": {"$ref": "#/$defs/claim"},
    "idea_provenance": {"anyOf": [{"$ref": "#/$defs/ideaProvenance"}, {"type": "null"}]},
    "evidence_ledger": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
    "reasoning": {"$ref": "#/$defs/reasoning"},
    "setup": {"$ref": "#/$defs/setup"},
    "resolution": {"$ref": "#/$defs/resolution"},
    "disclosure": {"$ref": "#/$defs/disclosure"},
    "relations": {"$ref": "#/$defs/relations"},
    "quality_report": {"$ref": "#/$defs/qualityReport"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"type": ["string", "null"]},
    "nullableNumber": {"type": ["number", "null"]},
    "nullableDateTime": {
      "anyOf": [
        {"type": "string", "format": "date-time"},
        {"type": "null"}
      ]
    },
    "stringSet": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "thesisId": {"type": "string", "pattern": "^THESIS_[a-z0-9]{8,64}$"},
    "thesisRef": {"type": "string", "pattern": "^THESIS_[a-z0-9]{8,64}@r[1-9][0-9]*$"},
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "updated_at", "as_of", "decision_cutoff_at", "activated_at", "expires_at"],
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "as_of": {"type": "string", "format": "date-time"},
        "decision_cutoff_at": {"type": "string", "format": "date-time"},
        "activated_at": {"$ref": "#/$defs/nullableDateTime"},
        "expires_at": {"$ref": "#/$defs/nullableDateTime"}
      }
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["creator_ref", "author_type"],
      "properties": {
        "creator_ref": {"$ref": "#/$defs/nonemptyString"},
        "author_type": {"enum": ["human", "ai", "hybrid"]}
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_artifact_refs", "root_thesis_ref", "previous_revision_ref", "canonical_hash"],
      "properties": {
        "source_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "root_thesis_ref": {"anyOf": [{"$ref": "#/$defs/thesisRef"}, {"type": "null"}]},
        "previous_revision_ref": {"anyOf": [{"$ref": "#/$defs/thesisRef"}, {"type": "null"}]},
        "canonical_hash": {
          "anyOf": [
            {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
            {"type": "null"}
          ]
        }
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrument_id", "display_name", "ticker", "asset_class", "venue", "quote_currency", "direction", "relationship", "projection_gate_ref", "proxy_reason"],
      "properties": {
        "instrument_id": {"$ref": "#/$defs/nonemptyString"},
        "display_name": {"$ref": "#/$defs/nonemptyString"},
        "ticker": {"$ref": "#/$defs/nullableString"},
        "asset_class": {"enum": ["equity", "etf", "index", "commodity", "fx", "rates", "credit", "crypto", "prediction_market", "other"]},
        "venue": {"$ref": "#/$defs/nonemptyString"},
        "quote_currency": {"$ref": "#/$defs/nullableString"},
        "direction": {"enum": ["long", "short", "neutral", "conditional"]},
        "relationship": {"enum": ["direct", "supported_proxy", "watch_only"]},
        "projection_gate_ref": {"$ref": "#/$defs/nullableString"},
        "proxy_reason": {"$ref": "#/$defs/nullableString"}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "why_now", "horizon", "confidence", "probability", "probability_basis"],
      "properties": {
        "statement": {"$ref": "#/$defs/nonemptyString"},
        "why_now": {"$ref": "#/$defs/nonemptyString"},
        "horizon": {"$ref": "#/$defs/nonemptyString"},
        "confidence": {"enum": ["low", "medium", "high"]},
        "probability": {"anyOf": [{"type": "number", "minimum": 0, "maximum": 1}, {"type": "null"}]},
        "probability_basis": {"$ref": "#/$defs/nullableString"}
      }
    },
    "ideaContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary", "evidence_refs"],
      "properties": {
        "kind": {"enum": ["evidence", "connection", "countercase", "market_context", "settlement_rule"]},
        "summary": {"$ref": "#/$defs/nonemptyString"},
        "evidence_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "ideaProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "creator_seed", "cuebook_contributions", "creator_decision", "idea_delta", "final_trade_idea", "public_attribution"],
      "properties": {
        "mode": {"enum": ["creator_led", "cuebook_assisted", "cuebook_generated"]},
        "creator_seed": {"$ref": "#/$defs/nullableString"},
        "cuebook_contributions": {"type": "array", "items": {"$ref": "#/$defs/ideaContribution"}},
        "creator_decision": {"$ref": "#/$defs/nonemptyString"},
        "idea_delta": {"enum": ["unchanged", "strengthened", "weakened", "narrowed", "conditionalized", "reversed", "abandoned"]},
        "final_trade_idea": {"$ref": "#/$defs/nonemptyString"},
        "public_attribution": {"type": "boolean"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "claim", "evidence_class", "source_ref", "as_of", "freshness", "role"],
      "properties": {
        "id": {"type": "string", "pattern": "^E[1-9][0-9]*$"},
        "claim": {"$ref": "#/$defs/nonemptyString"},
        "evidence_class": {"enum": ["source", "verified_live", "derived", "hypothesis"]},
        "source_ref": {"$ref": "#/$defs/nullableString"},
        "as_of": {"$ref": "#/$defs/nullableDateTime"},
        "freshness": {"enum": ["current", "stale", "unknown"]},
        "role": {"enum": ["supports", "challenges", "context"]}
      }
    },
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "claim", "status", "evidence_refs"],
      "properties": {
        "step": {"type": "integer", "minimum": 1},
        "claim": {"$ref": "#/$defs/nonemptyString"},
        "status": {"enum": ["sourced", "derived", "hypothesis"]},
        "evidence_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "condition", "expected_path", "signposts", "invalidation", "evidence_refs"],
      "properties": {
        "id": {"type": "string", "pattern": "^SC[1-9][0-9]*$"},
        "label": {"$ref": "#/$defs/nonemptyString"},
        "condition": {"$ref": "#/$defs/nonemptyString"},
        "expected_path": {"$ref": "#/$defs/nonemptyString"},
        "signposts": {"$ref": "#/$defs/stringSet"},
        "invalidation": {"$ref": "#/$defs/nonemptyString"},
        "evidence_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "reasoning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanisms", "supporting_evidence_refs", "counterevidence_refs", "gaps", "scenarios"],
      "properties": {
        "mechanisms": {"type": "array", "items": {"$ref": "#/$defs/mechanism"}},
        "supporting_evidence_refs": {"$ref": "#/$defs/stringSet"},
        "counterevidence_refs": {"$ref": "#/$defs/stringSet"},
        "gaps": {"$ref": "#/$defs/stringSet"},
        "scenarios": {"type": "array", "items": {"$ref": "#/$defs/scenario"}}
      }
    },
    "referenceObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "observed_at", "observation_basis", "market_state", "source_ref"],
      "properties": {
        "value": {"type": ["number", "string", "null"]},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "observed_at": {"$ref": "#/$defs/nullableDateTime"},
        "observation_basis": {"enum": ["last_trade", "last_close", "midpoint", "nav", "official_close", "official_settlement", "spot", "other"]},
        "market_state": {"enum": ["regular", "pre", "after", "overnight", "closed", "continuous", "unknown"]},
        "source_ref": {"$ref": "#/$defs/nullableString"}
      }
    },
    "catalyst": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "expected_at", "evidence_refs"],
      "properties": {
        "event": {"$ref": "#/$defs/nonemptyString"},
        "expected_at": {"$ref": "#/$defs/nullableDateTime"},
        "evidence_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "setup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference_observation", "action_state", "entry_condition", "trigger_condition", "catalysts", "invalidation"],
      "properties": {
        "reference_observation": {"$ref": "#/$defs/referenceObservation"},
        "action_state": {"enum": ["enter_now", "wait_for_trigger", "observe_only", "hold", "avoid", "exit"]},
        "entry_condition": {"$ref": "#/$defs/nonemptyString"},
        "trigger_condition": {"$ref": "#/$defs/nullableString"},
        "catalysts": {"type": "array", "items": {"$ref": "#/$defs/catalyst"}},
        "invalidation": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_value", "lower_bound", "upper_bound", "unit"],
      "properties": {
        "target_value": {"$ref": "#/$defs/nullableNumber"},
        "lower_bound": {"$ref": "#/$defs/nullableNumber"},
        "upper_bound": {"$ref": "#/$defs/nullableNumber"},
        "unit": {"$ref": "#/$defs/nullableString"}
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evaluation_kind", "metric", "operator", "threshold", "observation_basis", "window_start", "window_end", "data_source_ref", "benchmark_ref", "fallback_source_refs", "timezone", "adjustments_policy", "ambiguity_policy", "score_modes"],
      "properties": {
        "status": {"enum": ["complete", "incomplete", "not_applicable"]},
        "evaluation_kind": {"enum": ["price_target", "directional_return", "relative_performance", "event_occurrence", "range", "none"]},
        "metric": {"enum": ["spot_price", "official_settlement_price", "total_return_pct", "excess_return_pct", "event_status", "range_value", "none"]},
        "operator": {"enum": ["gt", "gte", "lt", "lte", "between", "occurred", "not_occurred", "none"]},
        "threshold": {"$ref": "#/$defs/threshold"},
        "observation_basis": {"enum": ["close", "official_settlement", "intraday_high", "intraday_low", "vwap", "event_status", "none"]},
        "window_start": {"$ref": "#/$defs/nullableDateTime"},
        "window_end": {"$ref": "#/$defs/nullableDateTime"},
        "data_source_ref": {"$ref": "#/$defs/nullableString"},
        "benchmark_ref": {"$ref": "#/$defs/nullableString"},
        "fallback_source_refs": {"$ref": "#/$defs/stringSet"},
        "timezone": {"$ref": "#/$defs/nonemptyString"},
        "adjustments_policy": {"$ref": "#/$defs/nonemptyString"},
        "ambiguity_policy": {"enum": ["manual_review", "annul", "fallback_source"]},
        "score_modes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["binary_accuracy", "brier", "directional_accuracy", "return", "excess_return"]}
        }
      }
    },
    "disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibility", "position_status", "position_text", "commercial_status", "commercial_text", "identity_status", "ai_assistance_status", "public_disclosures"],
      "properties": {
        "visibility": {"enum": ["private", "unlisted", "public"]},
        "position_status": {"enum": ["unknown", "none", "long", "short", "mixed"]},
        "position_text": {"$ref": "#/$defs/nullableString"},
        "commercial_status": {"enum": ["unknown", "none", "sponsored", "issuer_relationship", "other"]},
        "commercial_text": {"$ref": "#/$defs/nullableString"},
        "identity_status": {"enum": ["unknown", "verified", "pseudonymous", "ai_identity"]},
        "ai_assistance_status": {"enum": ["unknown", "none", "assisted", "generated"]},
        "public_disclosures": {"$ref": "#/$defs/stringSet"}
      }
    },
    "relations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supports", "challenges", "forks", "supersedes"],
      "properties": {
        "supports": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/thesisRef"}},
        "challenges": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/thesisRef"}},
        "forks": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/thesisRef"}},
        "supersedes": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/thesisRef"}}
      }
    },
    "qualityCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence", "supporting", "challenging", "mechanisms", "scenarios"],
      "properties": {
        "evidence": {"type": "integer", "minimum": 0},
        "supporting": {"type": "integer", "minimum": 0},
        "challenging": {"type": "integer", "minimum": 0},
        "mechanisms": {"type": "integer", "minimum": 0},
        "scenarios": {"type": "integer", "minimum": 0}
      }
    },
    "qualityReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "evidence_decision", "resolution_decision", "publication_decision", "hard_failures", "warnings", "checks", "counts"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "evidence_decision": {"enum": ["ready", "conditional", "blocked"]},
        "resolution_decision": {"enum": ["ready", "conditional", "blocked"]},
        "publication_decision": {"enum": ["ready", "conditional", "blocked"]},
        "hard_failures": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "checks": {"type": "array", "items": {"type": "string"}},
        "counts": {"$ref": "#/$defs/qualityCounts"}
      }
    }
  }
}
