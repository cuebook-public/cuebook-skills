{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/corpus-v1.schema.json",
  "title": "CorpusV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "corpus_id",
    "generated_at",
    "subject",
    "items",
    "provenance",
    "stats",
    "quality"
  ],
  "properties": {
    "schema_version": {"const": "corpus.v1"},
    "corpus_id": {"type": "string", "pattern": "^corpus_[a-f0-9]{16}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "subject": {"$ref": "#/$defs/subject"},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/item"}
    },
    "provenance": {"$ref": "#/$defs/corpusProvenance"},
    "stats": {"$ref": "#/$defs/stats"},
    "quality": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "nullableDateTime": {
      "anyOf": [
        {"type": "string", "format": "date-time"},
        {"type": "null"}
      ]
    },
    "nullableUri": {
      "anyOf": [
        {"type": "string", "format": "uri"},
        {"type": "null"}
      ]
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "handles", "platforms"],
      "properties": {
        "name": {"$ref": "#/$defs/nullableString"},
        "handles": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "platforms": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "handle"],
      "properties": {
        "name": {"$ref": "#/$defs/nullableString"},
        "handle": {"$ref": "#/$defs/nullableString"}
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "domain", "kind"],
      "properties": {
        "url": {"type": "string", "format": "uri"},
        "domain": {"type": "string", "minLength": 1},
        "kind": {
          "type": "string",
          "enum": ["source", "citation", "media", "external", "other"]
        },
        "title": {"type": "string"}
      }
    },
    "entities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tickers",
        "hashtags",
        "mentions",
        "organizations",
        "people",
        "locations",
        "other"
      ],
      "properties": {
        "tickers": {"$ref": "#/$defs/stringSet"},
        "hashtags": {"$ref": "#/$defs/stringSet"},
        "mentions": {"$ref": "#/$defs/stringSet"},
        "organizations": {"$ref": "#/$defs/stringSet"},
        "people": {"$ref": "#/$defs/stringSet"},
        "locations": {"$ref": "#/$defs/stringSet"},
        "other": {"$ref": "#/$defs/stringSet"}
      }
    },
    "stringSet": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "observed_at", "values", "missing"],
      "properties": {
        "available": {"type": "boolean"},
        "observed_at": {"$ref": "#/$defs/nullableDateTime"},
        "values": {
          "type": "object",
          "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"},
          "additionalProperties": {"type": "number", "minimum": 0}
        },
        "missing": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["likes", "reposts", "replies", "views", "bookmarks", "quotes"]
          }
        }
      }
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_label",
        "source_file",
        "source_file_sha256",
        "source_record_index",
        "source_record_id",
        "source_url"
      ],
      "properties": {
        "source_label": {"type": "string", "minLength": 1},
        "source_file": {"type": "string", "minLength": 1},
        "source_file_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_record_index": {"type": "integer", "minimum": 0},
        "source_record_id": {"$ref": "#/$defs/nullableString"},
        "source_url": {"$ref": "#/$defs/nullableUri"},
        "upstream": {"type": "object"}
      }
    },
    "itemProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rights_basis", "records", "transformations"],
      "properties": {
        "rights_basis": {"enum": ["public", "authorized"]},
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/sourceRecord"}
        },
        "transformations": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "external_id",
        "platform",
        "author",
        "content_type",
        "text",
        "created_at",
        "url",
        "language",
        "links",
        "entities",
        "metrics",
        "provenance"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^item_[a-f0-9]{16}$"},
        "external_id": {"$ref": "#/$defs/nullableString"},
        "platform": {"type": "string", "minLength": 1},
        "author": {"$ref": "#/$defs/author"},
        "content_type": {
          "enum": ["post", "article", "newsletter", "transcript", "comment", "other"]
        },
        "text": {"type": "string", "minLength": 1},
        "created_at": {"$ref": "#/$defs/nullableDateTime"},
        "url": {"$ref": "#/$defs/nullableUri"},
        "language": {"type": "string", "minLength": 2},
        "links": {
          "type": "array",
          "items": {"$ref": "#/$defs/link"}
        },
        "entities": {"$ref": "#/$defs/entities"},
        "metrics": {"$ref": "#/$defs/metrics"},
        "provenance": {"$ref": "#/$defs/itemProvenance"}
      }
    },
    "inputFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "format", "sha256", "records"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "format": {"enum": ["json", "jsonl", "csv"]},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "records": {"type": "integer", "minimum": 0}
      }
    },
    "corpusProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rights_basis", "source_label", "inputs", "normalized_at", "normalizer"],
      "properties": {
        "rights_basis": {"enum": ["public", "authorized"]},
        "source_label": {"type": "string", "minLength": 1},
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/inputFile"}
        },
        "normalized_at": {"type": "string", "format": "date-time"},
        "normalizer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"const": "normalize_corpus.py"},
            "version": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_records",
        "output_items",
        "duplicates_removed",
        "metrics_items",
        "languages",
        "platforms"
      ],
      "properties": {
        "input_records": {"type": "integer", "minimum": 0},
        "output_items": {"type": "integer", "minimum": 1},
        "duplicates_removed": {"type": "integer", "minimum": 0},
        "metrics_items": {"type": "integer", "minimum": 0},
        "languages": {"$ref": "#/$defs/countMap"},
        "platforms": {"$ref": "#/$defs/countMap"}
      }
    },
    "countMap": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warnings", "skipped_records", "duplicates_removed"],
      "properties": {
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        },
        "skipped_records": {"type": "integer", "minimum": 0},
        "duplicates_removed": {"type": "integer", "minimum": 0}
      }
    }
  }
}
