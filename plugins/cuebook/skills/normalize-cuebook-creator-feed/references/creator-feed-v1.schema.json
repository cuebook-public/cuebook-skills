{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/creator-feed-v1.schema.json",
  "title": "CreatorFeedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "feed_id", "generated_at", "as_of", "knowledge_cutoff_at",
    "input_hash", "ruleset_version", "brief", "source_register", "entities",
    "news", "calendar_events", "narratives", "trade_ideas", "trade_history",
    "links", "quality_report"
  ],
  "properties": {
    "schema_version": {"const": "creator-feed-v1"},
    "feed_id": {"type": "string", "pattern": "^CF_[a-z0-9]{8,64}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "as_of": {"type": "string", "format": "date-time"},
    "knowledge_cutoff_at": {"type": "string", "format": "date-time"},
    "input_hash": {"$ref": "#/$defs/hash"},
    "ruleset_version": {"type": "string", "minLength": 1},
    "brief": {"$ref": "#/$defs/brief"},
    "source_register": {"type": "array", "items": {"$ref": "#/$defs/source"}},
    "entities": {"type": "array", "items": {"$ref": "#/$defs/entity"}},
    "news": {"type": "array", "items": {"$ref": "#/$defs/news"}},
    "calendar_events": {"type": "array", "items": {"$ref": "#/$defs/calendar"}},
    "narratives": {"type": "array", "items": {"$ref": "#/$defs/narrative"}},
    "trade_ideas": {"type": "array", "items": {"$ref": "#/$defs/idea"}},
    "trade_history": {"type": "array", "items": {"$ref": "#/$defs/trade"}},
    "links": {"type": "array", "items": {"$ref": "#/$defs/link"}},
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "nullableTime": {"type": ["string", "null"], "format": "date-time"},
    "refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "recordStatus": {"enum": ["active", "quarantined", "superseded", "retracted", "expired"]},
    "brief": {
      "type": "object", "additionalProperties": false,
      "required": ["workspace_ref", "creator_ref", "snapshot_ref", "timezone", "locale", "universe", "personalized_advice_allowed"],
      "properties": {
        "workspace_ref": {"type": "string", "minLength": 1},
        "creator_ref": {"type": "string", "minLength": 1},
        "snapshot_ref": {"type": "string", "minLength": 1},
        "timezone": {"type": "string", "minLength": 1},
        "locale": {"type": "string", "minLength": 1},
        "universe": {"type": "array", "items": {"type": "string"}},
        "personalized_advice_allowed": {"const": false}
      }
    },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "revision_id", "source_type", "publisher", "locator", "external_id", "content_hash", "published_at", "source_updated_at", "observed_at", "authorized_at", "available_at", "access", "reuse_rights", "trust_state", "independent_cluster_id"],
      "properties": {
        "id": {"type": "string", "pattern": "^SRC_[a-z0-9_:-]+$"},
        "revision_id": {"$ref": "#/$defs/hash"},
        "source_type": {"enum": ["official_filing", "company_release", "official_data", "exchange", "market_data", "consensus_data", "transcript", "reputable_news", "specialist_research", "social", "user_supplied", "internal"]},
        "publisher": {"type": "string", "minLength": 1},
        "locator": {"type": "string", "minLength": 1},
        "external_id": {"type": ["string", "null"]},
        "content_hash": {"$ref": "#/$defs/hash"},
        "published_at": {"$ref": "#/$defs/nullableTime"},
        "source_updated_at": {"$ref": "#/$defs/nullableTime"},
        "observed_at": {"type": "string", "format": "date-time"},
        "authorized_at": {"$ref": "#/$defs/nullableTime"},
        "available_at": {"type": "string", "format": "date-time"},
        "access": {"enum": ["public", "authorized", "restricted", "unknown"]},
        "reuse_rights": {"enum": ["quote_allowed", "summarize_allowed", "internal_only", "unknown"]},
        "trust_state": {"enum": ["verified", "unverified", "disputed", "retracted"]},
        "independent_cluster_id": {"type": "string", "minLength": 1}
      }
    },
    "entity": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "canonical_name", "symbol_aliases"],
      "properties": {
        "id": {"type": "string", "pattern": "^ENT_[a-z0-9_:-]+$"},
        "kind": {"enum": ["company", "instrument", "sector", "commodity", "macro", "country", "crypto", "fund", "index", "other"]},
        "canonical_name": {"type": "string", "minLength": 1},
        "symbol_aliases": {"type": "array", "items": {"$ref": "#/$defs/alias"}}
      }
    },
    "alias": {
      "type": "object", "additionalProperties": false,
      "required": ["symbol", "venue", "valid_from", "valid_to"],
      "properties": {
        "symbol": {"type": "string", "minLength": 1},
        "venue": {"type": ["string", "null"]},
        "valid_from": {"$ref": "#/$defs/nullableTime"},
        "valid_to": {"$ref": "#/$defs/nullableTime"}
      }
    },
    "recordBase": {
      "type": "object",
      "required": ["id", "revision_id", "record_status", "entity_refs", "source_refs", "available_at"],
      "properties": {
        "id": {"type": "string"}, "revision_id": {"$ref": "#/$defs/hash"},
        "record_status": {"$ref": "#/$defs/recordStatus"},
        "entity_refs": {"$ref": "#/$defs/refs"}, "source_refs": {"$ref": "#/$defs/refs"},
        "available_at": {"type": "string", "format": "date-time"}
      }
    },
    "news": {
      "allOf": [{"$ref": "#/$defs/recordBase"}], "type": "object", "unevaluatedProperties": false,
      "required": ["id", "revision_id", "record_status", "headline", "summary", "entity_refs", "source_refs", "cluster_id", "occurred_at", "published_at", "observed_at", "available_at", "evidence_role"],
      "properties": {
        "id": {"pattern": "^NEWS_[a-z0-9_:-]+$"}, "revision_id": {}, "record_status": {},
        "headline": {"type": "string", "minLength": 1}, "summary": {"type": ["string", "null"]},
        "entity_refs": {}, "source_refs": {}, "cluster_id": {"type": "string", "minLength": 1},
        "occurred_at": {"$ref": "#/$defs/nullableTime"}, "published_at": {"$ref": "#/$defs/nullableTime"},
        "observed_at": {"type": "string", "format": "date-time"}, "available_at": {},
        "evidence_role": {"enum": ["discovery", "attributable_fact", "research_lead"]}
      }
    },
    "calendar": {
      "allOf": [{"$ref": "#/$defs/recordBase"}], "type": "object", "unevaluatedProperties": false,
      "required": ["id", "revision_id", "record_status", "label", "event_type", "event_status", "entity_refs", "source_refs", "scheduled_at", "timezone", "available_at", "previous_revision_refs"],
      "properties": {
        "id": {"pattern": "^CAL_[a-z0-9_:-]+$"}, "revision_id": {}, "record_status": {},
        "label": {"type": "string", "minLength": 1},
        "event_type": {"enum": ["earnings", "macro_release", "corporate_action", "conference", "policy", "listing", "expiry", "other"]},
        "event_status": {"enum": ["scheduled", "rescheduled", "cancelled", "completed_unknown", "completed_verified"]},
        "entity_refs": {}, "source_refs": {}, "scheduled_at": {"type": "string", "format": "date-time"},
        "timezone": {"type": "string", "minLength": 1}, "available_at": {},
        "previous_revision_refs": {"$ref": "#/$defs/refs"}
      }
    },
    "narrative": {
      "allOf": [{"$ref": "#/$defs/recordBase"}], "type": "object", "unevaluatedProperties": false,
      "required": ["id", "revision_id", "record_status", "origin", "narrative_class", "claim", "entity_refs", "source_refs", "created_at", "available_at", "horizon", "mechanism", "evidence_gaps", "falsifier"],
      "properties": {
        "id": {"pattern": "^NAR_[a-z0-9_:-]+$"}, "revision_id": {}, "record_status": {},
        "origin": {"enum": ["model", "human", "source"]},
        "narrative_class": {"enum": ["hypothesis", "derived", "source_bound"]},
        "claim": {"type": "string", "minLength": 1}, "entity_refs": {}, "source_refs": {},
        "created_at": {"type": "string", "format": "date-time"}, "available_at": {},
        "horizon": {"type": "string", "minLength": 1},
        "mechanism": {"type": "array", "items": {"type": "string"}},
        "evidence_gaps": {"type": "array", "items": {"type": "string"}},
        "falsifier": {"type": "string", "minLength": 1}
      }
    },
    "idea": {
      "allOf": [{"$ref": "#/$defs/recordBase"}], "type": "object", "unevaluatedProperties": false,
      "required": ["id", "revision_id", "record_status", "thesis", "direction", "entity_refs", "source_refs", "catalyst_refs", "created_at", "observed_at", "available_at", "horizon", "invalidation", "evidence_state", "execution_state"],
      "properties": {
        "id": {"pattern": "^IDEA_[a-z0-9_:-]+$"}, "revision_id": {}, "record_status": {},
        "thesis": {"type": "string", "minLength": 1},
        "direction": {"enum": ["long", "short", "relative", "volatility", "event", "watch", "no_direction"]},
        "entity_refs": {}, "source_refs": {}, "catalyst_refs": {"$ref": "#/$defs/refs"},
        "created_at": {"type": "string", "format": "date-time"},
        "observed_at": {"type": "string", "format": "date-time"}, "available_at": {},
        "horizon": {"type": "string", "minLength": 1}, "invalidation": {"type": "string", "minLength": 1},
        "evidence_state": {"enum": ["unresearched", "partial", "researched"]},
        "execution_state": {"enum": ["idea_only", "paper"]}
      }
    },
    "trade": {
      "allOf": [{"$ref": "#/$defs/recordBase"}], "type": "object", "unevaluatedProperties": false,
      "required": ["id", "revision_id", "record_status", "trade_type", "entity_refs", "source_refs", "idea_ref", "side", "lifecycle_state", "opened_at", "closed_at", "recorded_at", "available_at", "execution_verification", "position_disclosure", "commercial_relationship", "public_reuse_permission", "performance"],
      "properties": {
        "id": {"pattern": "^TRADE_[a-z0-9_:-]+$"}, "revision_id": {}, "record_status": {},
        "trade_type": {"enum": ["idea", "paper", "executed"]}, "entity_refs": {}, "source_refs": {},
        "idea_ref": {"type": ["string", "null"]}, "side": {"enum": ["long", "short", "mixed", "flat", "unknown"]},
        "lifecycle_state": {"enum": ["open", "closed", "cancelled", "unknown"]},
        "opened_at": {"$ref": "#/$defs/nullableTime"}, "closed_at": {"$ref": "#/$defs/nullableTime"},
        "recorded_at": {"type": "string", "format": "date-time"}, "available_at": {},
        "execution_verification": {"enum": ["not_applicable", "self_reported", "broker_reconciled"]},
        "position_disclosure": {"enum": ["public_long", "public_short", "public_mixed", "public_flat", "private", "unknown"]},
        "commercial_relationship": {"enum": ["none", "affiliate", "sponsor", "client", "employer", "issuer_relationship", "private", "unknown"]},
        "public_reuse_permission": {"enum": ["private", "aggregate_only", "record_allowed", "unknown"]},
        "performance": {"$ref": "#/$defs/performance"}
      }
    },
    "performance": {
      "type": "object", "additionalProperties": false,
      "required": ["return_pct", "pnl_amount", "currency", "fees_included", "basis"],
      "properties": {
        "return_pct": {"type": ["number", "null"]}, "pnl_amount": {"type": ["number", "null"]},
        "currency": {"type": ["string", "null"]}, "fees_included": {"type": ["boolean", "null"]},
        "basis": {"enum": ["none", "idea_score", "paper", "executed_raw", "executed_reconciled", "unknown"]}
      }
    },
    "link": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "from_ref", "to_ref", "relation"],
      "properties": {
        "id": {"type": "string", "pattern": "^LINK_[a-z0-9_:-]+$"},
        "from_ref": {"type": "string"}, "to_ref": {"type": "string"},
        "relation": {"enum": ["supports", "contradicts", "updates", "supersedes", "same_as", "catalyst_for", "history_of", "derived_from"]}
      }
    },
    "quality": {
      "type": "object", "additionalProperties": false,
      "required": ["decision", "hard_failures", "warnings", "checks", "record_counts", "quarantined_records"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "hard_failures": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "checks": {"type": "array", "items": {"type": "string"}},
        "record_counts": {
          "type": "object", "additionalProperties": false,
          "required": ["sources", "entities", "news", "calendar_events", "narratives", "trade_ideas", "trade_history", "links", "quarantined"],
          "properties": {
            "sources": {"type": "integer", "minimum": 0}, "entities": {"type": "integer", "minimum": 0},
            "news": {"type": "integer", "minimum": 0}, "calendar_events": {"type": "integer", "minimum": 0},
            "narratives": {"type": "integer", "minimum": 0}, "trade_ideas": {"type": "integer", "minimum": 0},
            "trade_history": {"type": "integer", "minimum": 0}, "links": {"type": "integer", "minimum": 0},
            "quarantined": {"type": "integer", "minimum": 0}
          }
        },
        "quarantined_records": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    }
  }
}
