  "evidence_contracts": {
    "creator_judgment": {"required_fields": ["creator_input_ref", "judgment_text", "direction"], "geometry_channels": ["type", "position"], "compact_fallback": "one judgment line", "integrity": "Creator-owned language may lead the image but cannot encode measured magnitude."},
    "point_metric": {"required_fields": ["value", "unit", "as_of", "basis", "source_ref"], "geometry_channels": ["type", "position", "length"], "compact_fallback": "one value with unit and basis", "integrity": "Comparable values share unit, period, currency, and calculation basis."},
    "level": {"required_fields": ["value", "unit", "relation", "observed_at", "source_ref"], "geometry_channels": ["position", "stroke", "label"], "compact_fallback": "one directly labeled threshold", "integrity": "A level is explicit in the source or deterministic calculation; it is never inferred for symmetry."},
    "ordered_series": {"required_fields": ["points", "x_field", "y_field", "unit", "observed_at", "source_ref"], "geometry_channels": ["position", "slope", "stroke"], "compact_fallback": "direct-labeled observed curve", "integrity": "Preserve point order and values; declare any smoothing, transformation, or missing-value policy."},
    "multi_series": {"required_fields": ["series", "synchronization_rule", "normalization", "unit", "observed_at", "source_refs"], "geometry_channels": ["position", "slope", "stroke", "color"], "compact_fallback": "two direct-labeled synchronized series", "integrity": "Subjects share timestamps, currency, adjustment, and normalization basis."},
    "ohlcv_series": {"required_fields": ["bars", "interval", "range", "adjustment", "timezone", "source_ref"], "geometry_channels": ["position", "length", "stroke", "area"], "compact_fallback": "approved thesis-chart crop", "integrity": "Route through render-cuebook-thesis-chart; do not replace bars or volume with a decorative line."},
    "event_set": {"required_fields": ["events", "event_id", "headline", "publisher", "event_time", "available_at", "source_ref"], "geometry_channels": ["position", "sequence", "label"], "compact_fallback": "one catalyst and its reaction", "integrity": "Keep event time separate from when the information became available to the market."},
    "news_cluster": {"required_fields": ["events", "event_id", "headline", "publisher", "event_time", "available_at", "source_ref", "cluster_id", "cluster_method", "unique_source_count"], "geometry_channels": ["position", "grouping", "count"], "compact_fallback": "top two deduplicated events plus synthesis", "integrity": "Deduplicate reports of the same event; article count is not independent evidence, importance, sentiment, or consensus."},
    "calendar_events": {"required_fields": ["events", "event_id", "date", "date_precision", "status", "source_ref"], "geometry_channels": ["position", "sequence", "label"], "compact_fallback": "next two catalysts", "integrity": "Unconfirmed or approximate dates remain visibly provisional."},
    "qualitative_relation": {"required_fields": ["from", "to", "relation", "state", "source_refs"], "geometry_channels": ["position", "uniform_stroke", "label"], "compact_fallback": "one named tension or arrow", "integrity": "Uniform geometry carries relation only; it never implies quantitative strength."},
    "causal_graph": {"required_fields": ["nodes", "edges", "node_states", "source_refs"], "geometry_channels": ["position", "sequence", "uniform_stroke"], "compact_fallback": "three-node public spine", "integrity": "Every edge is supported; conditional and derived nodes stay distinct from observations."},
    "pair_spread": {"required_fields": ["subjects", "formula", "timestamps", "currency", "adjustment", "normalization", "source_refs"], "geometry_channels": ["position", "distance", "slope"], "compact_fallback": "latest spread plus one direct comparison", "integrity": "Use synchronized observations and state the exact ratio, difference, or excess-return formula."},
    "distribution_sample": {"required_fields": ["observations", "n", "observation_unit", "window", "population", "weights", "quartile_method", "whisker_rule", "outlier_policy", "source_ref"], "geometry_channels": ["position", "count", "density", "length"], "compact_fallback": "dot or range plot for small samples", "integrity": "Do not mix horizons or bases. Prefer raw dots below 20 observations and avoid a box summary for very small samples."},
    "quantile_scenarios": {"required_fields": ["cutoff", "horizon", "quantile_levels", "quantile_values", "unit", "model_or_method", "model_vintage", "calibration", "source_refs"], "geometry_channels": ["position", "enclosure", "opacity"], "compact_fallback": "median and one outer quantile band", "integrity": "A fan begins after the cutoff and is labeled modeled or conditional; prose scenarios do not qualify."},
    "part_to_whole": {"required_fields": ["parts", "denominator", "unit", "as_of", "basis", "residual", "source_ref"], "geometry_channels": ["area", "length", "count"], "compact_fallback": "ranked bars plus residual", "integrity": "Parts are mutually exclusive, non-negative, and reconcile to the same whole."},
    "additive_components": {"required_fields": ["start", "components", "end", "unit", "period", "residual", "source_refs"], "geometry_channels": ["length", "position", "direction"], "compact_fallback": "largest positive and negative bridges", "integrity": "Components are additive and reconcile start to end without hiding a material residual."},
    "quantified_flow": {"required_fields": ["edges", "unit", "window", "residual", "declared_total", "source_refs"], "geometry_channels": ["width", "position", "direction"], "compact_fallback": "top measured flows plus residual", "integrity": "Flows share one unit and window, conserve the declared total, and avoid double counting."},
    "ordered_categories": {"required_fields": ["items", "order_basis", "state", "source_refs"], "geometry_channels": ["position", "sequence", "label"], "compact_fallback": "three most decision-relevant ordered items", "integrity": "Equal spacing is categorical; do not imply numeric distance without measured values."},
    "payoff_series": {"required_fields": ["instrument_terms", "underlying_domain", "calculation_method", "values", "unit", "source_refs"], "geometry_channels": ["position", "slope", "level"], "compact_fallback": "breakeven and terminal endpoints", "integrity": "Terminal payoff and pre-expiry PnL are different; pre-expiry values require a declared pricing model and assumptions."},
    "comparison_pair": {"required_fields": ["items", "value_field", "unit", "basis", "as_of", "source_refs"], "geometry_channels": ["position", "length", "distance", "label"], "compact_fallback": "two directly labeled values on one baseline", "integrity": "Items share unit, basis, period, currency, and as-of time; bars use a common zero unless the declared relation is a deviation."},
    "revision_series": {"required_fields": ["points", "vintage_field", "value_field", "period", "unit", "basis", "source_refs"], "geometry_channels": ["position", "slope", "sequence", "label"], "compact_fallback": "prior and latest vintage with the exact revision", "integrity": "Vintages are ordered by when the market could know them and keep one forecast period and basis."},
    "term_structure": {"required_fields": ["instruments", "maturity_field", "notional_field", "rate_field", "currency", "as_of", "source_refs"], "geometry_channels": ["position", "length", "sequence", "label"], "compact_fallback": "maturity notional bars with directly labeled rates", "integrity": "Maturity, notional, and rate belong to the same instrument set and as-of time; separate visual channels prevent an ambiguous dual axis."}
  },
  "grammars": [
    {"grammar_id": "editorial_statement", "required_shape_sets": [["creator_judgment"]], "optional_shapes": ["qualitative_relation", "point_metric", "event_set"], "required_binding_kind_sets": [["creator_judgment"]], "minimum_proof_bindings": 1, "requires_data_requirement": false, "renderer_route": "directed_html", "avoid": "A slogan with no visible reason or proof."},
    {"grammar_id": "big_number_proof", "required_shape_sets": [["point_metric"]], "optional_shapes": ["creator_judgment", "level", "event_set"], "required_binding_kind_sets": [["metric"], ["level"], ["fact"]], "minimum_proof_bindings": 1, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Decorative statistics without basis, unit, and as-of time."},
    {"grammar_id": "variance_bar", "required_shape_sets": [["comparison_pair"]], "optional_shapes": ["creator_judgment", "event_set", "point_metric"], "required_binding_kind_sets": [["metric"], ["fact"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "A forecast or prior-value gap without one common basis, a declared reference, and direct labels."},
    {"grammar_id": "bullet_comparison", "required_shape_sets": [["comparison_pair"]], "optional_shapes": ["creator_judgment", "level", "event_set"], "required_binding_kind_sets": [["metric"], ["fact"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "A filled progress-track treatment or a non-zero baseline that exaggerates the gap."},
    {"grammar_id": "revision_ladder", "required_shape_sets": [["revision_series"]], "optional_shapes": ["creator_judgment", "event_set", "point_metric"], "required_binding_kind_sets": [["metric"], ["fact"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Mixing forecast vintages, periods, or guidance and consensus without labeling the basis."},
    {"grammar_id": "maturity_profile", "required_shape_sets": [["term_structure"]], "optional_shapes": ["creator_judgment", "event_set", "point_metric"], "required_binding_kind_sets": [["instrument"], ["fact"], ["metric"]], "minimum_proof_bindings": 1, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Precise maturity bars without dates, notionals, currency, and directly associated rates."},
    {"grammar_id": "term_structure_curve", "required_shape_sets": [["term_structure"]], "optional_shapes": ["creator_judgment", "event_set", "point_metric"], "required_binding_kind_sets": [["instrument"], ["fact"], ["metric"]], "minimum_proof_bindings": 1, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Connecting sparse tenors into a smooth curve or mixing amount and rate on an undeclared axis."},
    {"grammar_id": "observed_curve", "required_shape_sets": [["ordered_series"], ["multi_series"]], "optional_shapes": ["creator_judgment", "level"], "required_binding_kind_sets": [["series"]], "minimum_proof_bindings": 1, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Smoothing, extrapolation, or synthetic intermediate points."},
    {"grammar_id": "curve_with_events", "required_shape_sets": [["ordered_series", "event_set"], ["multi_series", "event_set"]], "optional_shapes": ["creator_judgment", "level"], "required_binding_kind_sets": [["series", "event"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Attaching a headline to a curve when event timing is unknown."},
    {"grammar_id": "threshold_band", "required_shape_sets": [["ordered_series", "level"], ["ohlcv_series", "level"], ["pair_spread", "level"]], "optional_shapes": ["creator_judgment", "event_set"], "required_binding_kind_sets": [["series", "level"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "An unlabeled line or an inferred trigger."},
    {"grammar_id": "event_reaction", "required_shape_sets": [["event_set", "ordered_series"], ["event_set", "ohlcv_series"]], "optional_shapes": ["creator_judgment", "level"], "required_binding_kind_sets": [["event", "series"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Claiming causality from timing alone."},
    {"grammar_id": "news_constellation", "required_shape_sets": [["news_cluster"]], "optional_shapes": ["creator_judgment", "causal_graph"], "required_binding_kind_sets": [["event"]], "minimum_kind_counts": {"event": 2}, "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Faking density with duplicated or unbound headlines."},
    {"grammar_id": "catalyst_ribbon", "required_shape_sets": [["calendar_events"], ["event_set"]], "optional_shapes": ["creator_judgment", "level"], "required_binding_kind_sets": [["event"]], "minimum_kind_counts": {"event": 2}, "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Inventing event order or date precision."},
    {"grammar_id": "tension_field", "required_shape_sets": [["qualitative_relation"]], "optional_shapes": ["creator_judgment", "point_metric", "event_set"], "required_binding_kind_sets": [["relationship"]], "minimum_proof_bindings": 1, "requires_data_requirement": false, "renderer_route": "directed_html", "avoid": "Using bar length or area to imply an unmeasured magnitude."},
    {"grammar_id": "box_whisker", "required_shape_sets": [["distribution_sample"]], "optional_shapes": ["creator_judgment", "event_set"], "required_binding_kind_sets": [["series"]], "minimum_proof_bindings": 1, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Drawing five-number summaries from a single observation or mixed sampling bases."},
    {"grammar_id": "histogram_density", "required_shape_sets": [["distribution_sample"]], "optional_shapes": ["creator_judgment", "event_set"], "required_binding_kind_sets": [["series"]], "minimum_proof_bindings": 1, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Arbitrary bins or combining incomparable samples."},
    {"grammar_id": "fan_quantiles", "required_shape_sets": [["quantile_scenarios"]], "optional_shapes": ["creator_judgment", "event_set", "level"], "required_binding_kind_sets": [["series"], ["metric"]], "minimum_proof_bindings": 1, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Manufacturing a forecast cone from historical OHLC or prose scenarios."},
    {"grammar_id": "dot_plot", "required_shape_sets": [["distribution_sample"], ["ordered_categories"]], "optional_shapes": ["creator_judgment", "event_set"], "required_binding_kind_sets": [["series"], ["metric"]], "minimum_proof_bindings": 1, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Unlabeled dots or inconsistent category scales."},
    {"grammar_id": "slopegraph", "required_shape_sets": [["pair_spread"], ["multi_series"]], "optional_shapes": ["creator_judgment", "event_set"], "required_binding_kind_sets": [["series"], ["metric"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Comparing values with different units or unsynchronized dates."},
    {"grammar_id": "dumbbell", "required_shape_sets": [["pair_spread"]], "optional_shapes": ["creator_judgment", "event_set"], "required_binding_kind_sets": [["metric"], ["series"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Two endpoints without one declared common basis."},
    {"grammar_id": "indexed_comparison", "required_shape_sets": [["multi_series"], ["pair_spread"]], "optional_shapes": ["creator_judgment", "event_set", "level"], "required_binding_kind_sets": [["series"]], "minimum_proof_bindings": 2, "requires_data_requirement": true, "renderer_route": "directed_html", "avoid": "Unsynchronized baselines, currencies, or adjusted-price conventions."},
