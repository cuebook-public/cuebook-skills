{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.xyz/schemas/community-skill-submission-v1.schema.json",
  "title": "CommunitySkillSubmissionV1",
  "description": "Frozen record of one community skill submission: the package file listing, the zip identity, the confirmed manifest card, and the confirmation state. Numeric bounds beyond these patterns (file count, zip size, summary and description lengths) are enforced by validate_community_skill_submission.mjs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "creator_handle", "package", "manifest", "confirmation"],
  "properties": {
    "schema_version": {"const": "community-skill-submission-v1"},
    "creator_handle": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9_-]{0,38}[a-z0-9])?$",
      "description": "The creator's existing Cuebook handle; the published listing carries it."
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "zip_bytes", "zip_sha256"],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 40,
          "items": {"$ref": "#/$defs/packageFile"}
        },
        "zip_bytes": {"type": "integer", "description": "Exact zip byte size; the validator enforces 1..524288."},
        "zip_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "display_name", "summary", "description", "version", "declared_tier", "tier_reasoning", "license"],
      "properties": {
        "slug": {"type": "string", "pattern": "^(?=.{3,40}$)[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "display_name": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1, "description": "The validator enforces at most 280 characters."},
        "description": {"type": "string", "minLength": 1, "description": "The validator enforces at most 1024 characters."},
        "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
        "declared_tier": {"enum": ["t0", "t1", "t2"]},
        "tier_reasoning": {"type": "string", "minLength": 1, "description": "One line of reasoning shown on the manifest card for the declared tier."},
        "license": {"enum": ["CC-BY-4.0", "CC-BY-SA-4.0", "CC0-1.0", "MIT"]}
      }
    },
    "confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["card_confirmed"],
      "properties": {
        "card_confirmed": {"type": "boolean"},
        "confirmed_at": {"type": "string", "format": "date-time"}
      }
    }
  },
  "$defs": {
    "packageFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "bytes": {"type": "integer"}
      }
    }
  }
}
