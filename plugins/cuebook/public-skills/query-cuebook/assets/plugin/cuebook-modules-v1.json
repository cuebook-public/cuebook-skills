{
  "schema_version": "cuebook-modules-v1",
  "catalog_version": "1.28.0",
  "default_module": "query",
  "modules": [
    {
      "module_id": "query",
      "label": "Query",
      "description": "Search, view, compare, and explain Cuebook data while producing only citable read-only results.",
      "entrypoint_skill": "query-cuebook",
      "menu_ref": "./query-menu-v1.json",
      "access": "read_only",
      "may_invoke": [],
      "skill_refs": [
        "query-cuebook",
        "collect-market-commentator-corpus",
        "distill-market-commentator-profile",
        "collect-market-media-corpus",
        "distill-market-media-format",
        "normalize-cuebook-creator-feed",
        "validate-cuebook-projection",
        "route-cuebook-narrative",
        "build-market-research-pack",
        "compute-cuebook-market-indicators",
        "reconcile-market-content-history"
      ]
    },
    {
      "module_id": "create",
      "label": "Create",
      "description": "Strengthen a user's trading view into a Frame with one title, one body, and one paired viewpoint visual; keep evidence and optional settlement in the background, querying when data is missing.",
      "entrypoint_skill": "create-cuebook-content",
      "menu_ref": "./creation-menu-v1.json",
      "access": "compose_with_authorized_writes",
      "may_invoke": [
        "query"
      ],
      "skill_refs": [
        "create-cuebook-content",
        "compose-cuebook-content-recipe",
        "select-cuebook-content-opportunities",
        "compile-cuebook-market-view-semantics",
        "compose-cuebook-trading-thesis",
        "compile-cuebook-visual-argument",
        "classify-cuebook-trading-logic",
        "plan-cuebook-creator-expression",
        "assemble-cuebook-viewpoint-data",
        "direct-cuebook-viewpoint-visual",
        "render-cuebook-viewpoint-visual",
        "direct-cuebook-viewpoint-motion",
        "render-cuebook-viewpoint-motion",
        "render-cuebook-logic-card",
        "render-cuebook-market-figure",
        "render-cuebook-market-signal",
        "plan-market-content-program",
        "render-cuebook-market-post",
        "assemble-cuebook-publish-candidates",
        "compile-cuebook-settlement-claim",
        "compile-cuebook-settlement-formula",
        "render-cuebook-market-media",
        "render-cuebook-thesis-chart",
        "assemble-cuebook-viewpoint-card",
        "prepare-market-content-release",
        "orchestrate-cuebook-creator-workflow",
        "intake-cuebook-viewpoint"
      ]
    }
  ],
  "routing_rules": {
    "read_intents_route_to": "query",
    "creation_intents_route_to": "create",
    "ambiguous_intents_route_to": "query",
    "query_deliverables": [
      "answer",
      "comparison",
      "source_bundle",
      "data_table",
      "factual_chart",
      "history_view"
    ],
    "create_deliverables": [
      "market_post",
      "creator_viewpoint_graphic",
      "settlement_protocol",
      "release_bundle",
      "publishing_candidates"
    ],
    "query_may_invoke_create": false,
    "create_may_invoke_query": true
  }
}
