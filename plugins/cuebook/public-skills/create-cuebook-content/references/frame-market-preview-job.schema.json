{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/frame-market-preview-job.schema.json",
  "title": "FrameMarketPreviewJob",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "preview", "expressions"],
  "properties": {
    "schema_version": {"const": "frame-market-preview-job"},
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preview_id", "state", "created_at", "creator_view", "meaning_lock", "query_binding", "candidates"],
      "properties": {
        "preview_id": {"type": "string", "pattern": "^FPREV_[A-Za-z0-9_:-]{6,}$"},
        "state": {"enum": ["ready", "conditional"]},
        "created_at": {"type": "string", "format": "date-time"},
        "creator_view": {"$ref": "#/$defs/creatorView"},
        "meaning_lock": {"$ref": "#/$defs/meaningLock"},
        "query_binding": {"$ref": "#/$defs/queryBinding"},
        "candidates": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {"$ref": "#/$defs/candidate"}
        }
      }
    },
    "expressions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {"$ref": "#/$defs/expression"}
    }
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "stringSet": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonemptyString"}
    },
    "nullableDateTime": {
      "anyOf": [
        {"type": "null"},
        {"type": "string", "format": "date-time"}
      ]
    },
    "nullableNumberLike": {
      "anyOf": [
        {"type": "null"},
        {"type": "number"},
        {"type": "string", "minLength": 1}
      ]
    },
    "meaningLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lock_id", "status", "confirmed_at", "title", "body", "subject", "direction", "horizon", "claim", "mechanism", "next_watch", "settlement", "visual_intent"],
      "properties": {
        "lock_id": {"type": "string", "pattern": "^MLOCK_[A-Za-z0-9_:-]{6,}$"},
        "status": {"const": "creator_confirmed"},
        "confirmed_at": {"type": "string", "format": "date-time"},
        "title": {"type": "string", "minLength": 2, "maxLength": 32},
        "body": {"type": "string", "minLength": 20, "maxLength": 1200},
        "subject": {"type": "string", "minLength": 1, "maxLength": 80},
        "direction": {"enum": ["long", "short", "outperform", "underperform", "range", "compound", "avoid", "watch", "neutral", "explain"]},
        "horizon": {"type": "string", "minLength": 1, "maxLength": 80},
        "claim": {"type": "string", "minLength": 2, "maxLength": 200},
        "mechanism": {"type": "string", "minLength": 2, "maxLength": 240},
        "next_watch": {"type": "string", "minLength": 2, "maxLength": 160},
        "settlement": {"$ref": "#/$defs/meaningSettlement"},
        "visual_intent": {"$ref": "#/$defs/meaningVisualIntent"}
      }
    },
    "meaningSettlement": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "family", "asset_ref", "direction", "requested_settle_at", "session_policy", "threshold_bps", "success_condition"],
          "properties": {
            "mode": {"const": "standard_direction"},
            "family": {"const": "single_asset_direction"},
            "asset_ref": {"type": "string", "minLength": 1, "maxLength": 120},
            "direction": {"enum": ["long", "short"]},
            "requested_settle_at": {"type": "string", "format": "date-time"},
            "session_policy": {"const": "at_instant"},
            "threshold_bps": {"const": "0"},
            "success_condition": {"enum": ["above_publication_baseline", "below_publication_baseline"]}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "family", "asset_ref", "direction", "requested_settle_at", "session_policy", "max_abs_move_bps", "success_condition"],
          "properties": {
            "mode": {"const": "terminal_range"},
            "family": {"const": "single_asset_range"},
            "asset_ref": {"type": "string", "minLength": 1, "maxLength": 120},
            "direction": {"const": "range"},
            "requested_settle_at": {"type": "string", "format": "date-time"},
            "session_policy": {"const": "at_instant"},
            "max_abs_move_bps": {"type": "string", "pattern": "^\\d+(\\.\\d+)?$"},
            "success_condition": {"const": "within_publication_baseline_band_at_deadline"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "family", "asset_ref", "pair_asset_ref", "direction", "requested_settle_at", "session_policy", "spread_threshold_bps", "success_condition"],
          "properties": {
            "mode": {"const": "relative_outperformance"},
            "family": {"const": "pair_asset_direction"},
            "asset_ref": {"type": "string", "minLength": 1, "maxLength": 120},
            "pair_asset_ref": {"type": "string", "minLength": 1, "maxLength": 120},
            "direction": {"enum": ["outperform", "underperform"]},
            "requested_settle_at": {"type": "string", "format": "date-time"},
            "session_policy": {"const": "at_instant"},
            "spread_threshold_bps": {"type": "string", "pattern": "^\\d+(\\.\\d+)?$"},
            "success_condition": {"enum": ["focal_outperforms_pair", "focal_underperforms_pair"]}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "family", "asset_ref", "pair_asset_ref", "direction", "primary_direction", "pair_direction", "requested_settle_at", "session_policy", "threshold_bps", "pair_threshold_bps", "max_abs_move_bps", "pair_max_abs_move_bps", "aggregate", "success_condition", "flat_condition"],
          "properties": {
            "mode": {"const": "compound_conditions"},
            "family": {"enum": ["pair_asset_direction", "pair_asset_conditions"]},
            "asset_ref": {"type": "string", "minLength": 1, "maxLength": 120},
            "pair_asset_ref": {"type": "string", "minLength": 1, "maxLength": 120},
            "direction": {"const": "compound"},
            "primary_direction": {"enum": ["long", "short", "range"]},
            "pair_direction": {"enum": ["long", "short", "range"]},
            "requested_settle_at": {"type": "string", "format": "date-time"},
            "session_policy": {"const": "at_instant"},
            "threshold_bps": {"type": ["string", "null"], "pattern": "^-?\\d+(\\.\\d+)?$"},
            "pair_threshold_bps": {"type": ["string", "null"], "pattern": "^-?\\d+(\\.\\d+)?$"},
            "max_abs_move_bps": {"type": ["string", "null"], "pattern": "^\\d+(\\.\\d+)?$"},
            "pair_max_abs_move_bps": {"type": ["string", "null"], "pattern": "^\\d+(\\.\\d+)?$"},
            "aggregate": {"const": "all_legs"},
            "success_condition": {"const": "all_conditions_hit"},
            "flat_condition": {"const": "direction_equals_threshold_with_no_miss_or_missing"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "reason"],
          "properties": {
            "mode": {"enum": ["not_applicable", "non_settleable"]},
            "reason": {"type": "string", "minLength": 2, "maxLength": 160}
          }
        }
      ]
    },
    "meaningVisualIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "required_beats"],
      "properties": {
        "summary": {"type": "string", "minLength": 2, "maxLength": 240},
        "required_beats": {
          "type": "array",
          "minItems": 3,
          "maxItems": 7,
          "uniqueItems": true,
          "items": {"enum": ["price_context", "tested_observation", "argument_structure", "mechanism", "future_check", "settlement_clock", "settlement_band", "condition_join", "component_anatomy"]}
        }
      }
    },
    "creatorView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original_text", "subject", "direction", "observation_window", "horizon", "claim", "mechanism", "next_watch"],
      "properties": {
        "original_text": {"type": "string", "minLength": 2, "maxLength": 4000},
        "subject": {"type": "string", "minLength": 1, "maxLength": 80},
        "direction": {"enum": ["long", "short", "outperform", "underperform", "range", "compound", "avoid", "watch", "neutral", "explain"]},
        "observation_window": {"type": "string", "minLength": 1, "maxLength": 80},
        "horizon": {"type": "string", "minLength": 1, "maxLength": 80},
        "claim": {"type": "string", "minLength": 2, "maxLength": 200},
        "mechanism": {"type": "string", "minLength": 2, "maxLength": 240},
        "next_watch": {"type": "string", "minLength": 2, "maxLength": 160}
      }
    },
    "queryBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "status", "bundle_refs", "result_refs", "as_of", "warnings", "unavailable_capabilities"],
      "properties": {
        "required": {"type": "boolean"},
        "status": {"enum": ["not_required", "reused", "executed", "partial"]},
        "bundle_refs": {"$ref": "#/$defs/stringSet"},
        "result_refs": {"$ref": "#/$defs/stringSet"},
        "as_of": {"$ref": "#/$defs/nullableDateTime"},
        "warnings": {"$ref": "#/$defs/stringSet"},
        "unavailable_capabilities": {"$ref": "#/$defs/stringSet"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "angle", "frame", "evidence_refs"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^FPREV_CAND_[A-Za-z0-9_:-]{4,}$"},
        "angle": {"enum": ["conviction", "evidence", "mechanism"]},
        "frame": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "body"],
          "properties": {
            "title": {"type": "string", "minLength": 2, "maxLength": 32},
            "body": {"type": "string", "minLength": 20, "maxLength": 1200}
          }
        },
        "evidence_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "beat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "state", "binding_id", "source_refs"],
      "properties": {
        "text": {"type": "string", "minLength": 1, "maxLength": 80},
        "state": {"enum": ["observed", "reported", "derived", "creator_view", "conditional"]},
        "binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
        "source_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "argument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "observation", "mechanism", "implication", "countercase"],
      "properties": {
        "claim": {"$ref": "#/$defs/beat"},
        "observation": {"$ref": "#/$defs/beat"},
        "mechanism": {"$ref": "#/$defs/beat"},
        "implication": {"$ref": "#/$defs/beat"},
        "countercase": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "#/$defs/beat"}
          ]
        }
      }
    },
    "creatorSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "interview_text", "adoption_state"],
      "properties": {
        "origin": {"enum": ["direct_prompt", "heuristic_interview", "selected_cuebook_material"]},
        "interview_text": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "minLength": 1, "maxLength": 1200}
          ]
        },
        "adoption_state": {"enum": ["not_needed", "adopted", "partially_adopted", "skipped"]}
      }
    },
    "textImageDivision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title_job", "body_job", "image_job"],
      "properties": {
        "title_job": {"const": "memorable_judgment"},
        "body_job": {"enum": ["mechanism_and_horizon", "evidence_and_mechanism", "scenario_and_watch"]},
        "image_job": {"enum": ["evidence_and_time", "comparison_and_time", "mechanism_and_time", "scenario_and_time"]}
      }
    },
    "toolCandles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data", "meta"],
      "properties": {
        "data": {
          "type": "object",
          "additionalProperties": true,
          "required": ["ticker", "interval", "bars"],
          "properties": {
            "ticker": {"type": "string", "minLength": 1},
            "interval": {"type": "string", "minLength": 1},
            "bars": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["openTime", "open", "high", "low", "close", "volume"],
                "properties": {
                  "openTime": {"type": "string", "format": "date-time"},
                  "open": {"$ref": "#/$defs/nullableNumberLike"},
                  "high": {"$ref": "#/$defs/nullableNumberLike"},
                  "low": {"$ref": "#/$defs/nullableNumberLike"},
                  "close": {"$ref": "#/$defs/nullableNumberLike"},
                  "volume": {"$ref": "#/$defs/nullableNumberLike"}
                }
              }
            },
            "nextCursor": {"type": ["string", "null"]}
          }
        },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "required": ["asOf", "truncated"],
          "properties": {
            "asOf": {"type": "string", "format": "date-time"},
            "truncated": {"type": "boolean"}
          }
        }
      }
    },
    "marketState": {
      "type": "object",
      "additionalProperties": true,
      "required": ["price", "observedAt"],
      "properties": {
        "price": {"$ref": "#/$defs/nullableNumberLike"},
        "observedAt": {"$ref": "#/$defs/nullableDateTime"}
      }
    },
    "marketLeg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticker", "display_name", "asset_id", "asset_class", "result_ref", "market_state", "candles"],
      "properties": {
        "ticker": {"type": "string", "minLength": 1, "maxLength": 32},
        "display_name": {"type": "string", "minLength": 1, "maxLength": 80},
        "asset_id": {"anyOf": [{"type": "null"}, {"type": "integer", "minimum": 1}]},
        "asset_class": {"type": "string", "minLength": 1, "maxLength": 32},
        "result_ref": {"type": "string", "minLength": 1},
        "market_state": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/marketState"}]},
        "candles": {"$ref": "#/$defs/toolCandles"}
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": ["main_transform", "support_transform", "main_binding_ids", "support_binding_ids", "chart_style", "rolling_window", "show_volume", "primary", "benchmark"],
      "properties": {
        "main_transform": {"enum": ["raw_price", "indexed_return", "relative_spread", "drawdown", "rolling_correlation"]},
        "support_transform": {"enum": ["none", "volume_ratio", "relative_spread", "drawdown", "rolling_correlation"]},
        "main_binding_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"}
        },
        "support_binding_ids": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"}
        },
        "chart_style": {"enum": ["line", "candles"]},
        "rolling_window": {"type": "integer", "minimum": 5, "maximum": 30},
        "show_volume": {"type": "boolean"},
        "primary": {"$ref": "#/$defs/marketLeg"},
        "benchmark": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "#/$defs/marketLeg"}
          ]
        }
      }
    },
    "annotation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label", "occurred_at", "value", "state", "binding_id", "source_refs"],
      "properties": {
        "kind": {"enum": ["event", "threshold", "regime_start", "note"]},
        "label": {"type": "string", "minLength": 1, "maxLength": 36},
        "occurred_at": {"$ref": "#/$defs/nullableDateTime"},
        "value": {"anyOf": [{"type": "null"}, {"type": "number"}]},
        "state": {"enum": ["observed", "reported", "derived", "creator_view", "conditional"]},
        "binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
        "source_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "futureBeat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "label", "criterion", "at", "state", "binding_id", "source_refs"],
      "properties": {
        "role": {"enum": ["catalyst", "checkpoint", "confirmation", "invalidation", "settlement"]},
        "label": {"type": "string", "minLength": 1, "maxLength": 42},
        "criterion": {"type": "string", "minLength": 2, "maxLength": 60},
        "at": {"$ref": "#/$defs/nullableDateTime"},
        "state": {"enum": ["reported", "creator_view", "conditional"]},
        "binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
        "source_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "observationTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "statement", "threshold", "supports_binding_ids", "source_refs"],
      "properties": {
        "kind": {
          "enum": [
            "primary_outperformed_benchmark",
            "benchmark_declined",
            "primary_positive",
            "primary_drawdown_shallower",
            "primary_recovered_faster",
            "correlation_above",
            "correlation_below",
            "latest_above_threshold",
            "latest_below_threshold",
            "primary_positive_after_event",
            "primary_negative_after_event",
            "primary_outperformed_after_event"
          ]
        },
        "statement": {"type": "string", "minLength": 2, "maxLength": 80},
        "threshold": {"anyOf": [{"type": "null"}, {"type": "number"}]},
        "supports_binding_ids": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"}
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/nonemptyString"}
        }
      }
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observation_start", "declared_at", "horizon_end", "future_mode", "timezone"],
      "properties": {
        "observation_start": {"type": "string", "format": "date-time"},
        "declared_at": {"type": "string", "format": "date-time"},
        "horizon_end": {"$ref": "#/$defs/nullableDateTime"},
        "future_mode": {"enum": ["none", "empty_clock", "conditional_lanes", "milestone_ladder"]},
        "timezone": {"type": "string", "minLength": 1, "maxLength": 40}
      }
    },
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "creator_signal", "text_image_division", "reader_job", "analytic_relationship", "grammar", "composition", "surface", "subject_label", "horizon_label", "data_status", "data_as_of", "source_label", "argument", "observation_test", "time", "market", "annotations", "future_beats"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^FPREV_CAND_[A-Za-z0-9_:-]{4,}$"},
        "creator_signal": {"$ref": "#/$defs/creatorSignal"},
        "text_image_division": {"$ref": "#/$defs/textImageDivision"},
        "reader_job": {"enum": ["conviction", "proof", "mechanism", "comparison", "event", "scenario", "trigger"]},
        "analytic_relationship": {"enum": ["change_over_time", "deviation", "relative_value", "correlation", "event_reaction", "trigger_state", "causal_transmission", "scenario_payoff"]},
        "grammar": {"enum": ["curve_story", "relative_divergence", "drawdown_recovery", "correlation_shift", "event_window", "threshold_regime", "scenario_lanes", "causal_spine", "evidence_balance"]},
        "composition": {"enum": ["curve_stage", "editorial_split", "divergence_field", "timeline_rail", "threshold_field", "scenario_field", "causal_spine", "evidence_balance"]},
        "surface": {"enum": ["paper_signal", "midnight", "warm_editorial", "cool_mono"]},
        "subject_label": {"type": "string", "minLength": 1, "maxLength": 24},
        "horizon_label": {"type": "string", "minLength": 1, "maxLength": 24},
        "data_status": {"enum": ["frozen_observed", "synthetic_fixture", "creator_only"]},
        "data_as_of": {"$ref": "#/$defs/nullableDateTime"},
        "source_label": {"type": "string", "minLength": 2, "maxLength": 40},
        "argument": {"$ref": "#/$defs/argument"},
        "observation_test": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "#/$defs/observationTest"}
          ]
        },
        "time": {"$ref": "#/$defs/time"},
        "market": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "#/$defs/market"}
          ]
        },
        "annotations": {
          "type": "array",
          "maxItems": 4,
          "items": {"$ref": "#/$defs/annotation"}
        },
        "future_beats": {
          "type": "array",
          "maxItems": 4,
          "items": {"$ref": "#/$defs/futureBeat"}
        }
      }
    }
  }
}
