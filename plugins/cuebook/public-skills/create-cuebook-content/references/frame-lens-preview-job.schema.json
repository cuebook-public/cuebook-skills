{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/frame-lens-preview-job.schema.json",
  "title": "FrameLensPreviewJob",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "preview", "expression"],
  "properties": {
    "schema_version": {"const": "frame-lens-preview-job"},
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preview_id", "state", "created_at", "creator_view", "query_binding", "candidate"],
      "properties": {
        "preview_id": {"type": "string", "pattern": "^FPREV_[A-Za-z0-9_:-]{6,}$"},
        "state": {"enum": ["ready", "conditional"]},
        "created_at": {"type": "string", "format": "date-time"},
        "creator_view": {"$ref": "#/$defs/creatorView"},
        "query_binding": {"$ref": "#/$defs/queryBinding"},
        "candidate": {"$ref": "#/$defs/candidate"}
      }
    },
    "expression": {"$ref": "#/$defs/expression"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "stringSet": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/nonemptyString"}
    },
    "nullableNumberLike": {
      "anyOf": [
        {"type": "null"},
        {"type": "number"},
        {"type": "string", "minLength": 1}
      ]
    },
    "creatorView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original_text", "subject", "direction", "observation_window", "horizon", "claim", "mechanism", "next_watch"],
      "properties": {
        "original_text": {"type": "string", "minLength": 2, "maxLength": 4000},
        "subject": {"type": "string", "minLength": 1, "maxLength": 80},
        "direction": {"enum": ["long", "short", "outperform", "underperform", "range", "avoid", "watch", "neutral", "explain"]},
        "observation_window": {"type": "string", "minLength": 1, "maxLength": 80},
        "horizon": {"type": "string", "minLength": 1, "maxLength": 80},
        "claim": {"type": "string", "minLength": 2, "maxLength": 200},
        "mechanism": {"type": "string", "minLength": 2, "maxLength": 240},
        "next_watch": {"type": "string", "minLength": 2, "maxLength": 160}
      }
    },
    "queryBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "status", "bundle_refs", "result_refs", "as_of", "warnings", "unavailable_capabilities"],
      "properties": {
        "required": {"const": true},
        "status": {"enum": ["reused", "executed", "partial"]},
        "bundle_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
        "result_refs": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
        "as_of": {"type": "string", "format": "date-time"},
        "warnings": {"$ref": "#/$defs/stringSet"},
        "unavailable_capabilities": {"$ref": "#/$defs/stringSet"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "angle", "frame", "evidence_refs"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^FPREV_CAND_[A-Za-z0-9_:-]{4,}$"},
        "angle": {"enum": ["conviction", "evidence", "mechanism"]},
        "frame": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "body"],
          "properties": {
            "title": {"type": "string", "minLength": 2, "maxLength": 32},
            "body": {"type": "string", "minLength": 20, "maxLength": 1200}
          }
        },
        "evidence_refs": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}}
      }
    },
    "beat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "state", "binding_id", "source_refs"],
      "properties": {
        "text": {"type": "string", "minLength": 1, "maxLength": 60},
        "state": {"enum": ["derived", "creator_view", "conditional"]},
        "binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
        "source_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "argument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "observation", "mechanism", "implication", "countercase"],
      "properties": {
        "claim": {"$ref": "#/$defs/beat"},
        "observation": {"$ref": "#/$defs/beat"},
        "mechanism": {"$ref": "#/$defs/beat"},
        "implication": {"$ref": "#/$defs/beat"},
        "countercase": {
          "anyOf": [
            {"type": "null"},
            {"$ref": "#/$defs/beat"}
          ]
        }
      }
    },
    "creatorSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "interview_text", "adoption_state"],
      "properties": {
        "origin": {"enum": ["direct_prompt", "heuristic_interview", "selected_cuebook_material"]},
        "interview_text": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "minLength": 1, "maxLength": 1200}
          ]
        },
        "adoption_state": {"enum": ["not_needed", "adopted", "partially_adopted", "skipped"]}
      }
    },
    "textImageDivision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title_job", "body_job", "image_job"],
      "properties": {
        "title_job": {"const": "memorable_judgment"},
        "body_job": {"enum": ["mechanism_and_horizon", "evidence_and_mechanism"]},
        "image_job": {"enum": ["evidence_and_time", "comparison_and_time"]}
      }
    },
    "toolCandles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data", "meta"],
      "properties": {
        "data": {
          "type": "object",
          "additionalProperties": true,
          "required": ["ticker", "interval", "bars"],
          "properties": {
            "ticker": {"type": "string", "minLength": 1},
            "interval": {"type": "string", "minLength": 1},
            "bars": {
              "type": "array",
              "minItems": 5,
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["openTime", "open", "high", "low", "close", "volume"],
                "properties": {
                  "openTime": {"type": "string", "format": "date-time"},
                  "open": {"$ref": "#/$defs/nullableNumberLike"},
                  "high": {"$ref": "#/$defs/nullableNumberLike"},
                  "low": {"$ref": "#/$defs/nullableNumberLike"},
                  "close": {"$ref": "#/$defs/nullableNumberLike"},
                  "volume": {"$ref": "#/$defs/nullableNumberLike"}
                }
              }
            },
            "nextCursor": {"type": ["string", "null"]}
          }
        },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "required": ["asOf", "truncated"],
          "properties": {
            "asOf": {"type": "string", "format": "date-time"},
            "truncated": {"type": "boolean"}
          }
        }
      }
    },
    "marketLeg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticker", "display_name", "asset_id", "asset_class", "result_ref", "candles"],
      "properties": {
        "ticker": {"type": "string", "minLength": 1, "maxLength": 32},
        "display_name": {"type": "string", "minLength": 1, "maxLength": 80},
        "asset_id": {"anyOf": [{"type": "null"}, {"type": "integer", "minimum": 1}]},
        "asset_class": {"type": "string", "minLength": 1, "maxLength": 32},
        "result_ref": {"type": "string", "minLength": 1},
        "candles": {"$ref": "#/$defs/toolCandles"}
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["leg", "weight", "side", "inclusion_reason", "origin", "binding_id"],
      "properties": {
        "leg": {"$ref": "#/$defs/marketLeg"},
        "weight": {"type": "number", "exclusiveMinimum": -1, "exclusiveMaximum": 1, "not": {"const": 0}},
        "side": {"enum": ["long", "short"]},
        "inclusion_reason": {"type": "string", "minLength": 2, "maxLength": 24},
        "origin": {"enum": ["creator_named", "cuebook_discovered", "assistant_proxy"]},
        "binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"}
      }
    },
    "lens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lens_id", "name", "label_kind", "selection_mode", "universe_frozen_at", "base_value", "weighting", "rebalance", "formula", "components", "limitations", "curve_binding_id", "contribution_binding_id"],
      "properties": {
        "lens_id": {"type": "string", "pattern": "^LENS_[A-Za-z0-9_:-]{4,}$"},
        "name": {"type": "string", "minLength": 2, "maxLength": 32},
        "label_kind": {"enum": ["creator_lens", "long_short_lens"]},
        "selection_mode": {"enum": ["pre_registered", "retrospective_exploratory"]},
        "universe_frozen_at": {"type": "string", "format": "date-time"},
        "base_value": {"const": 100},
        "weighting": {"enum": ["equal", "custom"]},
        "rebalance": {"enum": ["none", "weekly", "monthly"]},
        "formula": {"type": "string", "minLength": 4, "maxLength": 160},
        "components": {"type": "array", "minItems": 3, "maxItems": 8, "items": {"$ref": "#/$defs/component"}},
        "limitations": {"type": "array", "minItems": 1, "maxItems": 2, "items": {"type": "string", "minLength": 2, "maxLength": 40}},
        "curve_binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
        "contribution_binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"}
      }
    },
    "observationTest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "statement", "threshold", "supports_binding_ids", "source_refs"],
      "properties": {
        "kind": {"enum": ["lens_positive", "lens_negative", "long_short_positive", "long_short_negative"]},
        "statement": {"type": "string", "minLength": 2, "maxLength": 80},
        "threshold": {"type": "number"},
        "supports_binding_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"}},
        "source_refs": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}}
      }
    },
    "futureBeat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "label", "criterion", "at", "state", "binding_id", "source_refs"],
      "properties": {
        "role": {"enum": ["checkpoint", "confirmation", "invalidation", "settlement"]},
        "label": {"type": "string", "minLength": 1, "maxLength": 42},
        "criterion": {"type": "string", "minLength": 2, "maxLength": 60},
        "at": {"type": "string", "format": "date-time"},
        "state": {"const": "conditional"},
        "binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
        "source_refs": {"type": "array", "maxItems": 0}
      }
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observation_start", "declared_at", "horizon_end", "timezone"],
      "properties": {
        "observation_start": {"type": "string", "format": "date-time"},
        "declared_at": {"type": "string", "format": "date-time"},
        "horizon_end": {"type": "string", "format": "date-time"},
        "timezone": {"type": "string", "minLength": 1, "maxLength": 40}
      }
    },
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "creator_signal", "text_image_division", "reader_job", "analytic_relationship", "grammar", "composition", "surface", "subject_label", "horizon_label", "data_status", "data_as_of", "source_label", "argument", "observation_test", "time", "lens", "future_beats"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^FPREV_CAND_[A-Za-z0-9_:-]{4,}$"},
        "creator_signal": {"$ref": "#/$defs/creatorSignal"},
        "text_image_division": {"$ref": "#/$defs/textImageDivision"},
        "reader_job": {"enum": ["proof", "mechanism", "comparison"]},
        "analytic_relationship": {"enum": ["basket_breadth", "long_short_spread"]},
        "grammar": {"enum": ["creator_lens", "long_short_lens"]},
        "composition": {"enum": ["lens_anatomy", "contribution_stage"]},
        "surface": {"enum": ["paper_signal", "midnight", "warm_editorial", "cool_mono"]},
        "subject_label": {"type": "string", "minLength": 1, "maxLength": 24},
        "horizon_label": {"type": "string", "minLength": 1, "maxLength": 24},
        "data_status": {"enum": ["frozen_observed", "synthetic_fixture"]},
        "data_as_of": {"type": "string", "format": "date-time"},
        "source_label": {"type": "string", "minLength": 2, "maxLength": 40},
        "argument": {"$ref": "#/$defs/argument"},
        "observation_test": {"$ref": "#/$defs/observationTest"},
        "time": {"$ref": "#/$defs/time"},
        "lens": {"$ref": "#/$defs/lens"},
        "future_beats": {"type": "array", "minItems": 2, "maxItems": 3, "items": {"$ref": "#/$defs/futureBeat"}}
      }
    }
  }
}
