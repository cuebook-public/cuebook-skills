{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/viewpoint-data-bundle-v1.schema.json",
  "title": "ViewpointDataBundleV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "bundle_id", "revision", "state", "temporal_mode",
    "lineage", "request", "instruments", "series", "key_values", "events",
    "levels", "formulas", "requirements", "render_payload", "quality_report"
  ],
  "properties": {
    "schema_version": {"const": "viewpoint-data-bundle-v1"},
    "bundle_id": {"type": "string", "pattern": "^VDATA_[A-Za-z0-9_:-]{8,96}$"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"enum": ["ready", "conditional", "blocked"]},
    "temporal_mode": {"enum": ["declaration", "tracking", "replay"]},
    "lineage": {"$ref": "#/$defs/lineage"},
    "request": {"$ref": "#/$defs/request"},
    "instruments": {"type": "array", "items": {"$ref": "#/$defs/instrument"}, "uniqueItems": true},
    "series": {"type": "array", "items": {"$ref": "#/$defs/series"}, "uniqueItems": true},
    "key_values": {"type": "array", "items": {"$ref": "#/$defs/keyValue"}, "uniqueItems": true},
    "events": {"type": "array", "items": {"$ref": "#/$defs/event"}, "uniqueItems": true},
    "levels": {"type": "array", "items": {"$ref": "#/$defs/level"}, "uniqueItems": true},
    "formulas": {"type": "array", "items": {"$ref": "#/$defs/formula"}, "uniqueItems": true},
    "evidence_objects": {"type": "array", "items": {"$ref": "#/$defs/evidenceObject"}, "uniqueItems": true},
    "requirements": {"type": "array", "items": {"$ref": "#/$defs/requirement"}, "minItems": 1, "uniqueItems": true},
    "render_payload": {"$ref": "#/$defs/renderPayload"},
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "dateTime": {"type": "string", "format": "date-time"},
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "nullableHttpUrl": {"anyOf": [{"type": "null"}, {"type": "string", "pattern": "^https?://[^\\s]+$"}]},
    "stringSet": {"type": "array", "items": {"$ref": "#/$defs/nonemptyString"}, "uniqueItems": true},
    "requestClass": {"enum": ["qualitative_evidence", "news_anchor", "official_event", "valuation_metric", "comparison_metric", "market_series", "price_level", "settlement_reference"]},
    "expressionSurfaces": {
      "type": "array",
      "items": {"enum": ["text", "visual"]},
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true
    },
    "lineage": {
      "type": "object", "additionalProperties": false,
      "required": ["expression_plan_ref", "meaning_fingerprint", "research_pack_ref", "input_artifact_refs", "decision_cutoff_at", "as_of"],
      "properties": {
        "expression_plan_ref": {"type": "string", "pattern": "^(CEXP|EXPR)_[A-Za-z0-9_:-]+(@r[1-9][0-9]*)?$"},
        "meaning_fingerprint": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "research_pack_ref": {"type": ["string", "null"]},
        "input_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "decision_cutoff_at": {"$ref": "#/$defs/dateTime"},
        "as_of": {"$ref": "#/$defs/dateTime"}
      }
    },
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["grammar", "visual_job", "required_kinds", "fallback_modes"],
      "properties": {
        "grammar": {"type": "string", "minLength": 1},
        "visual_job": {"type": "string", "minLength": 1, "maxLength": 220},
        "required_kinds": {"$ref": "#/$defs/stringSet"},
        "fallback_modes": {"type": "array", "items": {"enum": ["qualitative", "key_numbers", "series", "mixed"]}, "uniqueItems": true}
      }
    },
    "instrument": {
      "type": "object", "additionalProperties": false,
      "required": ["instrument_id", "entity_ref", "symbol", "venue", "currency", "role", "mapping_source_ref", "mapping_limitation"],
      "properties": {
        "instrument_id": {"type": "string", "pattern": "^INS_[A-Za-z0-9_:-]+$"},
        "entity_ref": {"type": "string", "minLength": 1},
        "symbol": {"type": "string", "minLength": 1},
        "venue": {"type": "string", "minLength": 1},
        "currency": {"$ref": "#/$defs/nullableString"},
        "role": {"enum": ["primary", "comparator", "proxy", "driver", "denominator"]},
        "mapping_source_ref": {"type": "string", "minLength": 1},
        "mapping_limitation": {"$ref": "#/$defs/nullableString"}
      }
    },
    "point": {
      "type": "object", "additionalProperties": false,
      "required": ["t", "state", "source_ref", "available_at"],
      "properties": {
        "t": {"$ref": "#/$defs/dateTime"},
        "state": {"enum": ["sealed", "forming"]},
        "source_ref": {"type": "string", "minLength": 1},
        "available_at": {"$ref": "#/$defs/dateTime"},
        "value": {"type": "number"},
        "o": {"type": "number"},
        "h": {"type": "number"},
        "l": {"type": "number"},
        "c": {"type": "number"},
        "v": {"type": "number", "minimum": 0}
      }
    },
    "series": {
      "type": "object", "additionalProperties": false,
      "required": ["series_id", "kind", "label", "instrument_refs", "unit", "interval", "timezone", "source_ref", "formula_ref", "points"],
      "properties": {
        "series_id": {"type": "string", "pattern": "^SER_[A-Za-z0-9_:-]+$"},
        "kind": {"enum": ["ohlcv", "price", "return", "spread", "flow", "estimate", "fundamental", "factor", "positioning", "volume"]},
        "label": {"type": "string", "minLength": 1},
        "instrument_refs": {"$ref": "#/$defs/stringSet"},
        "unit": {"type": "string", "minLength": 1},
        "interval": {"type": "string", "minLength": 1},
        "timezone": {"type": "string", "minLength": 1},
        "source_ref": {"type": "string", "minLength": 1},
        "formula_ref": {"$ref": "#/$defs/nullableString"},
        "points": {"type": "array", "items": {"$ref": "#/$defs/point"}, "minItems": 1}
      }
    },
    "keyValue": {
      "type": "object", "additionalProperties": false,
      "required": ["value_id", "label", "instrument_refs", "numeric_value", "display_value", "unit", "as_of", "available_at", "source_ref", "evidence_kind", "formula_ref", "role", "valuation_basis"],
      "properties": {
        "value_id": {"type": "string", "pattern": "^VAL_[A-Za-z0-9_:-]+$"},
        "label": {"type": "string", "minLength": 1},
        "instrument_refs": {"$ref": "#/$defs/stringSet"},
        "numeric_value": {"type": ["number", "null"]},
        "display_value": {"type": "string", "minLength": 1},
        "unit": {"type": "string", "minLength": 1},
        "as_of": {"$ref": "#/$defs/dateTime"},
        "available_at": {"$ref": "#/$defs/dateTime"},
        "source_ref": {"type": "string", "minLength": 1},
        "evidence_kind": {"enum": ["observed", "reported", "derived", "analogy"]},
        "formula_ref": {"$ref": "#/$defs/nullableString"},
        "role": {"enum": ["driver", "comparison", "magnitude", "risk", "context"]},
        "valuation_basis": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/valuationBasis"}]}
      }
    },
    "valuationBasis": {
      "type": "object", "additionalProperties": false,
      "required": ["metric_name", "numerator", "denominator", "denominator_value", "period_basis", "accounting_basis", "currency_treatment", "share_class", "comparability_notes"],
      "properties": {
        "metric_name": {"$ref": "#/$defs/nonemptyString"},
        "numerator": {"$ref": "#/$defs/nonemptyString"},
        "denominator": {"$ref": "#/$defs/nonemptyString"},
        "denominator_value": {"type": ["number", "null"]},
        "period_basis": {"enum": ["trailing", "forward", "current", "point_in_time", "not_applicable"]},
        "accounting_basis": {"$ref": "#/$defs/nonemptyString"},
        "currency_treatment": {"$ref": "#/$defs/nonemptyString"},
        "share_class": {"$ref": "#/$defs/nonemptyString"},
        "comparability_notes": {"$ref": "#/$defs/nullableString"}
      }
    },
    "event": {
      "type": "object", "additionalProperties": false,
      "required": ["event_id", "label", "at", "available_at", "source_ref", "publisher_or_issuer", "source_type", "source_url", "supported_fact_refs", "role"],
      "properties": {
        "event_id": {"type": "string", "pattern": "^EV_[A-Za-z0-9_:-]+$"},
        "label": {"type": "string", "minLength": 1},
        "at": {"$ref": "#/$defs/dateTime"},
        "available_at": {"$ref": "#/$defs/dateTime"},
        "source_ref": {"type": "string", "minLength": 1},
        "publisher_or_issuer": {"$ref": "#/$defs/nullableString"},
        "source_type": {"enum": ["issuer", "regulator", "exchange", "government", "filing", "newswire", "publisher", "market_data", "creator_source"]},
        "source_url": {"$ref": "#/$defs/nullableHttpUrl"},
        "supported_fact_refs": {"$ref": "#/$defs/stringSet"},
        "role": {"enum": ["catalyst", "decision_cutoff", "deadline", "news", "policy", "earnings", "listing", "trade_action"]}
      }
    },
    "level": {
      "type": "object", "additionalProperties": false,
      "required": ["level_id", "label", "instrument_ref", "value", "unit", "kind", "source_ref", "fact_refs", "observed_at", "available_at", "explicit"],
      "properties": {
        "level_id": {"type": "string", "pattern": "^LVL_[A-Za-z0-9_:-]+$"},
        "label": {"type": "string", "minLength": 1},
        "instrument_ref": {"type": "string", "pattern": "^INS_[A-Za-z0-9_:-]+$"},
        "value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1},
        "kind": {"enum": ["support", "resistance", "trigger", "invalidation", "target", "benchmark", "range_boundary"]},
        "source_ref": {"type": "string", "minLength": 1},
        "fact_refs": {"$ref": "#/$defs/stringSet"},
        "observed_at": {"$ref": "#/$defs/dateTime"},
        "available_at": {"$ref": "#/$defs/dateTime"},
        "explicit": {"type": "boolean"}
      }
    },
    "formula": {
      "type": "object", "additionalProperties": false,
      "required": ["formula_id", "label", "expression", "input_refs", "output_unit", "window", "normalization", "limitations"],
      "properties": {
        "formula_id": {"type": "string", "pattern": "^FORM_[A-Za-z0-9_:-]+$"},
        "label": {"type": "string", "minLength": 1},
        "expression": {"type": "string", "minLength": 1},
        "input_refs": {"$ref": "#/$defs/stringSet"},
        "output_unit": {"type": "string", "minLength": 1},
        "window": {"type": "string", "minLength": 1},
        "normalization": {"type": "string", "minLength": 1},
        "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}
      }
    },
    "evidenceShape": {
      "enum": [
        "news_cluster", "distribution_sample", "quantile_scenarios",
        "part_to_whole", "additive_components", "quantified_flow",
        "ordered_categories", "payoff_series"
      ]
    },
    "evidenceObject": {
      "type": "object", "additionalProperties": false,
      "required": [
        "evidence_id", "shape", "label", "state", "as_of", "available_at",
        "source_refs", "formula_ref", "payload"
      ],
      "properties": {
        "evidence_id": {"type": "string", "pattern": "^EOBJ_[A-Za-z0-9_:-]+$"},
        "shape": {"$ref": "#/$defs/evidenceShape"},
        "label": {"$ref": "#/$defs/nonemptyString"},
        "state": {"enum": ["observed", "derived", "modeled", "conditional"]},
        "as_of": {"$ref": "#/$defs/dateTime"},
        "available_at": {"$ref": "#/$defs/dateTime"},
        "source_refs": {"type": "array", "items": {"$ref": "#/$defs/nonemptyString"}, "minItems": 1, "uniqueItems": true},
        "formula_ref": {"$ref": "#/$defs/nullableString"},
        "payload": {"type": "object", "minProperties": 1}
      },
      "allOf": [
        {"if": {"properties": {"shape": {"const": "news_cluster"}}, "required": ["shape"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/newsClusterPayload"}}}},
        {"if": {"properties": {"shape": {"const": "distribution_sample"}}, "required": ["shape"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/distributionSamplePayload"}}}},
        {"if": {"properties": {"shape": {"const": "quantile_scenarios"}}, "required": ["shape"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/quantileScenariosPayload"}}}},
        {"if": {"properties": {"shape": {"const": "part_to_whole"}}, "required": ["shape"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/partToWholePayload"}}}},
        {"if": {"properties": {"shape": {"const": "additive_components"}}, "required": ["shape"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/additiveComponentsPayload"}}}},
        {"if": {"properties": {"shape": {"const": "quantified_flow"}}, "required": ["shape"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/quantifiedFlowPayload"}}}},
        {"if": {"properties": {"shape": {"const": "ordered_categories"}}, "required": ["shape"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/orderedCategoriesPayload"}}}},
        {"if": {"properties": {"shape": {"const": "payoff_series"}}, "required": ["shape"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/payoffSeriesPayload"}}}},
        {"if": {"properties": {"shape": {"enum": ["quantile_scenarios", "payoff_series"]}}, "required": ["shape"]}, "then": {"properties": {"formula_ref": {"$ref": "#/$defs/nonemptyString"}}}},
        {"if": {"properties": {"state": {"enum": ["derived", "modeled"]}, "shape": {"enum": ["distribution_sample", "part_to_whole", "additive_components", "quantified_flow"]}}, "required": ["state", "shape"]}, "then": {"properties": {"formula_ref": {"$ref": "#/$defs/nonemptyString"}}}}
      ]
    },
    "newsClusterPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["cluster_id", "event_refs", "cluster_method", "unique_source_count"],
      "properties": {
        "cluster_id": {"$ref": "#/$defs/nonemptyString"},
        "event_refs": {"type": "array", "items": {"type": "string", "pattern": "^EV_[A-Za-z0-9_:-]+$"}, "minItems": 2, "uniqueItems": true},
        "cluster_method": {"$ref": "#/$defs/nonemptyString"},
        "unique_source_count": {"type": "integer", "minimum": 2}
      }
    },
    "distributionSamplePayload": {
      "type": "object", "additionalProperties": false,
      "required": ["observations", "n", "observation_unit", "unit", "window", "population", "weights", "quartile_method", "whisker_rule", "outlier_policy"],
      "properties": {
        "observations": {"type": "array", "items": {"type": "number"}, "minItems": 2},
        "n": {"type": "integer", "minimum": 2},
        "observation_unit": {"$ref": "#/$defs/nonemptyString"},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "window": {"$ref": "#/$defs/nonemptyString"},
        "population": {"$ref": "#/$defs/nonemptyString"},
        "weights": {"$ref": "#/$defs/nonemptyString"},
        "quartile_method": {"$ref": "#/$defs/nonemptyString"},
        "whisker_rule": {"$ref": "#/$defs/nonemptyString"},
        "outlier_policy": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "quantileRow": {
      "type": "object", "additionalProperties": false,
      "required": ["t", "values"],
      "properties": {
        "t": {"$ref": "#/$defs/dateTime"},
        "values": {"type": "array", "items": {"type": "number"}, "minItems": 3}
      }
    },
    "quantileScenariosPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["cutoff", "horizon", "quantile_levels", "quantile_values", "unit", "model_or_method", "model_vintage", "calibration"],
      "properties": {
        "cutoff": {"$ref": "#/$defs/dateTime"},
        "horizon": {"$ref": "#/$defs/nonemptyString"},
        "quantile_levels": {"type": "array", "items": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1}, "minItems": 3, "uniqueItems": true},
        "quantile_values": {"type": "array", "items": {"$ref": "#/$defs/quantileRow"}, "minItems": 1},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "model_or_method": {"$ref": "#/$defs/nonemptyString"},
        "model_vintage": {"$ref": "#/$defs/nonemptyString"},
        "calibration": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "labeledValue": {
      "type": "object", "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {"label": {"$ref": "#/$defs/nonemptyString"}, "value": {"type": "number"}}
    },
    "partToWholePayload": {
      "type": "object", "additionalProperties": false,
      "required": ["parts", "denominator", "unit", "basis", "residual"],
      "properties": {
        "parts": {"type": "array", "items": {"$ref": "#/$defs/labeledValue"}, "minItems": 2},
        "denominator": {"type": "number", "exclusiveMinimum": 0},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "basis": {"$ref": "#/$defs/nonemptyString"},
        "residual": {"type": "number", "minimum": 0}
      }
    },
    "additiveComponentsPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["start", "components", "end", "unit", "period", "residual"],
      "properties": {
        "start": {"type": "number"},
        "components": {"type": "array", "items": {"$ref": "#/$defs/labeledValue"}, "minItems": 1},
        "end": {"type": "number"},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "period": {"$ref": "#/$defs/nonemptyString"},
        "residual": {"type": "number"}
      }
    },
    "flowEdge": {
      "type": "object", "additionalProperties": false,
      "required": ["origin", "destination", "value"],
      "properties": {
        "origin": {"$ref": "#/$defs/nonemptyString"},
        "destination": {"$ref": "#/$defs/nonemptyString"},
        "value": {"type": "number", "minimum": 0}
      }
    },
    "quantifiedFlowPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["edges", "unit", "window", "residual", "declared_total"],
      "properties": {
        "edges": {"type": "array", "items": {"$ref": "#/$defs/flowEdge"}, "minItems": 1},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "window": {"$ref": "#/$defs/nonemptyString"},
        "residual": {"type": "number", "minimum": 0},
        "declared_total": {"type": "number", "minimum": 0}
      }
    },
    "orderedCategory": {
      "type": "object", "additionalProperties": false,
      "required": ["label", "state", "source_refs"],
      "properties": {
        "label": {"$ref": "#/$defs/nonemptyString"},
        "state": {"enum": ["observed", "derived", "conditional"]},
        "source_refs": {"type": "array", "items": {"$ref": "#/$defs/nonemptyString"}, "minItems": 1, "uniqueItems": true}
      }
    },
    "orderedCategoriesPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["items", "order_basis"],
      "properties": {
        "items": {"type": "array", "items": {"$ref": "#/$defs/orderedCategory"}, "minItems": 2},
        "order_basis": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "instrumentTerm": {
      "type": "object", "additionalProperties": false,
      "required": ["instrument_ref", "instrument_type", "side", "strike", "expiry", "quantity", "premium"],
      "properties": {
        "instrument_ref": {"type": "string", "pattern": "^INS_[A-Za-z0-9_:-]+$"},
        "instrument_type": {"enum": ["equity", "future", "call", "put", "custom"]},
        "side": {"enum": ["long", "short"]},
        "strike": {"type": ["number", "null"]},
        "expiry": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/dateTime"}]},
        "quantity": {"type": "number", "not": {"const": 0}},
        "premium": {"type": "number", "minimum": 0}
      },
      "allOf": [{
        "if": {"properties": {"instrument_type": {"enum": ["call", "put"]}}, "required": ["instrument_type"]},
        "then": {"properties": {"strike": {"type": "number"}, "expiry": {"$ref": "#/$defs/dateTime"}}}
      }]
    },
    "underlyingDomain": {
      "type": "object", "additionalProperties": false,
      "required": ["min", "max", "unit"],
      "properties": {"min": {"type": "number"}, "max": {"type": "number"}, "unit": {"$ref": "#/$defs/nonemptyString"}}
    },
    "payoffCalculationMethod": {
      "type": "object", "additionalProperties": false,
      "required": ["basis", "model", "assumptions"],
      "properties": {
        "basis": {"enum": ["terminal_payoff", "pre_expiry_pnl"]},
        "model": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
        "assumptions": {"type": "array", "items": {"$ref": "#/$defs/nonemptyString"}, "uniqueItems": true}
      },
      "allOf": [{
        "if": {"properties": {"basis": {"const": "pre_expiry_pnl"}}, "required": ["basis"]},
        "then": {
          "properties": {
            "model": {"$ref": "#/$defs/nonemptyString"},
            "assumptions": {"type": "array", "items": {"$ref": "#/$defs/nonemptyString"}, "minItems": 1, "uniqueItems": true}
          }
        }
      }]
    },
    "payoffPoint": {
      "type": "object", "additionalProperties": false,
      "required": ["underlying", "payoff"],
      "properties": {"underlying": {"type": "number"}, "payoff": {"type": "number"}}
    },
    "payoffSeriesPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["instrument_terms", "underlying_domain", "calculation_method", "values", "unit"],
      "properties": {
        "instrument_terms": {"type": "array", "items": {"$ref": "#/$defs/instrumentTerm"}, "minItems": 1},
        "underlying_domain": {"$ref": "#/$defs/underlyingDomain"},
        "calculation_method": {"$ref": "#/$defs/payoffCalculationMethod"},
        "values": {"type": "array", "items": {"$ref": "#/$defs/payoffPoint"}, "minItems": 2},
        "unit": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "fallback": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "grammar", "reason"],
      "properties": {
        "mode": {"enum": ["qualitative", "key_numbers", "series", "mixed"]},
        "grammar": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "requirement": {
      "type": "object", "additionalProperties": false,
      "required": ["requirement_id", "expression_plan_requirement_ref", "kind", "request_class", "required", "material_to_claim", "expression_surfaces", "status", "resolved_refs", "missing_reason", "fallback"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^REQ_[A-Za-z0-9_:-]+$"},
        "expression_plan_requirement_ref": {"type": "string", "pattern": "^(CEXP|EXPR)_[A-Za-z0-9_:-]+(@r[1-9][0-9]*)?#/data_requirements/D[1-9][0-9]*$"},
        "kind": {"type": "string", "minLength": 1},
        "request_class": {"$ref": "#/$defs/requestClass"},
        "required": {"type": "boolean"},
        "material_to_claim": {"type": "boolean"},
        "expression_surfaces": {"$ref": "#/$defs/expressionSurfaces"},
        "status": {"enum": ["available", "degraded", "missing", "not_applicable"]},
        "resolved_refs": {"$ref": "#/$defs/stringSet"},
        "missing_reason": {"$ref": "#/$defs/nullableString"},
        "fallback": {"anyOf": [{"$ref": "#/$defs/fallback"}, {"type": "null"}]}
      }
    },
    "renderPayload": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "series_refs", "value_refs", "event_refs", "level_refs", "formula_refs"],
      "properties": {
        "mode": {"enum": ["qualitative", "key_numbers", "series", "evidence", "mixed"]},
        "series_refs": {"$ref": "#/$defs/stringSet"},
        "value_refs": {"$ref": "#/$defs/stringSet"},
        "event_refs": {"$ref": "#/$defs/stringSet"},
        "level_refs": {"$ref": "#/$defs/stringSet"},
        "formula_refs": {"$ref": "#/$defs/stringSet"},
        "evidence_object_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "quality": {
      "type": "object", "additionalProperties": false,
      "required": ["decision", "hard_failures", "warnings", "checks", "counts"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "hard_failures": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "checks": {"type": "array", "items": {"type": "string"}},
        "counts": {
          "type": "object", "additionalProperties": false,
          "required": ["instruments", "series", "key_values", "events", "levels", "formulas", "requirements", "missing_required"],
          "properties": {
            "instruments": {"type": "integer", "minimum": 0},
            "series": {"type": "integer", "minimum": 0},
            "key_values": {"type": "integer", "minimum": 0},
            "events": {"type": "integer", "minimum": 0},
            "levels": {"type": "integer", "minimum": 0},
            "formulas": {"type": "integer", "minimum": 0},
            "evidence_objects": {"type": "integer", "minimum": 0},
            "requirements": {"type": "integer", "minimum": 0},
            "missing_required": {"type": "integer", "minimum": 0}
          }
        }
      }
    }
  }
}
