{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/market-figure-v1.schema.json",
  "title": "MarketFigureV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "figure_id", "spec_ref", "grammar", "layout", "state", "generated_at", "theme", "dimensions", "lineage", "content", "asset", "quality_report"],
  "properties": {
    "schema_version": {"const": "market-figure-v1"},
    "figure_id": {"type": "string", "pattern": "^FIGURE_[A-Za-z0-9_:-]{8,}$"},
    "spec_ref": {"type": "string", "pattern": "^FIGSPEC_[A-Za-z0-9_:-]{8,}$"},
    "grammar": {"enum": ["event_reaction", "relative_strength", "expectation_revision", "fundamental_driver", "positioning_pressure", "sensitivity_curve", "instrument_map"]},
    "layout": {"enum": ["compact", "editorial"]},
    "state": {"enum": ["draft", "conditional", "ready", "frozen"]},
    "generated_at": {"type": "string", "format": "date-time"},
    "theme": {"enum": ["cuebook_light", "cuebook_dark"]},
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {"width": {"enum": [720, 1200]}, "height": {"enum": [420, 760]}}
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_artifact_refs", "series_refs", "marker_refs", "key_number_refs", "news_fact_refs", "source_refs", "settlement_claim_ref"],
      "properties": {
        "input_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "series_refs": {"$ref": "#/$defs/stringSet"},
        "marker_refs": {"$ref": "#/$defs/stringSet"},
        "key_number_refs": {"$ref": "#/$defs/stringSet"},
        "news_fact_refs": {"$ref": "#/$defs/stringSet"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "argument_node_refs": {"$ref": "#/$defs/stringSet"},
        "trade_logic_ref": {"$ref": "#/$defs/nullableString"},
        "settlement_claim_ref": {"$ref": "#/$defs/nullableString"}
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "viewpoint", "curve_title", "news_headline", "countercase_line", "settlement_line", "watermark"],
      "properties": {
        "headline": {"$ref": "#/$defs/nonemptyString"},
        "viewpoint": {"$ref": "#/$defs/nonemptyString"},
        "curve_title": {"$ref": "#/$defs/nonemptyString"},
        "news_headline": {"$ref": "#/$defs/nullableString"},
        "countercase_line": {"$ref": "#/$defs/nullableString"},
        "settlement_line": {"$ref": "#/$defs/nullableString"},
        "argument_path_labels": {"$ref": "#/$defs/stringSet"},
        "strategy_tags": {"$ref": "#/$defs/stringSet"},
        "watermark": {"const": "Cuebook"}
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["svg_ref", "content_hash"],
      "properties": {
        "svg_ref": {"type": "string", "minLength": 1},
        "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "hard_failures"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "warnings": {"$ref": "#/$defs/stringSet"},
        "hard_failures": {"$ref": "#/$defs/stringSet"}
      }
    }
  }
}
