{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/visual-argument-v1.schema.json",
  "title": "VisualArgumentV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "argument_id", "revision", "state", "lineage", "subject", "frame", "graph", "metrics", "levels", "scenarios", "settlement", "visual", "quality_report"],
  "properties": {
    "schema_version": {"const": "visual-argument-v1"},
    "argument_id": {"type": "string", "pattern": "^VARG_[A-Za-z0-9_:-]{8,}$"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"enum": ["draft", "conditional", "ready", "frozen"]},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_artifact_refs", "post_ref", "creator_intent_ref", "thesis_ref", "research_pack_ref", "settlement_claim_ref", "decision_cutoff_at"],
      "properties": {
        "input_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "post_ref": {"$ref": "#/$defs/nullableString"},
        "creator_intent_ref": {"$ref": "#/$defs/nullableString"},
        "thesis_ref": {"$ref": "#/$defs/nullableString"},
        "research_pack_ref": {"$ref": "#/$defs/nullableString"},
        "settlement_claim_ref": {"$ref": "#/$defs/nullableString"},
        "decision_cutoff_at": {"$ref": "#/$defs/dateTime"}
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "benchmark", "direction", "horizon_end"],
      "properties": {
        "primary": {"$ref": "#/$defs/instrument"},
        "benchmark": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/instrument"}]},
        "direction": {"enum": ["long", "short", "outperform", "underperform", "range", "neutral", "custom"]},
        "horizon_end": {"$ref": "#/$defs/nullableDateTime"}
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "thesis", "creator_text", "creator_text_preserved", "cuebook_contribution", "visual_job"],
      "properties": {
        "headline": {"$ref": "#/$defs/nonemptyString"},
        "thesis": {"$ref": "#/$defs/nonemptyString"},
        "creator_text": {"$ref": "#/$defs/nullableString"},
        "creator_text_preserved": {"type": "boolean"},
        "cuebook_contribution": {"$ref": "#/$defs/nullableString"},
        "visual_job": {"enum": ["explain_cause", "show_metrics", "map_scenarios", "weigh_evidence", "compare_assets", "show_price_path"]}
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {"type": "array", "minItems": 2, "maxItems": 14, "items": {"$ref": "#/$defs/node"}},
        "edges": {"type": "array", "minItems": 1, "maxItems": 20, "items": {"$ref": "#/$defs/edge"}}
      }
    },
    "metrics": {"type": "array", "maxItems": 8, "items": {"$ref": "#/$defs/metric"}},
    "levels": {"type": "array", "maxItems": 6, "items": {"$ref": "#/$defs/level"}},
    "scenarios": {"type": "array", "maxItems": 5, "items": {"$ref": "#/$defs/scenario"}},
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["settleable", "claim_ref", "deadline_at", "condition", "state"],
      "properties": {
        "settleable": {"type": "boolean"},
        "claim_ref": {"$ref": "#/$defs/nullableString"},
        "deadline_at": {"$ref": "#/$defs/nullableDateTime"},
        "condition": {"$ref": "#/$defs/nullableString"},
        "state": {"enum": ["not_applicable", "draft", "needs_confirmation", "ready", "frozen"]}
      }
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommended_grammar", "alternative_grammars", "rationale", "theme"],
      "properties": {
        "recommended_grammar": {"$ref": "#/$defs/grammar"},
        "alternative_grammars": {"type": "array", "maxItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/grammar"}},
        "rationale": {"$ref": "#/$defs/nonemptyString"},
        "theme": {"enum": ["cuebook_light", "cuebook_dark"]}
      }
    },
    "quality_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "hard_failures"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "warnings": {"$ref": "#/$defs/stringSet"},
        "hard_failures": {"$ref": "#/$defs/stringSet"}
      }
    }
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "dateTime": {"type": "string", "format": "date-time"},
    "nullableDateTime": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/dateTime"}]},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "grammar": {"enum": ["causal_chain", "metric_thesis", "scenario_tree", "evidence_balance", "comparison", "price_timeline"]},
    "instrument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrument_id", "ticker", "display_name"],
      "properties": {
        "instrument_id": {"$ref": "#/$defs/nonemptyString"},
        "ticker": {"$ref": "#/$defs/nonemptyString"},
        "display_name": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "detail", "status", "fact_refs", "source_refs", "metric_ref"],
      "properties": {
        "id": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "kind": {"enum": ["event", "evidence", "mechanism", "actor_action", "market_effect", "metric", "condition", "countercase", "invalidation", "settlement"]},
        "label": {"type": "string", "minLength": 1, "maxLength": 80},
        "detail": {"$ref": "#/$defs/nullableString"},
        "status": {"enum": ["observed", "derived", "conditional", "unresolved"]},
        "fact_refs": {"$ref": "#/$defs/stringSet"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "metric_ref": {"$ref": "#/$defs/nullableString"}
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to", "relation", "certainty", "label"],
      "properties": {
        "id": {"type": "string", "pattern": "^E[1-9][0-9]*$"},
        "from": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "to": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "relation": {"enum": ["causes", "enables", "pressures", "confirms", "challenges", "conditions", "settles", "compares"]},
        "certainty": {"enum": ["observed", "inferred", "hypothesis"]},
        "label": {"$ref": "#/$defs/nullableString"}
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "subject_ref", "label", "display_value", "numeric_value", "unit", "as_of", "source_ref", "status"],
      "properties": {
        "id": {"type": "string", "pattern": "^M[1-9][0-9]*$"},
        "subject_ref": {"enum": ["primary", "benchmark", "context"]},
        "label": {"$ref": "#/$defs/nonemptyString"},
        "display_value": {"$ref": "#/$defs/nonemptyString"},
        "numeric_value": {"type": ["number", "null"]},
        "unit": {"$ref": "#/$defs/nullableString"},
        "as_of": {"$ref": "#/$defs/nullableDateTime"},
        "source_ref": {"$ref": "#/$defs/nonemptyString"},
        "status": {"enum": ["verified", "provisional", "estimated"]}
      }
    },
    "level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "value", "unit", "observed_at", "source_ref", "status"],
      "properties": {
        "id": {"type": "string", "pattern": "^L[1-9][0-9]*$"},
        "kind": {"enum": ["baseline", "target", "trigger", "invalidation", "range_lower", "range_upper"]},
        "value": {"type": "number"},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "observed_at": {"$ref": "#/$defs/nullableDateTime"},
        "source_ref": {"$ref": "#/$defs/nonemptyString"},
        "status": {"enum": ["explicit", "derived"]}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "condition", "outcome", "stance", "fact_refs"],
      "properties": {
        "id": {"type": "string", "pattern": "^SC[1-9][0-9]*$"},
        "label": {"$ref": "#/$defs/nonemptyString"},
        "condition": {"$ref": "#/$defs/nonemptyString"},
        "outcome": {"$ref": "#/$defs/nonemptyString"},
        "stance": {"enum": ["bull", "base", "bear", "risk"]},
        "fact_refs": {"$ref": "#/$defs/stringSet"}
      }
    }
  }
}
