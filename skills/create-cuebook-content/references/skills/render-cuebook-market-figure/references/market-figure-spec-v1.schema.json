{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/market-figure-spec-v1.schema.json",
  "title": "MarketFigureSpecV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "spec_id", "revision", "state", "lineage", "grammar", "frame", "news_anchor", "curve", "key_numbers", "countercase", "settlement", "render", "quality_report"],
  "properties": {
    "schema_version": {"const": "market-figure-spec-v1"},
    "spec_id": {"type": "string", "pattern": "^FIGSPEC_[A-Za-z0-9_:-]{8,}$"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"enum": ["draft", "conditional", "ready", "frozen"]},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_artifact_refs", "visual_argument_ref", "thesis_chart_ref", "chart_data_ref", "indicator_pack_ref", "settlement_claim_ref", "news_fact_refs", "decision_cutoff_at"],
      "properties": {
        "input_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "visual_argument_ref": {"$ref": "#/$defs/nullableString"},
        "thesis_chart_ref": {"$ref": "#/$defs/nullableString"},
        "chart_data_ref": {"$ref": "#/$defs/nullableString"},
        "indicator_pack_ref": {"$ref": "#/$defs/nullableString"},
        "settlement_claim_ref": {"$ref": "#/$defs/nullableString"},
        "news_fact_refs": {"$ref": "#/$defs/stringSet"},
        "decision_cutoff_at": {"$ref": "#/$defs/dateTime"}
      }
    },
    "grammar": {"enum": ["event_reaction", "relative_strength", "expectation_revision", "fundamental_driver", "positioning_pressure", "sensitivity_curve", "instrument_map"]},
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kicker", "headline", "viewpoint"],
      "properties": {
        "kicker": {"$ref": "#/$defs/nonemptyString"},
        "headline": {"$ref": "#/$defs/nonemptyString"},
        "viewpoint": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "argument_path": {
      "anyOf": [
        {"type": "null"},
        {"$ref": "#/$defs/argumentPath"}
      ]
    },
    "trade_logic": {
      "anyOf": [
        {"type": "null"},
        {"$ref": "#/$defs/tradeLogicSummary"}
      ]
    },
    "news_anchor": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["headline", "publisher", "published_at", "status", "fact_refs", "source_refs"],
          "properties": {
            "headline": {"$ref": "#/$defs/nonemptyString"},
            "publisher": {"$ref": "#/$defs/nonemptyString"},
            "published_at": {"$ref": "#/$defs/dateTime"},
            "status": {"enum": ["observed", "provisional", "unconfirmed"]},
            "fact_refs": {"$ref": "#/$defs/stringSet"},
            "source_refs": {"$ref": "#/$defs/stringSet"}
          }
        }
      ]
    },
    "curve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "x_axis", "y_axis", "series", "markers"],
      "properties": {
        "title": {"$ref": "#/$defs/nonemptyString"},
        "x_axis": {"$ref": "#/$defs/axis"},
        "y_axis": {"$ref": "#/$defs/axis"},
        "series": {"type": "array", "minItems": 1, "maxItems": 7, "items": {"$ref": "#/$defs/series"}},
        "markers": {"type": "array", "maxItems": 8, "items": {"$ref": "#/$defs/marker"}},
        "data_fidelity": {"enum": ["native_series", "source_chart_redraw"]},
        "methodology": {"$ref": "#/$defs/nullableString"}
      }
    },
    "key_numbers": {"type": "array", "minItems": 2, "maxItems": 4, "items": {"$ref": "#/$defs/keyNumber"}},
    "countercase": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "condition", "source_refs"],
          "properties": {
            "label": {"$ref": "#/$defs/nonemptyString"},
            "condition": {"$ref": "#/$defs/nonemptyString"},
            "source_refs": {"$ref": "#/$defs/stringSet"}
          }
        }
      ]
    },
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["settleable", "claim_ref", "deadline_at", "success_line", "status"],
      "properties": {
        "settleable": {"type": "boolean"},
        "claim_ref": {"$ref": "#/$defs/nullableString"},
        "deadline_at": {"$ref": "#/$defs/nullableDateTime"},
        "success_line": {"$ref": "#/$defs/nullableString"},
        "status": {"enum": ["none", "needs_confirmation", "active", "frozen", "settled"]}
      }
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "width", "height", "theme", "watermark", "show_legend", "show_sources"],
      "properties": {
        "layout": {"enum": ["compact", "editorial"]},
        "width": {"enum": [720, 1200]},
        "height": {"enum": [420, 760]},
        "theme": {"enum": ["cuebook_light", "cuebook_dark"]},
        "semantic_mode": {"enum": ["curve_only", "argument_curve"]},
        "watermark": {"const": "Cuebook"},
        "show_legend": {"type": "boolean"},
        "show_sources": {"type": "boolean"},
        "focus_series_ids": {"type": "array", "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "pattern": "^S[1-9][0-9]*$"}},
        "endpoint_series_ids": {"type": "array", "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "pattern": "^S[1-9][0-9]*$"}}
      }
    },
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "dateTime": {"type": "string", "format": "date-time"},
    "nullableDateTime": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/dateTime"}]},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "axis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label", "unit", "zero_policy"],
      "properties": {
        "kind": {"enum": ["time", "category", "numeric", "value"]},
        "label": {"$ref": "#/$defs/nonemptyString"},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "zero_policy": {"enum": ["include", "adaptive"]}
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "state", "source_ref"],
      "properties": {
        "x": {"anyOf": [{"type": "number"}, {"$ref": "#/$defs/nonemptyString"}]},
        "y": {"type": "number"},
        "state": {"enum": ["sealed", "forming", "modelled"]},
        "source_ref": {"$ref": "#/$defs/nullableString"},
        "label": {"$ref": "#/$defs/nullableString"}
      }
    },
    "series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "role", "data_kind", "transformation", "unit", "source_ref", "formula", "baseline", "points"],
      "properties": {
        "id": {"type": "string", "pattern": "^S[1-9][0-9]*$"},
        "label": {"$ref": "#/$defs/nonemptyString"},
        "role": {"enum": ["primary", "benchmark", "driver", "context"]},
        "data_kind": {"enum": ["observed", "formula", "digitized_observed"]},
        "transformation": {"enum": ["raw_value", "return_from_baseline", "normalized_index", "excess_return", "revision", "flow", "positioning", "sensitivity", "payoff", "risk_exposure_map"]},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "source_ref": {"$ref": "#/$defs/nonemptyString"},
        "stroke_style": {"enum": ["solid", "dashed", "dotted"]},
        "color_role": {"enum": ["focus", "positive", "comparison", "support", "violet", "context", "risk"]},
        "formula": {"$ref": "#/$defs/nullableString"},
        "baseline": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["value", "observed_at", "source_ref"],
              "properties": {
                "value": {"type": "number"},
                "observed_at": {"$ref": "#/$defs/dateTime"},
                "source_ref": {"$ref": "#/$defs/nonemptyString"}
              }
            }
          ]
        },
        "points": {"type": "array", "minItems": 2, "maxItems": 500, "items": {"$ref": "#/$defs/point"}}
      }
    },
    "marker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "x", "y", "label", "status", "source_ref"],
      "properties": {
        "id": {"type": "string", "pattern": "^M[1-9][0-9]*$"},
        "kind": {"enum": ["event", "publication", "baseline", "latest", "trigger", "target", "invalidation", "expiry", "estimate"]},
        "x": {"anyOf": [{"type": "number"}, {"$ref": "#/$defs/nonemptyString"}]},
        "y": {"anyOf": [{"type": "null"}, {"type": "number"}]},
        "label": {"$ref": "#/$defs/nonemptyString"},
        "status": {"enum": ["observed", "derived", "proposed"]},
        "source_ref": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "keyNumber": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "display_value", "numeric_value", "unit", "as_of", "role", "status", "source_ref"],
      "properties": {
        "id": {"type": "string", "pattern": "^K[1-9][0-9]*$"},
        "label": {"$ref": "#/$defs/nonemptyString"},
        "display_value": {"$ref": "#/$defs/nonemptyString"},
        "numeric_value": {"anyOf": [{"type": "null"}, {"type": "number"}]},
        "unit": {"$ref": "#/$defs/nonemptyString"},
        "as_of": {"$ref": "#/$defs/nullableDateTime"},
        "role": {"enum": ["magnitude", "comparison", "driver", "risk", "settlement"]},
        "status": {"enum": ["observed", "derived", "provisional", "modelled"]},
        "source_ref": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "argumentPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "nodes", "edges"],
      "properties": {
        "mode": {"enum": ["causal_chain", "confirmation_ladder", "evidence_ladder"]},
        "nodes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": {"$ref": "#/$defs/pathNode"}
        },
        "edges": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/pathEdge"}
        }
      }
    },
    "pathNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "status", "source_refs"],
      "properties": {
        "id": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "kind": {"enum": ["event", "evidence", "mechanism", "actor_action", "market_effect", "metric", "condition", "countercase", "invalidation", "settlement"]},
        "label": {"type": "string", "minLength": 1, "maxLength": 80},
        "status": {"enum": ["observed", "derived", "conditional", "unresolved"]},
        "source_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "pathEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "relation", "certainty", "label"],
      "properties": {
        "from": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "to": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "relation": {"enum": ["causes", "enables", "pressures", "confirms", "challenges", "conditions", "settles", "compares"]},
        "certainty": {"enum": ["observed", "inferred", "hypothesis"]},
        "label": {"$ref": "#/$defs/nullableString"}
      }
    },
    "tradeLogicSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_ref", "family", "mechanism", "expression", "horizon", "public_tags"],
      "properties": {
        "profile_ref": {"type": "string", "pattern": "^TLOGIC_[A-Za-z0-9_:-]{8,}$"},
        "family": {"enum": ["event_driven", "relative_value", "directional", "global_macro", "factor_style", "volatility", "liquidity_microstructure", "carry_income"]},
        "mechanism": {"enum": ["risk_premium_transmission", "expectation_revision", "supply_demand_repricing", "forced_flow", "positioning_squeeze", "liquidity_amplification", "price_discovery_lead_lag", "valuation_mean_reversion", "fundamental_compounding", "momentum_continuation", "volatility_repricing", "carry_roll_down", "cross_asset_transmission"]},
        "expression": {"enum": ["outright_long", "outright_short", "relative_value_pair", "long_short_basket", "etf_basket", "curve_spread", "options_convexity", "volatility_trade", "hedge_overlay", "no_trade"]},
        "horizon": {"enum": ["intraday", "one_to_three_days", "one_to_four_weeks", "one_to_three_months", "structural"]},
        "public_tags": {"type": "array", "minItems": 2, "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 24}}
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "hard_failures"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "warnings": {"$ref": "#/$defs/stringSet"},
        "hard_failures": {"$ref": "#/$defs/stringSet"}
      }
    }
  }
}
