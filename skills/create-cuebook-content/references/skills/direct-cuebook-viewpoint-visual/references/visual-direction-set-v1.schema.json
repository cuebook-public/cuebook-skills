{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/visual-direction-set-v1.schema.json",
  "title": "VisualDirectionSetV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "direction_set_id", "state", "input_refs", "fact_refs", "data_requirement_refs", "design_read", "message", "bindings", "logic_progression", "directions", "selected_direction_id", "selection_reason"],
  "properties": {
    "schema_version": {"const": "visual-direction-set-v1"},
    "direction_set_id": {"type": "string", "pattern": "^VDSET_[A-Za-z0-9_:-]{8,}$"},
    "state": {"enum": ["draft", "previewed", "selected"]},
    "input_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
    "fact_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "data_requirement_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "intent_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reader_job", "reader_question", "analytic_relationship", "evidence_shape_refs", "finance_transform", "comparison_basis", "baseline_policy", "chart_decision", "renderer_route", "compact_fallback"],
      "properties": {
        "reader_job": {"type": "string", "minLength": 3, "maxLength": 120},
        "reader_question": {"type": "string", "minLength": 3, "maxLength": 160},
        "analytic_relationship": {"enum": ["deviation", "magnitude", "change_over_time", "ranking", "distribution", "correlation", "part_to_whole", "flow", "relative_value", "term_structure", "revision", "event_reaction", "trigger_state", "scenario_payoff", "causal_transmission"]},
        "evidence_shape_refs": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"enum": ["creator_judgment", "point_metric", "level", "ordered_series", "multi_series", "ohlcv_series", "event_set", "news_cluster", "calendar_events", "qualitative_relation", "causal_graph", "pair_spread", "distribution_sample", "quantile_scenarios", "part_to_whole", "additive_components", "quantified_flow", "ordered_categories", "payoff_series", "comparison_pair", "revision_series", "term_structure"]}},
        "finance_transform": {"enum": ["level", "delta", "return", "excess_return", "indexed", "spread", "drawdown", "contribution", "event_window", "quantile", "payoff", "maturity_profile", "causal_path", "categorical_order", "none"]},
        "comparison_basis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["unit", "currency", "period", "benchmark", "normalization"],
          "properties": {
            "unit": {"type": ["string", "null"], "maxLength": 80},
            "currency": {"type": ["string", "null"], "maxLength": 20},
            "period": {"type": ["string", "null"], "maxLength": 80},
            "benchmark": {"type": ["string", "null"], "maxLength": 80},
            "normalization": {"type": ["string", "null"], "maxLength": 80}
          }
        },
        "baseline_policy": {"enum": ["zero", "reference", "indexed_100", "cropped_disclosed", "none"]},
        "chart_decision": {"enum": ["text", "number", "table", "chart", "diagram", "full_ohlcv"]},
        "renderer_route": {"enum": ["directed_html", "render-cuebook-thesis-chart"]},
        "compact_fallback": {"type": "string", "minLength": 8, "maxLength": 180}
      }
    },
    "design_read": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "mode", "audience", "tone", "design_language", "reading_context", "design_variance", "visual_density", "creator_visual_profile", "preserve", "retire"],
      "properties": {
        "statement": {"type": "string", "minLength": 20, "maxLength": 300},
        "mode": {"enum": ["compose", "redesign_preserve", "redesign_overhaul"]},
        "audience": {"type": "string", "minLength": 3, "maxLength": 120},
        "tone": {"enum": ["urgent", "skeptical", "calm", "analytical", "contrarian", "promotional"]},
        "design_language": {"type": "string", "minLength": 3, "maxLength": 120},
        "reading_context": {"const": "feed_static_3_second"},
        "design_variance": {"type": "integer", "minimum": 1, "maximum": 10},
        "visual_density": {"type": "integer", "minimum": 1, "maximum": 10},
        "creator_visual_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "source_ref", "register", "energy", "conviction", "technicality", "emotionality", "compression", "contrast", "chroma", "neutral_temperature", "surface_bias", "signature_palette_id", "recent_palette_ids", "visual_context_refs"],
          "properties": {
            "source": {"enum": ["voice_spec", "commentator_profile", "creator_visual_corpus", "creator_text", "cuebook_default"]},
            "source_ref": {"type": ["string", "null"], "minLength": 3, "maxLength": 160},
            "register": {"enum": ["desk", "explainer", "strategist", "cinematic", "confessional", "meme", "research_memo"]},
            "energy": {"type": "integer", "minimum": 1, "maximum": 5},
            "conviction": {"type": "integer", "minimum": 1, "maximum": 5},
            "technicality": {"type": "integer", "minimum": 1, "maximum": 5},
            "emotionality": {"type": "integer", "minimum": 1, "maximum": 5},
            "compression": {"type": "integer", "minimum": 1, "maximum": 5},
            "contrast": {"enum": ["soft", "balanced", "high"]},
            "chroma": {"enum": ["restrained", "balanced", "vivid"]},
            "neutral_temperature": {"enum": ["cool", "neutral", "warm"]},
            "surface_bias": {"enum": ["light", "dark", "mixed"]},
            "signature_palette_id": {"type": ["string", "null"], "pattern": "^[a-z0-9]+(?:-[a-z0-9]+){1,5}$", "maxLength": 64},
            "recent_palette_ids": {"type": "array", "maxItems": 6, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+){1,5}$", "maxLength": 64}},
            "visual_context_refs": {"type": "array", "maxItems": 6, "uniqueItems": true, "items": {"type": "string", "minLength": 3, "maxLength": 180}}
          }
        },
        "preserve": {"type": "array", "maxItems": 6, "uniqueItems": true, "items": {"type": "string", "minLength": 2, "maxLength": 100}},
        "retire": {"type": "array", "maxItems": 6, "uniqueItems": true, "items": {"type": "string", "minLength": 2, "maxLength": 100}}
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "because", "implication", "direction", "asset_refs", "horizon"],
      "properties": {
        "claim": {"type": "string", "minLength": 2, "maxLength": 80},
        "because": {"type": "string", "minLength": 2, "maxLength": 140},
        "implication": {"type": "string", "minLength": 2, "maxLength": 120},
        "direction": {"enum": ["long", "short", "relative", "avoid", "watch", "explain", "neutral"]},
        "asset_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "horizon": {"type": ["string", "null"], "maxLength": 80}
      }
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["binding_id", "kind", "label", "state", "source_refs", "request_class", "material_to_claim", "selected_for_display"],
        "properties": {
          "binding_id": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
          "kind": {"enum": ["creator_judgment", "fact", "metric", "series", "level", "event", "quote", "relationship", "instrument"]},
          "label": {"type": "string", "minLength": 1, "maxLength": 160},
          "value": {"type": ["number", "string", "null"]},
          "unit": {"type": ["string", "null"], "maxLength": 40},
          "state": {"enum": ["observed", "reported", "derived", "conditional", "creator_view"]},
          "source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "request_class": {"enum": ["creator_judgment", "qualitative_evidence", "news_anchor", "official_event", "valuation_metric", "comparison_metric", "market_series", "price_level", "settlement_reference"]},
          "material_to_claim": {"type": "boolean"},
          "selected_for_display": {"type": "boolean"}
        }
      }
    },
    "logic_progression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "steps", "links", "public_spine_step_ids", "message_step_map"],
      "properties": {
        "pattern": {"enum": ["reaction_test", "event_transmission", "expectation_revision", "valuation_reframe", "relative_value", "cycle_rotation", "flow_pressure", "technical_trigger", "scenario_branch", "strategy_ladder", "custom"]},
        "steps": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step_id", "role", "state", "text", "binding_refs"],
            "properties": {
              "step_id": {"type": "string", "pattern": "^LSTEP_[A-Za-z0-9_:-]{3,}$"},
              "role": {"enum": ["context", "event", "evidence", "mechanism", "actor_action", "tension", "judgment", "market_effect", "trade_implication", "catalyst", "condition", "invalidation"]},
              "state": {"enum": ["observed", "reported", "derived", "creator_view", "conditional"]},
              "text": {"type": "string", "minLength": 2, "maxLength": 120},
              "binding_refs": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "pattern": "^BIND_"}}
            }
          }
        },
        "links": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from_step_id", "to_step_id", "relation"],
            "properties": {
              "from_step_id": {"type": "string", "pattern": "^LSTEP_"},
              "to_step_id": {"type": "string", "pattern": "^LSTEP_"},
              "relation": {"enum": ["causes", "enables", "pressures", "confirms", "challenges", "conditions", "compares", "leads_to", "invalidates"]}
            }
          }
        },
        "public_spine_step_ids": {"type": "array", "minItems": 3, "maxItems": 5, "uniqueItems": true, "items": {"type": "string", "pattern": "^LSTEP_"}},
        "message_step_map": {
          "type": "object",
          "additionalProperties": false,
          "required": ["claim_step_id", "because_step_id", "implication_step_id"],
          "properties": {
            "claim_step_id": {"type": "string", "pattern": "^LSTEP_"},
            "because_step_id": {"type": "string", "pattern": "^LSTEP_"},
            "implication_step_id": {"type": "string", "pattern": "^LSTEP_"}
          }
        }
      }
    },
    "directions": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["direction_id", "design_logic", "design_anchor", "layout_system", "route", "logic_route", "concept", "form_from_content", "hero_primitive", "support_primitives", "reading_order", "spatial_skeleton", "html_ref", "preview_ref", "compact_preview_ref", "capture_report_ref", "render_audit_ref", "binding_refs", "preflight", "critique"],
        "properties": {
          "direction_id": {"type": "string", "pattern": "^VDIR_[A-Za-z0-9_:-]{6,}$"},
          "design_logic": {"enum": ["product_native", "benchmark_transfer", "content_native"]},
          "design_anchor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_kind", "source_ref", "verified_at", "transferred_principle", "excluded_surface_traits"],
            "properties": {
              "source_kind": {"enum": ["cuebook_product", "verified_benchmark", "content_motif"]},
              "source_ref": {"type": ["string", "null"], "maxLength": 300},
              "verified_at": {"type": ["string", "null"], "format": "date-time"},
              "transferred_principle": {"type": "string", "minLength": 8, "maxLength": 240},
              "excluded_surface_traits": {"type": "array", "minItems": 1, "maxItems": 6, "uniqueItems": true, "items": {"type": "string", "minLength": 2, "maxLength": 100}}
            }
          },
          "layout_system": {
            "type": "object",
            "additionalProperties": false,
            "required": ["hierarchy", "entry_role", "grid", "alignment", "density", "type_scale", "craft_system", "color_system", "data_role", "responsive_rule"],
            "properties": {
              "hierarchy": {"type": "array", "minItems": 2, "maxItems": 5, "uniqueItems": true, "items": {"enum": ["claim", "reason", "evidence", "implication", "context", "brand"]}},
              "entry_role": {"enum": ["claim", "evidence", "condition"]},
              "grid": {"enum": ["single_axis", "editorial_split", "asymmetric_stage", "comparison_field", "timeline_band", "radial_field", "distribution_field", "network_field", "calendar_field", "instrument_field", "freeform"]},
              "alignment": {"enum": ["left", "centered", "split", "mixed"]},
              "density": {"enum": ["quiet", "balanced", "dense"]},
              "type_scale": {
                "type": "object",
                "additionalProperties": false,
                "required": ["hero_px_canvas", "body_px_canvas", "meta_px_canvas", "hero_body_ratio"],
                "properties": {
                  "hero_px_canvas": {"type": "number", "minimum": 64, "maximum": 120},
                  "body_px_canvas": {"type": "number", "minimum": 28, "maximum": 52},
                  "meta_px_canvas": {"type": "number", "minimum": 18, "maximum": 30},
                  "hero_body_ratio": {"type": "number", "minimum": 1.5, "maximum": 5}
                }
              },
              "craft_system": {
                "type": "object",
                "additionalProperties": false,
                "required": ["type_family_mode", "claim_weight", "claim_line_height", "claim_wrap", "number_style", "max_type_sizes", "max_weights", "radius_rule", "surface_separation", "optical_priority", "compact_mode", "compact_type_scale"],
                "properties": {
                  "type_family_mode": {"enum": ["system", "brand", "creator"]},
                  "claim_weight": {"type": "integer", "minimum": 500, "maximum": 900},
                  "claim_line_height": {"type": "number", "minimum": 1, "maximum": 1.25},
                  "claim_wrap": {"const": "balance"},
                  "number_style": {"const": "tabular-nums"},
                  "max_type_sizes": {"type": "integer", "minimum": 2, "maximum": 4},
                  "max_weights": {"type": "integer", "minimum": 2, "maximum": 4},
                  "radius_rule": {"enum": ["sharp", "soft", "concentric", "mixed_documented"]},
                  "surface_separation": {"enum": ["whitespace", "divider", "shadow", "mixed"]},
                  "optical_priority": {"type": "string", "minLength": 8, "maxLength": 180},
                  "compact_mode": {"enum": ["reflow", "recompose"]},
                  "compact_type_scale": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["hero_px_622", "body_px_622", "meta_px_622"],
                    "properties": {
                      "hero_px_622": {"type": "number", "minimum": 32, "maximum": 60},
                      "body_px_622": {"type": "number", "minimum": 14, "maximum": 26},
                      "meta_px_622": {"type": "number", "minimum": 11, "maximum": 18}
                    }
                  }
                }
              },
              "color_system": {
                "type": "object",
                "additionalProperties": false,
                "required": ["palette_family", "palette_strategy", "preset_id", "selection_reason", "surface", "semantic_roles", "dominant_role", "role_color_map", "redundant_cues"],
                "properties": {
                  "palette_family": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+){1,5}$", "maxLength": 64},
                  "palette_strategy": {"enum": ["creator_native", "thesis_native", "contrast_variant"]},
                  "preset_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+){1,5}$", "maxLength": 64},
                  "selection_reason": {"type": "string", "minLength": 8, "maxLength": 180},
                  "surface": {"enum": ["light", "dark", "split"]},
                  "semantic_roles": {"type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": {"enum": ["positive", "negative", "observed", "catalyst", "conditional", "comparison", "risk"]}},
                  "dominant_role": {"enum": ["positive", "negative", "observed", "catalyst", "conditional", "comparison", "risk"]},
                  "role_color_map": {
                    "type": "object",
                    "minProperties": 1,
                    "maxProperties": 3,
                    "propertyNames": {"enum": ["positive", "negative", "observed", "catalyst", "conditional", "comparison", "risk"]},
                    "additionalProperties": {"enum": ["accent-a", "accent-b", "accent-c", "risk"]}
                  },
                  "redundant_cues": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"enum": ["type", "position", "label", "shape", "stroke", "solid_dashed", "area"]}}
                }
              },
              "data_role": {"enum": ["hero", "support", "none"]},
              "responsive_rule": {"type": "string", "minLength": 8, "maxLength": 240}
            }
          },
          "route": {"enum": ["claim_first", "evidence_first", "reasoning_first", "strategy_first", "freeform"]},
          "logic_route": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entry_step_id", "visible_step_ids", "compact_step_ids"],
            "properties": {
              "entry_step_id": {"type": "string", "pattern": "^LSTEP_"},
              "visible_step_ids": {"type": "array", "minItems": 3, "maxItems": 6, "uniqueItems": true, "items": {"type": "string", "pattern": "^LSTEP_"}},
              "compact_step_ids": {"type": "array", "minItems": 3, "maxItems": 5, "uniqueItems": true, "items": {"type": "string", "pattern": "^LSTEP_"}}
            }
          },
          "expression_recipe": {
            "type": "object",
            "additionalProperties": false,
            "required": ["candidate_job", "evidence_shapes", "primary_grammar", "support_grammars", "proof_binding_refs", "data_requirement_refs", "composition_rule", "fit_reason"],
            "properties": {
              "candidate_job": {"enum": ["conviction_snapshot", "evidence_proof", "relative_comparison", "distribution_risk", "trigger_watch", "news_synthesis", "mechanism_path", "scenario_range", "flow_map", "strategy_map", "cycle_map"]},
              "evidence_shapes": {
                "type": "array",
                "minItems": 1,
                "maxItems": 4,
                "uniqueItems": true,
                "items": {"enum": ["creator_judgment", "point_metric", "level", "ordered_series", "multi_series", "ohlcv_series", "event_set", "news_cluster", "calendar_events", "qualitative_relation", "causal_graph", "pair_spread", "distribution_sample", "quantile_scenarios", "part_to_whole", "additive_components", "quantified_flow", "ordered_categories", "payoff_series", "comparison_pair", "revision_series", "term_structure"]}
              },
              "primary_grammar": {"enum": ["editorial_statement", "big_number_proof", "variance_bar", "bullet_comparison", "revision_ladder", "maturity_profile", "term_structure_curve", "observed_curve", "curve_with_events", "threshold_band", "event_reaction", "news_constellation", "catalyst_ribbon", "tension_field", "box_whisker", "histogram_density", "fan_quantiles", "dot_plot", "slopegraph", "dumbbell", "indexed_comparison", "spread_divergence", "stacked_composition", "dot_matrix", "waterfall_bridge", "causal_chain", "transmission_gate", "scenario_tree", "risk_ladder", "cycle_map", "flow_map", "payoff_curve", "calendar_map", "ohlcv_trigger_chart"]},
              "support_grammars": {
                "type": "array",
                "maxItems": 2,
                "uniqueItems": true,
                "items": {"enum": ["editorial_statement", "big_number_proof", "variance_bar", "bullet_comparison", "revision_ladder", "maturity_profile", "term_structure_curve", "observed_curve", "curve_with_events", "threshold_band", "event_reaction", "news_constellation", "catalyst_ribbon", "tension_field", "box_whisker", "histogram_density", "fan_quantiles", "dot_plot", "slopegraph", "dumbbell", "indexed_comparison", "spread_divergence", "stacked_composition", "dot_matrix", "waterfall_bridge", "causal_chain", "transmission_gate", "scenario_tree", "risk_ladder", "cycle_map", "flow_map", "payoff_curve", "calendar_map", "ohlcv_trigger_chart"]}
              },
              "market_relationship": {"enum": ["deviation", "magnitude", "change_over_time", "ranking", "distribution", "correlation", "part_to_whole", "flow", "relative_value", "term_structure", "revision", "event_reaction", "trigger_state", "scenario_payoff", "causal_transmission"]},
              "argument_archetype": {"enum": ["forecast_surprise", "guidance_reset", "valuation_reframe", "relative_trade", "crowding_unwind", "event_driven", "balance_sheet_pressure", "term_structure_risk", "technical_trigger", "regime_shift", "capital_flow", "news_synthesis", "scenario_payoff", "strategy_ladder"]},
              "composition_archetype": {"enum": ["chart_stage", "editorial_split", "comparison_axis", "instrument_strip", "threshold_field", "transmission_gate", "timeline_rail", "distribution_field", "scenario_field", "network_field", "editorial_statement"]},
              "axis_integrity": {"enum": ["time_scaled", "ordinal_gap_marked", "uniform_true"], "description": "Required when a selected grammar declares an ordered_axis (tenor, vintage): how unequal gaps on the ordered axis stay honest in the rendered geometry."},
              "proof_binding_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^BIND_"}},
              "data_requirement_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}, "description": "Subset of the direction-set data_requirement_refs used by this expression recipe."},
              "composition_rule": {"type": "string", "minLength": 12, "maxLength": 240},
              "fit_reason": {"type": "string", "minLength": 12, "maxLength": 240}
            }
          },
          "concept": {"type": "string", "minLength": 8, "maxLength": 240},
          "form_from_content": {"type": "string", "minLength": 8, "maxLength": 240},
          "hero_primitive": {"enum": ["statement", "key_number", "quote_fragment", "observed_curve", "level", "before_after", "contrast", "causal_path", "tension", "loop", "branch", "ladder", "timeline", "news_cluster", "distribution", "fan_range", "part_to_whole", "quantified_flow", "spread", "payoff", "full_chart", "freeform"]},
          "support_primitives": {"type": "array", "maxItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 2, "maxLength": 40}},
          "reading_order": {"type": "array", "minItems": 2, "maxItems": 4, "items": {"type": "string", "minLength": 1, "maxLength": 80}},
          "spatial_skeleton": {"type": "string", "minLength": 5, "maxLength": 160},
          "html_ref": {"type": "string", "pattern": "^[^/].*\\.html$"},
          "preview_ref": {"type": "string", "pattern": "^[^/].*\\.png$"},
          "compact_preview_ref": {"type": "string", "pattern": "^[^/].*\\.png$"},
          "capture_report_ref": {"type": ["string", "null"], "pattern": "^[^/].*\\.json$"},
          "render_audit_ref": {"type": ["string", "null"], "pattern": "^[^/].*\\.json$"},
          "binding_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^BIND_"}},
          "preflight": {
            "type": "object",
            "additionalProperties": false,
            "required": ["copy_audited", "compact_readable", "anti_default_checked", "layout_signature_unique", "source_bindings_complete", "logic_route_complete", "shape_system_consistent", "typography_craft_checked", "optical_alignment_checked", "hierarchy_survives_grayscale", "semantic_color_checked"],
            "properties": {
              "copy_audited": {"type": "boolean"},
              "compact_readable": {"type": "boolean"},
              "anti_default_checked": {"type": "boolean"},
              "layout_signature_unique": {"type": "boolean"},
              "source_bindings_complete": {"type": "boolean"},
              "logic_route_complete": {"type": "boolean"},
              "shape_system_consistent": {"type": "boolean"},
              "typography_craft_checked": {"type": "boolean"},
              "optical_alignment_checked": {"type": "boolean"},
              "hierarchy_survives_grayscale": {"type": "boolean"},
              "semantic_color_checked": {"type": "boolean"}
            }
          },
          "critique": {
            "type": "object",
            "additionalProperties": false,
            "required": ["concept", "three_second", "hierarchy", "data_integrity", "color_logic", "craft", "originality", "anti_default", "weighted_score", "verdict", "revision"],
            "properties": {
              "concept": {"type": "number", "minimum": 0, "maximum": 10},
              "three_second": {"type": "number", "minimum": 0, "maximum": 10},
