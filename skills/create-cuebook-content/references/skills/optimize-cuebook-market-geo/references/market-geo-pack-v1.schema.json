{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://market-content.local/schemas/market-geo-pack-v1.schema.json",
  "title": "MarketGEOPackV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack_id", "input_hash", "ruleset_version", "generated_at", "mode", "brief", "source_register", "seo_eligibility", "entity_graph", "fact_cards", "question_map", "answer_units", "citation_map", "crawler_access", "measurement_plan", "observations", "sample_summary", "issues", "quality_report", "readiness"],
  "properties": {
    "schema_version": {"const": "market-geo-pack.v1"},
    "pack_id": {"type": "string", "pattern": "^geo_pack_[a-f0-9]{16}$"},
    "input_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "ruleset_version": {"type": "string", "pattern": "^cuebook-market-geo/[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "mode": {"enum": ["plan", "preflight", "monitor_plan", "sample_review"]},
    "brief": {"$ref": "#/$defs/brief"},
    "source_register": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}},
    "seo_eligibility": {"$ref": "#/$defs/seoEligibility"},
    "entity_graph": {"$ref": "#/$defs/entityGraph"},
    "fact_cards": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/factCard"}},
    "question_map": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/question"}},
    "answer_units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/answerUnit"}},
    "citation_map": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/citation"}},
    "crawler_access": {"type": "array", "items": {"$ref": "#/$defs/crawlerAccess"}},
    "measurement_plan": {"$ref": "#/$defs/measurementPlan"},
    "observations": {"type": "array", "items": {"$ref": "#/$defs/observation"}},
    "sample_summary": {"$ref": "#/$defs/sampleSummary"},
    "issues": {"type": "array", "items": {"$ref": "#/$defs/issue"}},
    "quality_report": {"$ref": "#/$defs/qualityReport"},
    "readiness": {"enum": ["blocked", "conditional", "ready"]}
  },
  "$defs": {
    "nullableString": {"type": ["string", "null"]},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cue_ref", "research_pack_ref", "seo_pack_ref", "artifact_ref", "target_url", "locale", "regions", "engines", "temporal_mode", "as_of", "source_refs", "sample_refs", "personalized_advice_allowed"],
      "properties": {
        "cue_ref": {"$ref": "#/$defs/nullableString"},
        "research_pack_ref": {"type": "string", "minLength": 1},
        "seo_pack_ref": {"$ref": "#/$defs/nullableString"},
        "artifact_ref": {"$ref": "#/$defs/nullableString"},
        "target_url": {"$ref": "#/$defs/nullableString"},
        "locale": {"type": "string", "minLength": 2},
        "regions": {"$ref": "#/$defs/stringSet"},
        "engines": {"$ref": "#/$defs/stringSet"},
        "temporal_mode": {"enum": ["realtime", "historical_replay", "evergreen"]},
        "as_of": {"$ref": "#/$defs/nullableString"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "sample_refs": {"$ref": "#/$defs/stringSet"},
        "personalized_advice_allowed": {"const": false}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_ref", "source_locator", "kind", "observed_at", "freshness", "fact_ids", "evidence_ref"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^GEO_S[0-9]+$"},
        "source_ref": {"type": "string", "minLength": 1},
        "source_locator": {"type": "string", "minLength": 1},
        "kind": {"enum": ["research_fact", "official_guidance", "page_observation", "authorized_platform_sample", "manual_platform_sample", "synthetic_sample", "hypothesis"]},
        "observed_at": {"$ref": "#/$defs/nullableString"},
        "freshness": {"enum": ["current", "stale", "unknown"]},
        "fact_ids": {"$ref": "#/$defs/stringSet"},
        "evidence_ref": {"$ref": "#/$defs/nullableString"}
      }
    },
    "seoEligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "seo_pack_ref", "notes"],
      "properties": {
        "state": {"enum": ["pass", "conditional", "blocked", "unknown"]},
        "seo_pack_ref": {"$ref": "#/$defs/nullableString"},
        "notes": {"type": "string"}
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_id", "canonical_name", "kind", "aliases", "fact_ids", "source_ids", "confidence"],
      "properties": {
        "entity_id": {"type": "string", "pattern": "^GEO_ENT_[A-Za-z0-9_-]+$"},
        "canonical_name": {"type": "string", "minLength": 1},
        "kind": {"enum": ["company", "ticker", "security", "sector", "metric", "event", "person", "regulator", "concept"]},
        "aliases": {"$ref": "#/$defs/stringSet"},
        "fact_ids": {"$ref": "#/$defs/stringSet"},
        "source_ids": {"$ref": "#/$defs/stringSet"},
        "confidence": {"enum": ["high", "medium", "low"]}
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation_id", "subject_entity_id", "predicate", "object_entity_id", "status", "fact_ids", "source_ids"],
      "properties": {
        "relation_id": {"type": "string", "pattern": "^GEO_REL_[A-Za-z0-9_-]+$"},
        "subject_entity_id": {"type": "string", "minLength": 1},
        "predicate": {"type": "string", "minLength": 1},
        "object_entity_id": {"type": "string", "minLength": 1},
        "status": {"enum": ["verified", "derived", "hypothesis"]},
        "fact_ids": {"$ref": "#/$defs/stringSet"},
        "source_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "entityGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entities", "relations"],
      "properties": {
        "entities": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/entity"}},
        "relations": {"type": "array", "items": {"$ref": "#/$defs/relation"}}
      }
    },
    "factCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["card_id", "question", "answer_boundary", "fact_ids", "source_ids", "as_of", "freshness", "temporal_scope", "prohibited_inferences"],
      "properties": {
        "card_id": {"type": "string", "pattern": "^GEO_FC[0-9]+$"},
        "question": {"type": "string", "minLength": 1},
        "answer_boundary": {"type": "string", "minLength": 1},
        "fact_ids": {"$ref": "#/$defs/stringSet"},
        "source_ids": {"$ref": "#/$defs/stringSet"},
        "as_of": {"$ref": "#/$defs/nullableString"},
        "freshness": {"enum": ["current", "stale", "unknown"]},
        "temporal_scope": {"enum": ["current_as_of", "historical_replay", "evergreen"]},
        "prohibited_inferences": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_id", "cluster", "question", "standalone_rewrite", "evidence_query", "target_asset_ref", "required_fact_ids", "status"],
      "properties": {
        "question_id": {"type": "string", "pattern": "^GEO_Q[0-9]+$"},
        "cluster": {"enum": ["definition", "changed", "mechanism", "comparison", "risk", "valuation", "catalyst", "invalidation", "source_check"]},
        "question": {"type": "string", "minLength": 1},
        "standalone_rewrite": {"type": "string", "minLength": 1},
        "evidence_query": {"type": "string", "minLength": 1},
        "target_asset_ref": {"$ref": "#/$defs/nullableString"},
        "required_fact_ids": {"$ref": "#/$defs/stringSet"},
        "status": {"enum": ["observed", "derived", "hypothesis"]}
      }
    },
    "answerUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit_id", "job", "question_ids", "fact_ids", "source_ids", "context_dependency", "temporal_label", "placement"],
      "properties": {
        "unit_id": {"type": "string", "pattern": "^GEO_AU[0-9]+$"},
        "job": {"enum": ["direct_answer", "definition", "comparison", "countercase", "timeline", "data_table", "source_note"]},
        "question_ids": {"$ref": "#/$defs/stringSet"},
        "fact_ids": {"$ref": "#/$defs/stringSet"},
        "source_ids": {"$ref": "#/$defs/stringSet"},
        "context_dependency": {"enum": ["self_contained", "requires_context"]},
        "temporal_label": {"enum": ["current_as_of", "historical_replay", "evergreen"]},
        "placement": {"type": "string", "minLength": 1}
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["citation_id", "claim", "fact_ids", "source_ids", "support", "visible_source_required"],
      "properties": {
        "citation_id": {"type": "string", "pattern": "^GEO_C[0-9]+$"},
        "claim": {"type": "string", "minLength": 1},
        "fact_ids": {"$ref": "#/$defs/stringSet"},
        "source_ids": {"$ref": "#/$defs/stringSet"},
        "support": {"enum": ["direct", "partial", "unsupported"]},
        "visible_source_required": {"type": "boolean"}
      }
    },
    "crawlerAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "crawler", "policy", "checked_at", "official_source_url", "observed_source_id"],
      "properties": {
        "engine": {"type": "string", "minLength": 1},
        "crawler": {"type": "string", "minLength": 1},
        "policy": {"enum": ["allowed", "blocked", "unknown", "not_applicable"]},
        "checked_at": {"$ref": "#/$defs/nullableString"},
        "official_source_url": {"$ref": "#/$defs/nullableString"},
        "observed_source_id": {"$ref": "#/$defs/nullableString"}
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_id", "engine", "question_id", "version", "text"],
      "properties": {
        "prompt_id": {"type": "string", "pattern": "^GEO_P[0-9]+$"},
        "engine": {"type": "string", "minLength": 1},
        "question_id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1}
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "offset_hours"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "offset_hours": {"type": "number", "minimum": 0}
      }
    },
    "measurementPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_mode", "prompts", "windows", "required_sample_fields", "correction_owner"],
      "properties": {
        "sample_mode": {"enum": ["manual_real", "authorized_api", "browser_assisted_with_permission", "synthetic_replay", "plan_only"]},
        "prompts": {"type": "array", "items": {"$ref": "#/$defs/prompt"}},
        "windows": {"type": "array", "items": {"$ref": "#/$defs/window"}},
        "required_sample_fields": {"$ref": "#/$defs/stringSet"},
        "correction_owner": {"type": "string", "minLength": 1}
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observation_id", "sample_mode", "engine", "sampled_at", "prompt_id", "raw_evidence_ref", "answer_hash", "mentioned_entity_ids", "citation_urls", "evaluated_citation_ids", "review_state"],
      "properties": {
        "observation_id": {"type": "string", "pattern": "^GEO_O[0-9]+$"},
        "sample_mode": {"enum": ["manual_real", "authorized_api", "browser_assisted_with_permission", "synthetic_replay"]},
        "engine": {"type": "string", "minLength": 1},
        "sampled_at": {"type": "string", "format": "date-time"},
        "prompt_id": {"type": "string", "minLength": 1},
        "raw_evidence_ref": {"type": "string", "minLength": 1},
        "answer_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "mentioned_entity_ids": {"$ref": "#/$defs/stringSet"},
        "citation_urls": {"$ref": "#/$defs/stringSet"},
        "evaluated_citation_ids": {"$ref": "#/$defs/stringSet"},
        "review_state": {"enum": ["manual_verified", "unverified"]}
      }
    },
    "sampleMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "numerator", "denominator", "value", "definition"],
      "properties": {
        "metric_id": {"type": "string", "pattern": "^GEO_M[0-9]+$"},
        "numerator": {"type": "integer", "minimum": 0},
        "denominator": {"type": "integer", "minimum": 0},
        "value": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "definition": {"type": "string", "minLength": 1}
      }
    },
    "sampleSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_samples", "valid_samples", "invalid_samples", "metrics"],
      "properties": {
        "total_samples": {"type": "integer", "minimum": 0},
        "valid_samples": {"type": "integer", "minimum": 0},
        "invalid_samples": {"type": "integer", "minimum": 0},
        "metrics": {"type": "array", "items": {"$ref": "#/$defs/sampleMetric"}}
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue_id", "severity", "location", "evidence_source_ids", "action", "owner", "acceptance_test", "handoff"],
      "properties": {
        "issue_id": {"type": "string", "pattern": "^GEO_I[0-9]+$"},
        "severity": {"enum": ["block", "high", "medium", "low"]},
        "location": {"type": "string", "minLength": 1},
        "evidence_source_ids": {"$ref": "#/$defs/stringSet"},
        "action": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1},
        "acceptance_test": {"type": "string", "minLength": 1},
        "handoff": {"enum": ["research", "renderer", "seo", "release", "sample_collection", "none"]}
      }
    },
    "qualityReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upstream_research_state", "sample_integrity", "hard_failures", "warnings", "unknowns"],
      "properties": {
        "upstream_research_state": {"enum": ["ready", "conditional", "blocked"]},
        "sample_integrity": {"enum": ["no_samples", "verified", "partial", "synthetic_only", "invalid"]},
        "hard_failures": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "warnings": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "unknowns": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
