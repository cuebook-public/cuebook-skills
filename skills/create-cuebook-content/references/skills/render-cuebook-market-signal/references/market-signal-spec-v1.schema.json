{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/market-signal-spec-v1.schema.json",
  "title": "MarketSignalSpecV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "signal_id", "revision", "state", "mode", "lineage", "frame", "trade_logic", "key_number", "key_news", "render", "quality_report"],
  "properties": {
    "schema_version": {"const": "market-signal-spec-v1"},
    "signal_id": {"type": "string", "pattern": "^SIGSPEC_[A-Za-z0-9_:-]{8,}$"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"enum": ["conditional", "ready", "frozen"]},
    "mode": {"enum": ["key_number", "key_news"]},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_artifact_refs", "source_refs", "decision_cutoff_at"],
      "properties": {
        "input_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "decision_cutoff_at": {"$ref": "#/$defs/dateTime"}
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "asset_label", "headline", "interpretation"],
      "properties": {
        "category": {"$ref": "#/$defs/nonemptyString"},
        "asset_label": {"$ref": "#/$defs/nonemptyString"},
        "headline": {"type": "string", "minLength": 1, "maxLength": 120},
        "interpretation": {"type": "string", "minLength": 1, "maxLength": 180}
      }
    },
    "trade_logic": {"$ref": "#/$defs/tradeLogicSummary"},
    "key_number": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "display_value", "numeric_value", "unit", "as_of", "status", "comparison", "source_ref"],
          "properties": {
            "label": {"$ref": "#/$defs/nonemptyString"},
            "display_value": {"type": "string", "minLength": 1, "maxLength": 24},
            "numeric_value": {"anyOf": [{"type": "null"}, {"type": "number"}]},
            "unit": {"$ref": "#/$defs/nonemptyString"},
            "as_of": {"$ref": "#/$defs/dateTime"},
            "status": {"enum": ["observed", "derived", "provisional"]},
            "comparison": {"$ref": "#/$defs/nullableString"},
            "source_ref": {"$ref": "#/$defs/nonemptyString"}
          }
        }
      ]
    },
    "key_news": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["headline", "publisher", "published_at", "status", "source_refs"],
          "properties": {
            "headline": {"type": "string", "minLength": 1, "maxLength": 220},
            "publisher": {"$ref": "#/$defs/nonemptyString"},
            "published_at": {"$ref": "#/$defs/dateTime"},
            "status": {"enum": ["observed", "provisional", "unconfirmed"]},
            "source_refs": {"$ref": "#/$defs/stringSet"}
          }
        }
      ]
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "width", "height", "theme", "design_profile", "watermark"],
      "properties": {
        "layout": {"const": "compact"},
        "width": {"const": 720},
        "height": {"const": 420},
        "theme": {"enum": ["cuebook_light", "cuebook_dark"]},
        "design_profile": {"const": "receptive_restraint"},
        "watermark": {"const": "Cuebook"}
      }
    },
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "dateTime": {"type": "string", "format": "date-time"},
    "stringSet": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "tradeLogicSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_ref", "family", "mechanism", "expression", "horizon", "public_tags"],
      "properties": {
        "profile_ref": {"type": "string", "pattern": "^TLOGIC_[A-Za-z0-9_:-]{8,}$"},
        "family": {"enum": ["event_driven", "relative_value", "directional", "global_macro", "factor_style", "volatility", "liquidity_microstructure", "carry_income"]},
        "mechanism": {"enum": ["risk_premium_transmission", "expectation_revision", "supply_demand_repricing", "forced_flow", "positioning_squeeze", "liquidity_amplification", "price_discovery_lead_lag", "valuation_mean_reversion", "fundamental_compounding", "momentum_continuation", "volatility_repricing", "carry_roll_down", "cross_asset_transmission"]},
        "expression": {"enum": ["outright_long", "outright_short", "relative_value_pair", "long_short_basket", "etf_basket", "curve_spread", "options_convexity", "volatility_trade", "hedge_overlay", "no_trade"]},
        "horizon": {"enum": ["intraday", "one_to_three_days", "one_to_four_weeks", "one_to_three_months", "structural"]},
        "public_tags": {"type": "array", "minItems": 2, "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 24}}
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "hard_failures"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "warnings": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
        "hard_failures": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}}
      }
    }
  }
}
