{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/market-signal-v1.schema.json",
  "title": "MarketSignalV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "market_signal_id", "spec_ref", "mode", "state", "generated_at", "dimensions", "theme", "lineage", "content", "asset", "quality_report"],
  "properties": {
    "schema_version": {"const": "market-signal-v1"},
    "market_signal_id": {"type": "string", "pattern": "^SIGNAL_[A-Za-z0-9_:-]{8,}$"},
    "spec_ref": {"type": "string", "pattern": "^SIGSPEC_[A-Za-z0-9_:-]{8,}$"},
    "mode": {"enum": ["key_number", "key_news"]},
    "state": {"enum": ["conditional", "ready", "frozen"]},
    "generated_at": {"type": "string", "format": "date-time"},
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {"width": {"const": 720}, "height": {"const": 420}}
    },
    "theme": {"enum": ["cuebook_light", "cuebook_dark"]},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_artifact_refs", "source_refs", "decision_cutoff_at", "trade_logic_ref"],
      "properties": {
        "input_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "decision_cutoff_at": {"type": "string", "format": "date-time"},
        "trade_logic_ref": {"type": "string", "pattern": "^TLOGIC_[A-Za-z0-9_:-]{8,}$"}
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "asset_label", "headline", "interpretation", "strategy_tags", "signal_time", "signal_label", "signal_value", "signal_status", "watermark"],
      "properties": {
        "category": {"$ref": "#/$defs/nonemptyString"},
        "asset_label": {"$ref": "#/$defs/nonemptyString"},
        "headline": {"$ref": "#/$defs/nonemptyString"},
        "interpretation": {"$ref": "#/$defs/nonemptyString"},
        "strategy_tags": {"type": "array", "minItems": 2, "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 24}},
        "signal_time": {"type": "string", "format": "date-time"},
        "signal_label": {"$ref": "#/$defs/nonemptyString"},
        "signal_value": {"$ref": "#/$defs/nullableString"},
        "signal_status": {"enum": ["observed", "derived", "provisional", "unconfirmed"]},
        "watermark": {"const": "Cuebook"}
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["svg_ref", "content_hash"],
      "properties": {
        "svg_ref": {"$ref": "#/$defs/nonemptyString"},
        "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "stringSet": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "hard_failures"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "warnings": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
        "hard_failures": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}}
      }
    }
  }
}
