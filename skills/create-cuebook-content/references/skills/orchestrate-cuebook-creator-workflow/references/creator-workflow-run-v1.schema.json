{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/creator-workflow-run-v1.schema.json",
  "title": "CreatorWorkflowRunV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workflow_id", "feed_ref", "opportunity_set_ref", "recipe_ref", "catalog_version", "query_bundle_refs", "selected_opportunity_refs", "mode", "created_at", "as_of", "ruleset_version", "state", "nodes", "artifact_registry", "approvals", "state_events", "blockers", "quality_report"],
  "properties": {
    "schema_version": {"const": "creator-workflow-run-v1"},
    "workflow_id": {"type": "string", "pattern": "^WF_[a-z0-9]{8,64}$"},
    "feed_ref": {"type": "string", "pattern": "^CF_[a-z0-9]{8,64}$"},
    "opportunity_set_ref": {"type": "string", "pattern": "^OS_[a-z0-9]{8,64}$"},
    "recipe_ref": {"type": "string", "pattern": "^RECIPE_[a-z0-9]{8,64}$"},
    "catalog_version": {"const": "1.27.0", "description": "Pinned Cuebook creator skill catalog for this workflow contract revision."},
    "query_bundle_refs": {"type": "array", "items": {"type": "string", "pattern": "^ART_"}, "uniqueItems": true},
    "selected_opportunity_refs": {"type": "array", "items": {"type": "string", "pattern": "^OPP_"}, "uniqueItems": true},
    "mode": {"enum": ["plan_only", "single", "batch", "event_lifecycle", "postmortem", "correction"]},
    "created_at": {"type": "string", "format": "date-time"},
    "as_of": {"type": "string", "format": "date-time"},
    "ruleset_version": {"type": "string", "minLength": 1},
    "state": {"enum": ["planned", "in_progress", "blocked", "ready_for_handoff", "complete"]},
    "nodes": {"type": "array", "items": {"$ref": "#/$defs/node"}},
    "artifact_registry": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
    "approvals": {"type": "array", "items": {"$ref": "#/$defs/approval"}},
    "state_events": {"type": "array", "items": {"$ref": "#/$defs/event"}},
    "blockers": {"type": "array", "items": {"$ref": "#/$defs/blocker"}},
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "node": {
      "type": "object", "additionalProperties": false,
      "required": ["node_id", "capability", "skill_name", "skill_version", "availability", "opportunity_refs", "depends_on", "input_artifact_refs", "output_contract", "state", "artifact_refs", "blocking", "human_gate", "owner", "reason"],
      "properties": {
        "node_id": {"type": "string", "pattern": "^NODE_[a-z0-9_:-]+$"},
        "capability": {"anyOf": [{"enum": ["normalize_feed", "compose_recipe", "select_opportunities", "validate_projection", "route_narrative", "query_cuebook", "build_research_pack", "plan_content_program", "render_market_post", "render_market_media", "compile_settlement_claim", "optimize_market_seo", "optimize_market_geo", "prepare_release", "publish_external", "reconcile_history"]}, {"type": "string", "pattern": "^(catalog|extension):[a-z0-9-]+$"}]},
        "skill_name": {"type": ["string", "null"]},
        "skill_version": {"type": ["string", "null"], "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "availability": {"enum": ["installed", "external", "deferred"]},
        "opportunity_refs": {"$ref": "#/$defs/refs"},
        "depends_on": {"$ref": "#/$defs/refs"},
        "input_artifact_refs": {"$ref": "#/$defs/refs"},
        "output_contract": {"type": "string", "minLength": 1},
        "state": {"enum": ["pending", "ready", "running", "completed", "blocked", "skipped", "deferred"]},
        "artifact_refs": {"$ref": "#/$defs/refs"},
        "blocking": {"type": "boolean"},
        "human_gate": {"enum": ["none", "research", "editorial", "compliance", "release"]},
        "owner": {"enum": ["ai", "human", "system", "external"]},
        "reason": {"type": ["string", "null"]}
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "schema_version", "content_hash", "locator", "created_at", "producer_node_ref", "input_artifact_refs", "status"],
      "allOf": [
        {
          "if": {
            "required": ["artifact_type"],
            "properties": {
              "artifact_type": {
                "enum": ["CuebookQueryBundleV1", "ResearchPackV1", "CreatorExpressionPlanV1", "ViewpointDataBundleV1", "PublishCandidateSetV1"]
              }
            }
          },
          "then": {"required": ["gate_summary"]}
        },
        {
          "if": {"required": ["artifact_type"], "properties": {"artifact_type": {"const": "CuebookQueryBundleV1"}}},
          "then": {"properties": {"gate_summary": {"$ref": "#/$defs/dataGateSummary"}}}
        },
        {
          "if": {"required": ["artifact_type"], "properties": {"artifact_type": {"const": "ResearchPackV1"}}},
          "then": {"properties": {"gate_summary": {"$ref": "#/$defs/researchGateSummary"}}}
        },
        {
          "if": {"required": ["artifact_type"], "properties": {"artifact_type": {"const": "CreatorExpressionPlanV1"}}},
          "then": {"properties": {"gate_summary": {"$ref": "#/$defs/expressionGateSummary"}}}
        },
        {
          "if": {"required": ["artifact_type"], "properties": {"artifact_type": {"const": "ViewpointDataBundleV1"}}},
          "then": {"properties": {"gate_summary": {"$ref": "#/$defs/dataGateSummary"}}}
        },
        {
          "if": {"required": ["artifact_type"], "properties": {"artifact_type": {"const": "PublishCandidateSetV1"}}},
          "then": {"properties": {"gate_summary": {"$ref": "#/$defs/candidateGateSummary"}}}
        }
      ],
      "properties": {
        "artifact_id": {"type": "string", "pattern": "^ART_[a-z0-9_:-]+$"},
        "artifact_type": {"type": "string", "minLength": 1},
        "schema_version": {"type": "string", "minLength": 1},
        "content_hash": {"$ref": "#/$defs/hash"},
        "locator": {"type": ["string", "null"], "description": "Opaque artifact address. Validators must not dereference it."},
        "created_at": {"type": "string", "format": "date-time"},
        "producer_node_ref": {"type": "string"},
        "input_artifact_refs": {"$ref": "#/$defs/refs"},
        "status": {"enum": ["current", "superseded", "invalidated"]},
        "gate_summary": {"$ref": "#/$defs/gateSummary"}
      }
    },
    "gateSummary": {
      "type": "object", "additionalProperties": false,
      "required": ["quality_decision", "artifact_state", "unresolved_material_request_count"],
      "properties": {
        "quality_decision": {"enum": ["ready", "conditional", "blocked", "ready_for_selection", "selected"]},
        "artifact_state": {"enum": ["draft", "ready", "conditional", "frozen", "ready_for_selection", "selected", "blocked"]},
        "unresolved_material_request_count": {"type": "integer", "minimum": 0}
      }
    },
    "researchGateSummary": {
      "allOf": [
        {"$ref": "#/$defs/gateSummary"},
        {
          "oneOf": [
            {"properties": {"quality_decision": {"const": "ready"}, "artifact_state": {"const": "ready"}}},
            {"properties": {"quality_decision": {"const": "conditional"}, "artifact_state": {"const": "conditional"}}},
            {"properties": {"quality_decision": {"const": "blocked"}, "artifact_state": {"const": "blocked"}}}
          ]
        }
      ]
    },
    "expressionGateSummary": {
      "allOf": [
        {"$ref": "#/$defs/gateSummary"},
        {
          "oneOf": [
            {"properties": {"artifact_state": {"const": "draft"}, "quality_decision": {"enum": ["ready", "conditional", "blocked"]}}},
            {"properties": {"artifact_state": {"const": "conditional"}, "quality_decision": {"const": "conditional"}}},
            {"properties": {"artifact_state": {"enum": ["ready", "frozen"]}, "quality_decision": {"const": "ready"}}}
          ]
        }
      ]
    },
    "dataGateSummary": {"$ref": "#/$defs/researchGateSummary"},
    "candidateGateSummary": {
      "allOf": [
        {"$ref": "#/$defs/gateSummary"},
        {
          "oneOf": [
            {"properties": {"artifact_state": {"const": "draft"}, "quality_decision": {"enum": ["ready_for_selection", "selected", "blocked"]}}},
            {"properties": {"artifact_state": {"const": "ready_for_selection"}, "quality_decision": {"const": "ready_for_selection"}}},
            {"properties": {"artifact_state": {"const": "selected"}, "quality_decision": {"const": "selected"}}},
            {"properties": {"artifact_state": {"const": "blocked"}, "quality_decision": {"const": "blocked"}}}
          ]
        }
      ]
    },
    "approvalVersion": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_ref", "content_hash"],
      "properties": {"artifact_ref": {"type": "string"}, "content_hash": {"$ref": "#/$defs/hash"}}
    },
    "approval": {
      "type": "object", "additionalProperties": false,
      "required": ["approval_id", "gate", "artifact_versions", "decision", "reviewer_ref", "decided_at", "policy_version", "reason"],
      "properties": {
        "approval_id": {"type": "string", "pattern": "^APR_[a-z0-9_:-]+$"},
        "gate": {"enum": ["research", "editorial", "compliance", "release"]},
        "artifact_versions": {"type": "array", "items": {"$ref": "#/$defs/approvalVersion"}, "minItems": 1},
        "decision": {"enum": ["pending", "approved", "changes_requested", "rejected", "revoked"]},
        "reviewer_ref": {"type": "string", "minLength": 1},
        "decided_at": {"type": ["string", "null"], "format": "date-time"},
        "policy_version": {"type": "string", "minLength": 1},
        "reason": {"type": ["string", "null"]}
      }
    },
    "event": {
      "type": "object", "additionalProperties": false,
      "required": ["event_id", "node_ref", "from_state", "to_state", "actor", "occurred_at", "reason"],
      "properties": {
        "event_id": {"type": "string", "pattern": "^EVT_[a-z0-9_:-]+$"},
        "node_ref": {"type": "string"},
        "from_state": {"enum": [null, "pending", "ready", "running", "completed", "blocked", "skipped", "deferred"]},
        "to_state": {"enum": ["pending", "ready", "running", "completed", "blocked", "skipped", "deferred"]},
        "actor": {"type": "string", "minLength": 1},
        "occurred_at": {"type": "string", "format": "date-time"},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "blocker": {
      "type": "object", "additionalProperties": false,
      "required": ["blocker_id", "node_ref", "code", "detail", "resolution", "blocking"],
      "properties": {
        "blocker_id": {"type": "string", "pattern": "^BLK_[a-z0-9_:-]+$"},
        "node_ref": {"type": "string"}, "code": {"type": "string", "minLength": 1},
        "detail": {"type": "string", "minLength": 1}, "resolution": {"type": "string", "minLength": 1},
        "blocking": {"type": "boolean"}
      }
    },
    "quality": {
      "type": "object", "additionalProperties": false,
      "required": ["decision", "hard_failures", "warnings", "checks", "counts"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "hard_failures": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}},
        "checks": {"type": "array", "items": {"type": "string"}},
        "counts": {
          "type": "object", "additionalProperties": false,
          "required": ["nodes", "completed", "blocked", "deferred", "artifacts", "approvals_pending"],
          "properties": {
            "nodes": {"type": "integer", "minimum": 0}, "completed": {"type": "integer", "minimum": 0},
            "blocked": {"type": "integer", "minimum": 0}, "deferred": {"type": "integer", "minimum": 0},
            "artifacts": {"type": "integer", "minimum": 0}, "approvals_pending": {"type": "integer", "minimum": 0}
          }
        }
      }
    }
  }
}
