{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/market-series-batch-v1.schema.json",
  "title": "MarketSeriesBatchV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "fetched_at", "series"],
  "properties": {
    "schema_version": {"const": "market-series-batch-v1"},
    "fetched_at": {"type": "string", "format": "date-time"},
    "series": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/series"}
    }
  },
  "$defs": {
    "nullableNumber": {"type": ["number", "null"]},
    "nullableString": {"type": ["string", "null"]},
    "series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["series_ref", "instrument_id", "ticker", "interval", "coverage_status", "source_ref", "session", "quote_basis", "bars"],
      "properties": {
        "series_ref": {"type": "string", "pattern": "^S[1-9][0-9]*$"},
        "instrument_id": {"type": "string", "minLength": 1},
        "ticker": {"type": "string", "minLength": 1},
        "interval": {"type": "string", "minLength": 1},
        "coverage_status": {"enum": ["complete", "partial", "unavailable", "unknown"]},
        "source_ref": {"type": "string", "minLength": 1},
        "provider_id": {"type": "string", "minLength": 1},
        "venue": {"type": "string", "minLength": 1},
        "currency": {"type": "string", "minLength": 1},
        "timezone": {"type": "string", "minLength": 1},
        "calendar_ref": {"type": "string", "minLength": 1},
        "session": {"type": "string", "minLength": 1},
        "quote_basis": {"type": "string", "minLength": 1},
        "adjustment_basis": {"enum": ["raw", "split_adjusted", "dividend_adjusted", "total_return", "unknown"]},
        "source_as_of": {"type": "string", "format": "date-time"},
        "license_scope": {"enum": ["internal", "display", "redistribution", "unknown"]},
        "quality_flags": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "bars": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/bar"}
        }
      }
    },
    "bar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["open_time", "observed_at", "open", "high", "low", "close", "volume", "vwap", "state", "last_event_time"],
      "properties": {
        "open_time": {"type": "string", "format": "date-time"},
        "observed_at": {"type": "string", "format": "date-time"},
        "open": {"type": "number"},
        "high": {"type": "number"},
        "low": {"type": "number"},
        "close": {"type": "number"},
        "volume": {"$ref": "#/$defs/nullableNumber"},
        "vwap": {"$ref": "#/$defs/nullableNumber"},
        "state": {"enum": ["sealed", "forming"]},
        "last_event_time": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "format": "date-time"}
          ]
        }
      }
    }
  }
}
