{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/profile-v1.schema.json",
  "title": "ProfileV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "generated_at",
    "target",
    "corpus_summary",
    "quality_gate",
    "source_map",
    "attention_map",
    "reasoning_map",
    "writing_map",
    "risk_map",
    "cuebook_bridge"
  ],
  "properties": {
    "schema_version": {"const": "profile.v1"},
    "profile_id": {"type": "string", "pattern": "^profile_[a-f0-9]{16}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "target": {"$ref": "#/$defs/target"},
    "corpus_summary": {"$ref": "#/$defs/corpusSummary"},
    "quality_gate": {"$ref": "#/$defs/qualityGate"},
    "source_map": {"$ref": "#/$defs/sourceMap"},
    "attention_map": {
      "type": "array",
      "items": {"$ref": "#/$defs/attentionEntry"}
    },
    "reasoning_map": {
      "type": "array",
      "items": {"$ref": "#/$defs/reasoningEntry"}
    },
    "writing_map": {"$ref": "#/$defs/writingMap"},
    "risk_map": {"$ref": "#/$defs/riskMap"},
    "cuebook_bridge": {"$ref": "#/$defs/cuebookBridge"}
  },
  "$defs": {
    "nullableString": {"type": ["string", "null"]},
    "nullableDateTime": {
      "anyOf": [
        {"type": "string", "format": "date-time"},
        {"type": "null"}
      ]
    },
    "stringSet": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "confidence": {"enum": ["low", "medium", "high"]},
    "sourceType": {"enum": ["official", "media_wire", "market_data", "social", "other"]},
    "eventType": {
      "enum": [
        "hard-data-print",
        "tape-break",
        "prediction-market-shift",
        "crowded-unwind",
        "macro-risk-premium",
        "estimate-revision",
        "mechanical-flow",
        "supply-bottleneck",
        "credit-cashflow-stress",
        "sentiment-pain",
        "valuation-rerating"
      ]
    },
    "routeEventType": {
      "enum": [
        "technical-level",
        "prediction-market",
        "mechanical-flow",
        "credit-financing",
        "company-guidance",
        "earnings-result",
        "inventory-print",
        "macro-policy",
        "analyst-action",
        "government-contract",
        "deal-event",
        "legal-regulatory",
        "geopolitical-risk",
        "capital-investment",
        "operating-data",
        "crowded-positioning",
        "social-sentiment",
        "product-strategy",
        "price-action"
      ]
    },
    "ruleId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9-]+)+$"
    },
    "reasoningType": {
      "enum": [
        "source-first",
        "actor-forced",
        "model-line",
        "tape-first",
        "crowding-first",
        "analogy-first",
        "pain-first",
        "skepticism-first",
        "falsifier-first"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "handles", "platforms"],
      "properties": {
        "name": {"$ref": "#/$defs/nullableString"},
        "handles": {"$ref": "#/$defs/stringSet"},
        "platforms": {"$ref": "#/$defs/stringSet"}
      }
    },
    "countShare": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "count", "share"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "count": {"type": "integer", "minimum": 0},
        "share": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "tickerCount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticker", "count"],
      "properties": {
        "ticker": {"type": "string", "minLength": 1},
        "count": {"type": "integer", "minimum": 1}
      }
    },
    "corpusSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "corpus_id",
        "items_total",
        "items_analyzed",
        "date_range",
        "language_distribution",
        "platform_distribution",
        "top_tickers",
        "linked_items"
      ],
      "properties": {
        "corpus_id": {"type": "string", "minLength": 1},
        "items_total": {"type": "integer", "minimum": 1},
        "items_analyzed": {"type": "integer", "minimum": 1},
        "date_range": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": {"$ref": "#/$defs/nullableDateTime"},
            "end": {"$ref": "#/$defs/nullableDateTime"}
          }
        },
        "language_distribution": {
          "type": "array",
          "items": {"$ref": "#/$defs/countShare"}
        },
        "platform_distribution": {
          "type": "array",
          "items": {"$ref": "#/$defs/countShare"}
        },
        "top_tickers": {
          "type": "array",
          "items": {"$ref": "#/$defs/tickerCount"}
        },
        "linked_items": {"type": "integer", "minimum": 0}
      }
    },
    "metricFieldAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_items", "coverage"],
      "properties": {
        "observed_items": {"type": "integer", "minimum": 0},
        "coverage": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "metricsAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "items_total",
        "items_with_any",
        "item_coverage",
        "fields",
        "engagement_ranking_available"
      ],
      "properties": {
        "items_total": {"type": "integer", "minimum": 1},
        "items_with_any": {"type": "integer", "minimum": 0},
        "item_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "fields": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/metricFieldAvailability"}
        },
        "engagement_ranking_available": {"type": "boolean"}
      }
    },
    "qualityCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "value", "threshold", "detail"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "status": {"enum": ["pass", "caution", "reject"]},
        "value": {"type": "number", "minimum": 0},
        "threshold": {"type": "string", "minLength": 1},
        "detail": {"type": "string", "minLength": 1}
      }
    },
    "qualityGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "score", "reasons", "checks", "metrics_availability"],
      "properties": {
        "status": {"enum": ["pass", "caution", "reject"]},
        "score": {"type": "integer", "minimum": 0, "maximum": 100},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/qualityCheck"}
        },
        "metrics_availability": {"$ref": "#/$defs/metricsAvailability"}
      }
    },
    "sourceCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "link_count",
        "item_count",
        "share",
        "domains",
        "evidence_item_ids"
      ],
      "properties": {
        "source_type": {"$ref": "#/$defs/sourceType"},
        "link_count": {"type": "integer", "minimum": 1},
        "item_count": {"type": "integer", "minimum": 1},
        "share": {"type": "number", "minimum": 0, "maximum": 1},
        "domains": {"$ref": "#/$defs/stringSet"},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "sourceDomain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "source_type", "link_count", "item_count"],
      "properties": {
        "domain": {"type": "string", "minLength": 1},
        "source_type": {"$ref": "#/$defs/sourceType"},
        "link_count": {"type": "integer", "minimum": 1},
        "item_count": {"type": "integer", "minimum": 1}
      }
    },
    "sourceMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["linked_items", "unlinked_items", "link_coverage", "categories", "domains"],
      "properties": {
        "linked_items": {"type": "integer", "minimum": 0},
        "unlinked_items": {"type": "integer", "minimum": 0},
        "link_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "categories": {
          "type": "array",
          "items": {"$ref": "#/$defs/sourceCategory"}
        },
        "domains": {
          "type": "array",
          "items": {"$ref": "#/$defs/sourceDomain"}
        }
      }
    },
    "attentionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_type", "count", "share", "confidence", "evidence_item_ids"],
      "properties": {
        "event_type": {"$ref": "#/$defs/eventType"},
        "count": {"type": "integer", "minimum": 1},
        "share": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence": {"$ref": "#/$defs/confidence"},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "reasoningEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "count", "share", "confidence", "evidence_item_ids"],
      "properties": {
        "pattern": {"$ref": "#/$defs/reasoningType"},
        "count": {"type": "integer", "minimum": 1},
        "share": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence": {"$ref": "#/$defs/confidence"},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "hookEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "count", "share", "confidence", "evidence_item_ids"],
      "properties": {
        "pattern": {
          "enum": ["number-first", "judgment-first", "question-first", "anecdote-first", "thread", "statement"]
        },
        "count": {"type": "integer", "minimum": 1},
        "share": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence": {"$ref": "#/$defs/confidence"},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "formatEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "count", "share"],
      "properties": {
        "pattern": {"enum": ["short", "multiline", "contains-number", "contains-question", "long-form"]},
        "count": {"type": "integer", "minimum": 1},
        "share": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "writingMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hooks", "cadence", "format_patterns", "language_distribution", "abstraction_rule"],
      "properties": {
        "hooks": {"type": "array", "items": {"$ref": "#/$defs/hookEntry"}},
        "cadence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["median_characters", "median_lines"],
          "properties": {
            "median_characters": {"type": "number", "minimum": 0},
            "median_lines": {"type": "number", "minimum": 0}
          }
        },
        "format_patterns": {"type": "array", "items": {"$ref": "#/$defs/formatEntry"}},
        "language_distribution": {"type": "array", "items": {"$ref": "#/$defs/countShare"}},
        "abstraction_rule": {"type": "string", "minLength": 1}
      }
    },
    "riskFlag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_type", "severity", "detail", "evidence_item_ids"],
      "properties": {
        "risk_type": {"type": "string", "minLength": 1},
        "severity": {"enum": ["low", "medium", "high"]},
        "detail": {"type": "string", "minLength": 1},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "riskMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flags", "prohibited_actions"],
      "properties": {
        "flags": {"type": "array", "items": {"$ref": "#/$defs/riskFlag"}},
        "prohibited_actions": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "attentionAffinity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "attention_type", "route_event_types", "weight", "evidence_item_ids"],
      "properties": {
        "rule_id": {"$ref": "#/$defs/ruleId"},
        "attention_type": {"$ref": "#/$defs/eventType"},
        "route_event_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/routeEventType"}
        },
        "weight": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "sourcePreference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "source_type", "weight", "evidence_item_ids"],
      "properties": {
        "rule_id": {"$ref": "#/$defs/ruleId"},
        "source_type": {"$ref": "#/$defs/sourceType"},
        "weight": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "reasoningRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "pattern", "weight", "evidence_item_ids"],
      "properties": {
        "rule_id": {"$ref": "#/$defs/ruleId"},
        "pattern": {"$ref": "#/$defs/reasoningType"},
        "weight": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "openingRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "pattern", "weight", "evidence_item_ids"],
      "properties": {
        "rule_id": {"$ref": "#/$defs/ruleId"},
        "pattern": {"enum": ["number-first", "judgment-first", "question-first", "anecdote-first", "thread", "statement"]},
        "weight": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "dataHook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "attention_type", "route_event_types", "required_inputs", "evidence_item_ids"],
      "properties": {
        "rule_id": {"$ref": "#/$defs/ruleId"},
        "attention_type": {"$ref": "#/$defs/eventType"},
        "route_event_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/routeEventType"}
        },
        "required_inputs": {"$ref": "#/$defs/stringSet"},
        "evidence_item_ids": {"$ref": "#/$defs/stringSet"}
      }
    },
    "renderConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "instruction"],
      "properties": {
        "rule_id": {"$ref": "#/$defs/ruleId"},
        "instruction": {"type": "string", "minLength": 1}
      }
    },
    "cuebookBridge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taxonomy_version",
        "attention_affinities",
        "source_preferences",
        "reasoning_rules",
        "opening_rules",
        "data_hooks",
        "render_constraints",
        "prohibited_moves"
      ],
      "properties": {
        "taxonomy_version": {"const": "profile-bridge-v1"},
        "attention_affinities": {"type": "array", "items": {"$ref": "#/$defs/attentionAffinity"}},
        "source_preferences": {"type": "array", "items": {"$ref": "#/$defs/sourcePreference"}},
        "reasoning_rules": {"type": "array", "items": {"$ref": "#/$defs/reasoningRule"}},
        "opening_rules": {"type": "array", "items": {"$ref": "#/$defs/openingRule"}},
        "data_hooks": {"type": "array", "items": {"$ref": "#/$defs/dataHook"}},
        "render_constraints": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/renderConstraint"}},
        "prohibited_moves": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    }
  }
}
