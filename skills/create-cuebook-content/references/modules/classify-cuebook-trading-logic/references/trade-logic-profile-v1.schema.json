{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/trade-logic-profile-v1.schema.json",
  "title": "TradeLogicProfileV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "revision", "state", "lineage", "classification", "stance", "public_expression", "evidence_boundary", "quality_report"],
  "properties": {
    "schema_version": {"const": "trade-logic-profile-v1"},
    "profile_id": {"type": "string", "pattern": "^TLOGIC_[A-Za-z0-9_:-]{8,}$"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"enum": ["draft", "conditional", "ready", "frozen"]},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_artifact_refs", "source_refs", "decision_cutoff_at"],
      "properties": {
        "input_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "decision_cutoff_at": {"$ref": "#/$defs/dateTime"}
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "catalyst", "mechanism", "expression", "horizon", "edge", "rationale_refs"],
      "properties": {
        "family": {"enum": ["event_driven", "relative_value", "directional", "global_macro", "factor_style", "volatility", "liquidity_microstructure", "carry_income"]},
        "catalyst": {"enum": ["corporate_action", "earnings", "product", "policy", "macro_data", "geopolitical", "supply_demand", "technical_break", "flow_positioning", "valuation_dislocation", "none"]},
        "mechanism": {"enum": ["risk_premium_transmission", "expectation_revision", "supply_demand_repricing", "forced_flow", "positioning_squeeze", "liquidity_amplification", "price_discovery_lead_lag", "valuation_mean_reversion", "fundamental_compounding", "momentum_continuation", "volatility_repricing", "carry_roll_down", "cross_asset_transmission"]},
        "expression": {"enum": ["outright_long", "outright_short", "relative_value_pair", "long_short_basket", "etf_basket", "curve_spread", "options_convexity", "volatility_trade", "hedge_overlay", "no_trade"]},
        "horizon": {"enum": ["intraday", "one_to_three_days", "one_to_four_weeks", "one_to_three_months", "structural"]},
        "edge": {"enum": ["information", "causal", "structural", "behavioral", "mechanical", "valuation", "timing"]},
        "rationale_refs": {"$ref": "#/$defs/stringSet"}
      }
    },
    "stance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_asset", "direction", "comparator", "horizon_label"],
      "properties": {
        "primary_asset": {"$ref": "#/$defs/nonemptyString"},
        "direction": {"enum": ["long", "short", "outperform", "underperform", "long_vol", "short_vol", "steepener", "flattener", "neutral"]},
        "comparator": {"$ref": "#/$defs/nullableString"},
        "horizon_label": {"type": "string", "minLength": 1, "maxLength": 24}
      }
    },
    "public_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_line", "because_line", "tags"],
      "properties": {
        "action_line": {"type": "string", "minLength": 1, "maxLength": 100},
        "because_line": {"type": "string", "minLength": 1, "maxLength": 160},
        "tags": {"type": "array", "minItems": 2, "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 24}}
      }
    },
    "evidence_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_claim_refs", "inferred_claim_refs", "missing_requirement_refs", "public_status_suppressed"],
      "properties": {
        "observed_claim_refs": {"$ref": "#/$defs/stringList"},
        "inferred_claim_refs": {"$ref": "#/$defs/stringList"},
        "missing_requirement_refs": {"$ref": "#/$defs/stringList"},
        "public_status_suppressed": {"const": true}
      }
    },
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "dateTime": {"type": "string", "format": "date-time"},
    "stringSet": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "stringList": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "hard_failures"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "warnings": {"$ref": "#/$defs/stringList"},
        "hard_failures": {"$ref": "#/$defs/stringList"}
      }
    }
  }
}
