{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/settlement-formula-v1.schema.json",
  "title": "SettlementFormulaV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "formula_id", "revision", "state", "lineage", "subject", "execution_profile", "variables", "activation", "outcome", "invalidation", "lifecycle", "resolution", "public_math", "quality_report"],
  "properties": {
    "schema_version": {"const": "settlement-formula-v1"},
    "formula_id": {"type": "string", "pattern": "^FORMULA_[A-Za-z0-9_-]{8,}$"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"enum": ["draft", "ready", "frozen"]},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_ref", "claim_hash", "canonical_hash"],
      "properties": {
        "claim_ref": {"$ref": "#/$defs/nonemptyString"},
        "claim_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "canonical_hash": {"anyOf": [{"type": "null"}, {"type": "string", "pattern": "^[a-f0-9]{64}$"}]}
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrument_id", "ticker", "direction"],
      "properties": {
        "instrument_id": {"$ref": "#/$defs/nonemptyString"},
        "ticker": {"$ref": "#/$defs/nonemptyString"},
        "direction": {"enum": ["long", "short", "outperform", "underperform", "range", "event_yes", "event_no", "neutral"]}
      }
    },
    "execution_profile": {"$ref": "#/$defs/executionProfile"},
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/variable"}
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "window_start", "window_end", "end_event_ref", "expression", "captures"],
      "properties": {
        "mode": {"enum": ["immediate", "first_true"]},
        "window_start": {"$ref": "#/$defs/nullableDateTime"},
        "window_end": {"$ref": "#/$defs/nullableDateTime"},
        "end_event_ref": {"$ref": "#/$defs/nullableString"},
        "expression": {"$ref": "#/$defs/nullableExpression"},
        "captures": {"type": "array", "items": {"$ref": "#/$defs/capture"}}
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observation_mode", "observed_at", "window_start", "window_end", "event_ref", "expression"],
      "properties": {
        "observation_mode": {"enum": ["at_datetime", "any_in_window", "every_observation", "first_sealed_bar_after_event"]},
        "observed_at": {"$ref": "#/$defs/nullableDateTime"},
        "window_start": {"$ref": "#/$defs/nullableDateTime"},
        "window_end": {"$ref": "#/$defs/nullableDateTime"},
        "event_ref": {"$ref": "#/$defs/nullableString"},
        "expression": {"$ref": "#/$defs/expression"}
      }
    },
    "invalidation": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "expression", "result"],
          "properties": {
            "mode": {"enum": ["first_true", "at_datetime"]},
            "expression": {"$ref": "#/$defs/expression"},
            "result": {"enum": ["failed", "no_score"]}
          }
        }
      ]
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial_state", "activation_state", "terminal_states", "untriggered_result", "tie_result", "invalidated_result"],
      "properties": {
        "initial_state": {"enum": ["pending_activation", "active"]},
        "activation_state": {"const": "active"},
        "terminal_states": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"enum": ["succeeded", "failed", "expired_untriggered", "invalidated", "manual_review", "annulled"]}},
        "untriggered_result": {"enum": ["no_score", "failed", "annulled"]},
        "tie_result": {"enum": ["failed", "succeeded", "manual_review"]},
        "invalidated_result": {"enum": ["failed", "no_score"]}
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_source_refs", "fallback_source_refs", "zero_division_policy", "missing_data_policy", "precision", "rounding_mode", "observation_order"],
      "properties": {
        "primary_source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
        "fallback_source_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
        "zero_division_policy": {"enum": ["manual_review", "annul", "not_applicable"]},
        "missing_data_policy": {"enum": ["manual_review", "annul", "fallback_source"]},
        "precision": {"type": "integer", "minimum": 0, "maximum": 18},
        "rounding_mode": {"enum": ["none", "half_even", "half_up", "down"]},
        "observation_order": {"enum": ["event_time", "official_sequence"]}
      }
    },
    "public_math": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activation_formula", "success_formula", "failure_formula", "one_line"],
      "properties": {
        "activation_formula": {"$ref": "#/$defs/nonemptyString"},
        "success_formula": {"$ref": "#/$defs/nonemptyString"},
        "failure_formula": {"$ref": "#/$defs/nonemptyString"},
        "one_line": {"type": "string", "minLength": 1, "maxLength": 320}
      }
    },
    "quality_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "missing_fields"],
      "properties": {
        "decision": {"enum": ["ready", "needs_confirmation", "blocked"]},
        "warnings": {"$ref": "#/$defs/stringSet"},
        "missing_fields": {"$ref": "#/$defs/stringSet"}
      }
    }
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "nullableDateTime": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
    "nullableUuid": {"anyOf": [{"type": "null"}, {"type": "string", "format": "uuid"}]},
    "decimalString": {"type": "string", "pattern": "^-?(?:0|[1-9][0-9]*)(?:\\.[0-9]{1,18})?$"},
    "nullableDecimalString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/decimalString"}]},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "executionProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "formula_family", "aggregation", "legs", "clock", "direction_threshold_bps", "long_short"],
      "properties": {
        "engine": {"const": "cuebook_settlement_v1"},
        "formula_family": {"enum": ["single_asset_direction", "single_asset_price_target", "pair_asset_direction", "pair_asset_price_targets"]},
        "aggregation": {"enum": ["single", "all", "long_short"]},
        "legs": {"type": "array", "minItems": 1, "maxItems": 2, "items": {"$ref": "#/$defs/executionLeg"}},
        "clock": {"$ref": "#/$defs/executionClock"},
        "direction_threshold_bps": {"anyOf": [{"type": "null"}, {"type": "integer", "minimum": 0, "maximum": 100000}]},
        "long_short": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["long_leg_id", "short_leg_id", "operator", "margin_bps", "weighting", "return_basis", "endpoint_alignment", "max_entry_skew_seconds", "fx_policy"],
              "properties": {
                "long_leg_id": {"enum": ["A", "B"]},
                "short_leg_id": {"enum": ["A", "B"]},
                "operator": {"enum": ["gt", "gte"]},
                "margin_bps": {"type": "integer", "minimum": 0, "maximum": 100000},
                "weighting": {"const": "equal_notional"},
                "return_basis": {"const": "simple_price_return"},
                "endpoint_alignment": {"enum": ["same_session_close", "same_utc_timestamp"]},
                "max_entry_skew_seconds": {"type": "integer", "minimum": 0, "maximum": 86400},
                "fx_policy": {"enum": ["same_quote_currency", "local_price_return"]}
              }
            }
          ]
        }
      }
    },
    "executionLeg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["leg_id", "role", "asset_id", "provider_instrument_id", "canonical_ticker", "provider", "quote_currency", "direction", "entry", "exit_variable_ref", "target"],
      "properties": {
        "leg_id": {"enum": ["A", "B"]},
        "role": {"enum": ["primary", "comparator"]},
        "asset_id": {"type": "integer", "minimum": 1},
        "provider_instrument_id": {"type": "string", "format": "uuid"},
        "canonical_ticker": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]*$"},
        "provider": {"$ref": "#/$defs/nonemptyString"},
        "quote_currency": {"type": "string", "pattern": "^[A-Z][A-Z0-9]{2,9}$"},
        "direction": {"enum": ["long", "short"]},
        "entry": {"$ref": "#/$defs/executionEntry"},
        "exit_variable_ref": {"type": "string", "pattern": "^VAR_[A-Z0-9_]+$"},
        "target": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["metric", "operator", "value", "unit"],
              "properties": {
                "metric": {"const": "price"},
                "operator": {"enum": ["gt", "gte", "lt", "lte"]},
                "value": {"$ref": "#/$defs/decimalString"},
                "unit": {"$ref": "#/$defs/nonemptyString"}
              }
            }
          ]
        }
      }
    },
    "executionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "price", "observed_at", "source", "market_session", "symbol_period_id", "provider_symbol", "observation_ref", "capture_ref"],
      "properties": {
        "mode": {"enum": ["fixed_snapshot", "activation_capture"]},
        "price": {"$ref": "#/$defs/nullableDecimalString"},
        "observed_at": {"$ref": "#/$defs/nullableDateTime"},
        "source": {"anyOf": [{"type": "null"}, {"enum": ["realtime", "candle_close"]}]},
        "market_session": {"$ref": "#/$defs/nullableString"},
        "symbol_period_id": {"$ref": "#/$defs/nullableUuid"},
        "provider_symbol": {"$ref": "#/$defs/nullableString"},
        "observation_ref": {"$ref": "#/$defs/nullableString"},
        "capture_ref": {"$ref": "#/$defs/nullableString"}
      }
    },
    "executionClock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["starts_at", "settle_at", "end_event_ref", "interval", "timezone", "session", "outcome_source", "selection", "origin", "adjustment", "max_observation_delay_seconds"],
      "properties": {
        "starts_at": {"type": "string", "format": "date-time"},
        "settle_at": {"$ref": "#/$defs/nullableDateTime"},
        "end_event_ref": {"$ref": "#/$defs/nullableString"},
        "interval": {"$ref": "#/$defs/nonemptyString"},
        "timezone": {"$ref": "#/$defs/nonemptyString"},
        "session": {"enum": ["regular", "extended", "all_sessions", "continuous"]},
        "outcome_source": {"enum": ["realtime", "candle_close", "warm_candle"]},
        "selection": {"enum": ["first_eligible_at_or_after", "any_sealed_in_window", "first_sealed_after_event"]},
        "origin": {"anyOf": [{"type": "null"}, {"enum": ["provider_official", "ws_built", "internal"]}]},
        "adjustment": {"anyOf": [{"type": "null"}, {"enum": ["adjusted", "unadjusted"]}]},
        "max_observation_delay_seconds": {"type": "integer", "minimum": 0, "maximum": 1209600}
      }
    },
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "symbol", "kind", "value_type", "unit", "source_ref", "instrument_ref", "metric", "interval", "timezone", "session", "sealed_only", "parameters"],
      "properties": {
        "id": {"type": "string", "pattern": "^VAR_[A-Z0-9_]+$"},
        "symbol": {"$ref": "#/$defs/nonemptyString"},
        "kind": {"enum": ["market_observation", "derived_metric", "event_observation"]},
        "value_type": {"enum": ["number", "boolean", "datetime"]},
        "unit": {"$ref": "#/$defs/nullableString"},
        "source_ref": {"$ref": "#/$defs/nonemptyString"},
        "instrument_ref": {"$ref": "#/$defs/nullableString"},
        "metric": {"$ref": "#/$defs/nonemptyString"},
        "interval": {"$ref": "#/$defs/nullableString"},
        "timezone": {"$ref": "#/$defs/nullableString"},
        "session": {"enum": ["regular", "extended", "all_sessions", "continuous", "event_window", "none"]},
        "sealed_only": {"type": "boolean"},
        "parameters": {"type": "object"}
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "symbol", "variable_ref", "mode"],
      "properties": {
        "id": {"type": "string", "pattern": "^CAP_[A-Z0-9_]+$"},
        "symbol": {"$ref": "#/$defs/nonemptyString"},
        "variable_ref": {"type": "string", "pattern": "^VAR_[A-Z0-9_]+$"},
        "mode": {"const": "value_at_activation"}
      }
    },
    "window": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["lookback", "include_current"],
          "properties": {
            "lookback": {"type": "integer", "minimum": 1, "maximum": 10000},
            "include_current": {"type": "boolean"}
          }
        }
      ]
    },
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "args", "value", "ref", "window"],
      "properties": {
        "op": {"enum": ["literal", "var", "capture", "add", "sub", "mul", "div", "mean", "gt", "gte", "lt", "lte", "eq", "between", "and", "or", "not"]},
        "args": {"type": "array", "items": {"$ref": "#/$defs/expression"}},
        "value": {"anyOf": [{"type": "null"}, {"type": "number"}, {"type": "boolean"}, {"$ref": "#/$defs/decimalString"}]},
        "ref": {"$ref": "#/$defs/nullableString"},
        "window": {"$ref": "#/$defs/window"}
      }
    },
    "nullableExpression": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/expression"}]}
  }
}
