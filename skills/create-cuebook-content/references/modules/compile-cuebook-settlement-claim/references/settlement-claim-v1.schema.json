{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/settlement-claim-v1.schema.json",
  "title": "SettlementClaimV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "claim_id", "revision", "state", "lineage", "extraction", "subject", "direction", "claim_text", "baseline", "clock", "success", "failure", "resolution", "public_view", "quality_report"],
  "properties": {
    "schema_version": {"const": "settlement-claim-v1"},
    "claim_id": {"type": "string", "pattern": "^SETTLE_[A-Za-z0-9_-]{8,}$"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"enum": ["draft", "needs_confirmation", "ready", "frozen"]},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_content_refs", "thesis_ref", "canonical_hash"],
      "properties": {
        "source_content_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
        "thesis_ref": {"$ref": "#/$defs/nullableString"},
        "canonical_hash": {"anyOf": [{"type": "null"}, {"type": "string", "pattern": "^[a-f0-9]{64}$"}]}
      }
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "explicit_fields", "inferred_fields", "proposed_fields", "confirmed_fields", "missing_fields"],
      "properties": {
        "mode": {"enum": ["explicit", "mixed", "proposed"]},
        "explicit_fields": {"$ref": "#/$defs/stringSet"},
        "inferred_fields": {"$ref": "#/$defs/stringSet"},
        "proposed_fields": {"$ref": "#/$defs/stringSet"},
        "confirmed_fields": {"$ref": "#/$defs/stringSet"},
        "missing_fields": {"$ref": "#/$defs/stringSet"}
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instrument_id", "ticker", "display_name", "asset_class", "venue", "quote_currency"],
      "properties": {
        "instrument_id": {"$ref": "#/$defs/nonemptyString"},
        "ticker": {"$ref": "#/$defs/nonemptyString"},
        "display_name": {"$ref": "#/$defs/nonemptyString"},
        "asset_class": {"enum": ["equity", "etf", "crypto", "commodity", "future", "option", "fx", "rate", "bond", "prediction_market", "index", "other"]},
        "venue": {"$ref": "#/$defs/nonemptyString"},
        "quote_currency": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "direction": {"enum": ["long", "short", "outperform", "underperform", "range", "event_yes", "event_no", "neutral"]},
    "claim_text": {"$ref": "#/$defs/nonemptyString"},
    "intent": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["action_state", "trigger_condition_ref", "entry_price_rule"],
          "properties": {
            "action_state": {"enum": ["enter_now", "wait_for_trigger", "observe_only", "hold", "avoid", "exit"]},
            "trigger_condition_ref": {"$ref": "#/$defs/nullableString"},
            "entry_price_rule": {"enum": ["publication_baseline", "trigger_observation", "not_applicable"]}
          }
        },
        {"type": "null"}
      ]
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "observed_at", "observation_basis", "market_state", "data_source_ref"],
      "properties": {
        "value": {"$ref": "#/$defs/nullableNumber"},
        "unit": {"$ref": "#/$defs/nullableString"},
        "observed_at": {"$ref": "#/$defs/nullableDateTime"},
        "observation_basis": {"enum": ["last_trade", "last_close", "midpoint", "official_close", "official_settlement", "spot", "intraday", "nav", "event_status", "none"]},
        "market_state": {"enum": ["regular", "pre", "after", "overnight", "closed", "continuous", "event_window", "unknown"]},
        "data_source_ref": {"$ref": "#/$defs/nullableString"}
      }
    },
    "clock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declared_at", "window_start", "window_end", "timezone", "market_session"],
      "properties": {
        "declared_at": {"$ref": "#/$defs/dateTime"},
        "window_start": {"$ref": "#/$defs/dateTime"},
        "window_end": {"$ref": "#/$defs/nullableDateTime"},
        "end_mode": {"enum": ["fixed_datetime", "protocol_event"]},
        "end_event_ref": {"$ref": "#/$defs/nullableString"},
        "end_event_label": {"$ref": "#/$defs/nullableString"},
        "end_event_source_ref": {"$ref": "#/$defs/nullableString"},
        "fallback_window_end": {"$ref": "#/$defs/nullableDateTime"},
        "timezone": {"$ref": "#/$defs/nonemptyString"},
        "market_session": {"enum": ["regular", "extended", "all_sessions", "continuous", "event_window"]}
      }
    },
    "success": {"$ref": "#/$defs/conditionGroup"},
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "conditions", "text"],
      "properties": {
        "mode": {"enum": ["complement_at_expiry", "early_condition", "manual_review"]},
        "conditions": {"type": "array", "items": {"$ref": "#/$defs/condition"}},
        "text": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_source_ref", "fallback_source_refs", "adjustments_policy", "ambiguity_policy", "score_modes"],
      "properties": {
        "primary_source_ref": {"$ref": "#/$defs/nonemptyString"},
        "fallback_source_refs": {"$ref": "#/$defs/stringSet"},
        "adjustments_policy": {"$ref": "#/$defs/nonemptyString"},
        "ambiguity_policy": {"enum": ["manual_review", "annul", "fallback_source"]},
        "score_modes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["binary_accuracy", "directional_accuracy", "return", "excess_return"]}}
      }
    },
    "public_view": {
      "type": "object",
      "additionalProperties": false,
      "required": ["settlement_summary", "one_line", "status_label"],
      "properties": {
        "settlement_summary": {"type": "string", "minLength": 1, "maxLength": 600},
        "one_line": {"type": "string", "minLength": 1, "maxLength": 240},
        "status_label": {"enum": ["Draft", "Needs confirmation", "Ready to settle", "Frozen"]}
      }
    },
    "quality_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "missing_fields"],
      "properties": {
        "decision": {"enum": ["ready", "needs_confirmation", "blocked"]},
        "warnings": {"$ref": "#/$defs/stringSet"},
        "missing_fields": {"$ref": "#/$defs/stringSet"}
      }
    }
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "nullableNumber": {"anyOf": [{"type": "null"}, {"type": "number"}]},
    "dateTime": {"type": "string", "format": "date-time"},
    "nullableDateTime": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/dateTime"}]},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "lower_bound", "upper_bound", "unit", "value_source"],
      "properties": {
        "value": {"$ref": "#/$defs/nullableNumber"},
        "lower_bound": {"$ref": "#/$defs/nullableNumber"},
        "upper_bound": {"$ref": "#/$defs/nullableNumber"},
        "unit": {"$ref": "#/$defs/nullableString"},
        "value_source": {"enum": ["baseline", "explicit_target", "benchmark", "event", "trigger_observation", "none"]}
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "subject_ref", "kind", "metric", "operator", "target", "observation_mode", "window_start", "window_end", "data_source_ref", "benchmark_ref", "event_ref", "description"],
      "properties": {
        "id": {"type": "string", "pattern": "^[CF][1-9][0-9]*$"},
        "subject_ref": {"$ref": "#/$defs/nonemptyString"},
        "kind": {"enum": ["terminal_value", "window_barrier", "relative_return", "range", "event", "spread", "probability", "fundamental"]},
        "metric": {"enum": ["official_close", "official_settlement", "spot_price", "intraday_high", "intraday_low", "vwap", "total_return_pct", "excess_return_pct", "spread_value", "probability_pct", "event_status", "fundamental_value"]},
        "operator": {"enum": ["gt", "gte", "lt", "lte", "eq", "between", "occurred", "not_occurred"]},
        "target": {"$ref": "#/$defs/target"},
        "observation_mode": {"enum": ["at_expiry", "any_in_window", "every_observation", "first_after_event", "event_by_expiry"]},
        "window_start": {"$ref": "#/$defs/nullableDateTime"},
        "window_end": {"$ref": "#/$defs/nullableDateTime"},
        "data_source_ref": {"$ref": "#/$defs/nonemptyString"},
        "benchmark_ref": {"$ref": "#/$defs/nullableString"},
        "event_ref": {"$ref": "#/$defs/nullableString"},
        "description": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "conditionGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logic", "conditions"],
      "properties": {
        "logic": {"enum": ["all", "any", "sequence"]},
        "conditions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/condition"}}
      }
    }
  }
}
