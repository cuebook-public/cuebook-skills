{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/viewpoint-visual-spec-v1.schema.json",
  "title": "ViewpointVisualSpecV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "spec_id", "revision", "state", "grammar", "payload_mode", "visual_job", "lineage", "frame", "data", "render", "quality_report"],
  "properties": {
    "schema_version": {"const": "viewpoint-visual-spec-v1"},
    "spec_id": {"type": "string", "pattern": "^VVSPEC_[A-Za-z0-9_:-]{8,}$"},
    "revision": {"type": "integer", "minimum": 1},
    "state": {"enum": ["conditional", "ready", "frozen"]},
    "grammar": {"$ref": "#/$defs/grammar"},
    "payload_mode": {"enum": ["qualitative", "key_numbers", "series", "mixed"]},
    "visual_job": {"$ref": "#/$defs/visualJob"},
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_artifact_refs", "source_refs", "decision_cutoff_at"],
      "properties": {
        "input_artifact_refs": {"$ref": "#/$defs/stringSet"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "decision_cutoff_at": {"$ref": "#/$defs/dateTime"}
      }
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "observation", "observed_at", "strategy_tags", "alt_text"],
      "properties": {
        "headline": {"type": "string", "minLength": 1, "maxLength": 96},
        "observation": {"type": "string", "minLength": 1, "maxLength": 120},
        "observed_at": {"$ref": "#/$defs/dateTime"},
        "strategy_tags": {"type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 20}},
        "alt_text": {"type": "string", "minLength": 1, "maxLength": 320}
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["series", "values", "levels", "events", "nodes", "edges", "rails", "stages"],
      "properties": {
        "series": {"type": "array", "maxItems": 2, "items": {"$ref": "#/$defs/series"}},
        "values": {"type": "array", "maxItems": 3, "items": {"$ref": "#/$defs/value"}},
        "levels": {"type": "array", "maxItems": 1, "items": {"$ref": "#/$defs/level"}},
        "events": {"type": "array", "maxItems": 1, "items": {"$ref": "#/$defs/event"}},
        "nodes": {"type": "array", "maxItems": 4, "items": {"$ref": "#/$defs/node"}},
        "edges": {"type": "array", "maxItems": 4, "items": {"$ref": "#/$defs/edge"}},
        "rails": {"type": "array", "maxItems": 2, "items": {"$ref": "#/$defs/rail"}},
        "stages": {"type": "array", "maxItems": 3, "items": {"$ref": "#/$defs/stage"}}
      }
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "width", "height", "theme", "watermark", "generated_at"],
      "properties": {
        "layout": {"const": "landscape"},
        "width": {"const": 720},
        "height": {"const": 420},
        "theme": {"const": "cuebook_accessible_light"},
        "watermark": {"const": "Cuebook"},
        "generated_at": {"$ref": "#/$defs/dateTime"}
      }
    },
    "quality_report": {"$ref": "#/$defs/quality"}
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "nullableString": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]},
    "dateTime": {"type": "string", "format": "date-time"},
    "stringSet": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "grammar": {"enum": ["reaction_test", "parallel_contrast", "category_reframe", "relative_value_trigger", "policy_pivot", "sentiment_witness", "event_unwind", "feedback_loop", "binary_level", "expectation_gap", "factor_rotation"]},
    "visualJob": {"enum": ["test_reaction", "compare_paths", "reframe_category", "show_relative_trigger", "show_policy_pivot", "show_sentiment_witness", "show_event_unwind", "explain_feedback_loop", "test_binary_level", "show_expectation_gap", "show_factor_rotation"]},
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "source_ref"],
      "properties": {
        "x": {"anyOf": [{"type": "number"}, {"type": "string", "minLength": 1}]},
        "y": {"type": "number"},
        "source_ref": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/nonemptyString"}]}
      }
    },
    "series": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "role", "data_kind", "unit", "source_ref", "points"],
      "properties": {
        "id": {"type": "string", "pattern": "^S[1-9][0-9]*$"},
        "label": {"type": "string", "minLength": 1, "maxLength": 28},
        "role": {"enum": ["reaction", "primary", "comparison", "witness", "unwind", "level_test"]},
        "data_kind": {"const": "observed"},
        "unit": {"type": "string", "minLength": 1, "maxLength": 12},
        "source_ref": {"$ref": "#/$defs/nonemptyString"},
        "points": {"type": "array", "minItems": 2, "maxItems": 24, "items": {"$ref": "#/$defs/point"}}
      }
    },
    "value": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "role", "display_value", "numeric_value", "unit", "as_of", "source_ref", "shape", "formula"],
      "properties": {
        "id": {"type": "string", "pattern": "^V[1-9][0-9]*$"},
        "label": {"type": "string", "minLength": 1, "maxLength": 32},
        "role": {"enum": ["spread", "baseline", "witness", "current", "expected", "actual", "gap", "from", "to", "shock_primary", "shock_secondary"]},
        "display_value": {"type": "string", "minLength": 1, "maxLength": 20},
        "numeric_value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1, "maxLength": 12},
        "as_of": {"$ref": "#/$defs/dateTime"},
        "source_ref": {"$ref": "#/$defs/nonemptyString"},
        "shape": {"enum": ["circle", "square", "triangle", "diamond"]},
        "formula": {"$ref": "#/$defs/nullableString"}
      }
    },
    "level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "role", "display_value", "numeric_value", "unit", "relation", "relation_label", "source_ref"],
      "properties": {
        "id": {"type": "string", "pattern": "^L[1-9][0-9]*$"},
        "label": {"type": "string", "minLength": 1, "maxLength": 32},
        "role": {"enum": ["trigger", "threshold"]},
        "display_value": {"type": "string", "minLength": 1, "maxLength": 20},
        "numeric_value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1, "maxLength": 12},
        "relation": {"enum": ["above", "below", "at"]},
        "relation_label": {"type": "string", "minLength": 1, "maxLength": 24},
        "source_ref": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "occurred_at", "source_ref"],
      "properties": {
        "id": {"type": "string", "pattern": "^EVT[1-9][0-9]*$"},
        "label": {"type": "string", "minLength": 1, "maxLength": 36},
        "occurred_at": {"$ref": "#/$defs/dateTime"},
        "source_ref": {"$ref": "#/$defs/nonemptyString"}
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "role", "source_refs", "shape", "path_kind"],
      "properties": {
        "id": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "label": {"type": "string", "minLength": 1, "maxLength": 48},
        "role": {"enum": ["frame_from", "frame_to", "policy_before", "policy_after", "loop"]},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "shape": {"enum": ["circle", "square", "triangle", "diamond"]},
        "path_kind": {"enum": ["solid", "conditional", "future"]}
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to", "relation", "label", "source_refs", "path_kind"],
      "properties": {
        "id": {"type": "string", "pattern": "^E[1-9][0-9]*$"},
        "from": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "to": {"type": "string", "pattern": "^N[1-9][0-9]*$"},
        "relation": {"enum": ["reframes", "pivots", "reinforces", "dampens"]},
        "label": {"$ref": "#/$defs/nullableString"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "path_kind": {"enum": ["solid", "conditional", "future"]}
      }
    },
    "rail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "detail", "role", "display_value", "numeric_value", "unit", "formula", "source_refs", "shape", "path_kind"],
      "properties": {
        "id": {"type": "string", "pattern": "^R[1-9][0-9]*$"},
        "label": {"type": "string", "minLength": 1, "maxLength": 32},
        "detail": {"type": "string", "minLength": 1, "maxLength": 72},
        "role": {"enum": ["pressure", "response", "primary", "comparison", "spread", "trigger", "policy_before", "policy_after", "baseline", "witness", "expected", "actual", "from", "to"]},
        "display_value": {"$ref": "#/$defs/nullableString"},
        "numeric_value": {"anyOf": [{"type": "null"}, {"type": "number"}]},
        "unit": {"$ref": "#/$defs/nullableString"},
        "formula": {"$ref": "#/$defs/nullableString"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "shape": {"enum": ["circle", "square", "triangle", "diamond"]},
        "path_kind": {"enum": ["solid", "conditional", "future"]}
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "detail", "role", "occurred_at", "display_value", "numeric_value", "unit", "source_refs", "shape", "path_kind"],
      "properties": {
        "id": {"type": "string", "pattern": "^T[1-9][0-9]*$"},
        "label": {"type": "string", "minLength": 1, "maxLength": 32},
        "detail": {"type": "string", "minLength": 1, "maxLength": 64},
        "role": {"enum": ["pre_event", "event_day", "next_step"]},
        "occurred_at": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/dateTime"}]},
        "display_value": {"$ref": "#/$defs/nullableString"},
        "numeric_value": {"anyOf": [{"type": "null"}, {"type": "number"}]},
        "unit": {"$ref": "#/$defs/nullableString"},
        "source_refs": {"$ref": "#/$defs/stringSet"},
        "shape": {"enum": ["circle", "square", "triangle", "diamond"]},
        "path_kind": {"enum": ["solid", "conditional", "future"]}
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "warnings", "hard_failures"],
      "properties": {
        "decision": {"enum": ["ready", "conditional", "blocked"]},
        "warnings": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
        "hard_failures": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}}
      }
    }
  }
}
