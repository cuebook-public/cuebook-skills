{
  "schema_version": "tradingview-canvas-tool-policy-v1",
  "upstream": {
    "repository": "https://github.com/tradesdontlie/tradingview-mcp",
    "audited_commit": "0ac960ad548597d0d1e5fb2bf7bd9a7a50faa87b",
    "audited_at": "2026-07-22T00:00:00Z",
    "advertised_server_version": "2.0.0",
    "connector": "tradingview_desktop"
  },
  "allowed_tools": {
    "preflight": [
      "chart_get_state",
      "draw_list",
      "tv_health_check"
    ],
    "stage": [
      "chart_set_symbol",
      "chart_set_timeframe"
    ],
    "apply": [
      "draw_shape"
    ],
    "verify": [
      "draw_get_properties",
      "draw_list"
    ],
    "cleanup": [
      "draw_remove_one"
    ],
    "local_artifact": [
      "capture_screenshot"
    ]
  },
  "shape_allowlist": [
    "horizontal_line",
    "vertical_line",
    "trend_line",
    "rectangle",
    "text"
  ],
  "explicitly_blocked_tools": [
    "alert_create",
    "alert_delete",
    "draw_clear",
    "pine_compile",
    "pine_get_source",
    "pine_new",
    "pine_open",
    "pine_save",
    "pine_set_source",
    "pine_smart_compile",
    "replay_trade",
    "tv_discover",
    "tv_launch",
    "tv_update",
    "ui_click",
    "ui_evaluate",
    "ui_keyboard",
    "ui_mouse_click",
    "ui_type_text",
    "watchlist_add",
    "watchlist_add_bulk",
    "watchlist_remove"
  ],
  "lifecycle": {
    "creator_confirmation_required_before_draw": true,
    "snapshot_existing_entity_ids": true,
    "record_every_created_entity_id": true,
    "cleanup_only_created_entity_ids": true,
    "clear_all_allowed": false,
    "restore_staged_chart_state": true,
    "direct_frame_pixel_reuse_allowed": false
  }
}
