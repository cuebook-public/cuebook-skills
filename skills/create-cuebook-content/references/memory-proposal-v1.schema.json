{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProposeMemoryInputV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "idempotency_key",
    "kind",
    "summary",
    "scope",
    "client_observed_user_intent"
  ],
  "properties": {
    "schema_version": { "const": "propose-memory-input.v1" },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "kind": { "enum": ["preference", "constraint", "thinking_anchor", "decision_pattern"] },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind"],
      "properties": {
        "schema_version": { "const": "memory-scope.v1" },
        "kind": { "enum": ["global", "qualified"] },
        "asset_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["locator_type", "locator"],
            "properties": {
              "locator_type": { "const": "canonical_ticker" },
              "locator": { "type": "string", "minLength": 1, "maxLength": 32 },
              "asset_class_hint": { "type": "string" }
            }
          }
        },
        "sector_refs": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "maxLength": 128 } },
        "strategy_refs": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "maxLength": 128 } },
        "task_refs": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "maxLength": 128 } },
        "horizons": { "type": "array", "minItems": 1, "maxItems": 16, "items": { "type": "string", "maxLength": 128 } }
      }
    },
    "source_refs": {
      "type": "array",
      "maxItems": 16,
      "items": { "type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^cuebook://" }
    },
    "client_attestation": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_version", "message_hash", "occurred_at"],
          "properties": {
            "schema_version": { "const": "client-attestation.v1" },
            "message_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "occurred_at": { "type": "string", "format": "date-time" },
            "excerpt": { "type": "string", "minLength": 1, "maxLength": 1000 }
          }
        }
      ]
    },
    "proposal_reason": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "client_observed_user_intent": { "enum": ["explicit", "inferred", "unknown"] }
  }
}
