{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/frame-preview-fast-job-v1.schema.json",
  "title": "FramePreviewFastJobV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "preview", "visual"],
  "properties": {
    "schema_version": {"const": "frame-preview-fast-job-v1"},
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preview_id", "state", "created_at", "creator_view", "query_binding", "candidate"],
      "properties": {
        "preview_id": {"type": "string", "pattern": "^FPREV_[A-Za-z0-9_:-]{6,}$"},
        "state": {"enum": ["ready", "conditional"]},
        "created_at": {"type": "string", "format": "date-time"},
        "creator_view": {
          "type": "object",
          "additionalProperties": false,
          "required": ["original_text", "subject", "direction", "observation_window", "horizon", "claim", "mechanism", "next_watch"],
          "properties": {
            "original_text": {"type": "string", "minLength": 2, "maxLength": 4000},
            "subject": {"type": "string", "minLength": 1, "maxLength": 80},
            "direction": {"enum": ["long", "short", "outperform", "underperform", "range", "avoid", "watch", "neutral", "explain"]},
            "observation_window": {"type": "string", "minLength": 1, "maxLength": 80},
            "horizon": {"type": "string", "minLength": 1, "maxLength": 80},
            "claim": {"type": "string", "minLength": 2, "maxLength": 200},
            "mechanism": {"type": "string", "minLength": 2, "maxLength": 240},
            "next_watch": {"type": "string", "minLength": 2, "maxLength": 160}
          }
        },
        "query_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "status", "bundle_refs", "result_refs", "as_of", "warnings", "unavailable_capabilities"],
          "properties": {
            "required": {"type": "boolean"},
            "status": {"enum": ["not_required", "reused", "executed", "partial"]},
            "bundle_refs": {"$ref": "#/$defs/stringSet"},
            "result_refs": {"$ref": "#/$defs/stringSet"},
            "as_of": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
            "warnings": {"$ref": "#/$defs/stringSet"},
            "unavailable_capabilities": {"$ref": "#/$defs/stringSet"}
          }
        },
        "candidate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["candidate_id", "angle", "frame", "evidence_refs"],
          "properties": {
            "candidate_id": {"type": "string", "pattern": "^FPREV_CAND_[A-Za-z0-9_:-]{4,}$"},
            "angle": {"enum": ["conviction", "evidence", "mechanism"]},
            "frame": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "body", "alt_text"],
              "properties": {
                "title": {"type": "string", "minLength": 2, "maxLength": 32},
                "body": {"type": "string", "minLength": 20, "maxLength": 280},
                "alt_text": {"type": "string", "minLength": 2, "maxLength": 160}
              }
            },
            "evidence_refs": {"$ref": "#/$defs/stringSet"}
          }
        }
      }
    },
    "visual": {
      "oneOf": [
        {"$ref": "#/$defs/logicVisual"},
        {"$ref": "#/$defs/marketVisual"}
      ]
    }
  },
  "$defs": {
    "nonemptyString": {"type": "string", "minLength": 1},
    "stringSet": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonemptyString"}},
    "nullableNumberLike": {
      "anyOf": [
        {"type": "null"},
        {"type": "number"},
        {"type": "string", "minLength": 1}
      ]
    },
    "logicVisual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "template_id", "subject", "horizon", "as_of_label", "claim", "evidence", "mechanism", "condition", "binding_refs"],
      "properties": {
        "kind": {"const": "logic_card"},
        "template_id": {"enum": ["verdict", "proof", "system"]},
        "subject": {"type": "string", "minLength": 1, "maxLength": 24},
        "horizon": {"type": "string", "minLength": 1, "maxLength": 24},
        "as_of_label": {"type": "string", "minLength": 1, "maxLength": 48},
        "claim": {"type": "string", "minLength": 1, "maxLength": 44},
        "evidence": {"type": "string", "minLength": 1, "maxLength": 60},
        "mechanism": {"type": "string", "minLength": 1, "maxLength": 60},
        "condition": {"type": "string", "minLength": 1, "maxLength": 40},
        "binding_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["claim", "evidence", "mechanism", "condition"],
          "properties": {
            "claim": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
            "evidence": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
            "mechanism": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"},
            "condition": {"type": "string", "pattern": "^BIND_[A-Za-z0-9_:-]{4,}$"}
          }
        }
      }
    },
    "toolCandles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data", "meta"],
      "properties": {
        "data": {
          "type": "object",
          "additionalProperties": true,
          "required": ["ticker", "interval", "bars"],
          "properties": {
            "ticker": {"type": "string", "minLength": 1},
            "interval": {"type": "string", "minLength": 1},
            "bars": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["openTime", "open", "high", "low", "close", "volume"],
                "properties": {
                  "openTime": {"type": "string", "format": "date-time"},
                  "open": {"$ref": "#/$defs/nullableNumberLike"},
                  "high": {"$ref": "#/$defs/nullableNumberLike"},
                  "low": {"$ref": "#/$defs/nullableNumberLike"},
                  "close": {"$ref": "#/$defs/nullableNumberLike"},
                  "volume": {"$ref": "#/$defs/nullableNumberLike"}
                }
              }
            },
            "nextCursor": {"type": ["string", "null"]}
          }
        },
        "meta": {
          "type": "object",
          "additionalProperties": true,
          "required": ["asOf", "truncated"],
          "properties": {
            "asOf": {"type": "string", "format": "date-time"},
            "truncated": {"type": "boolean"}
          }
        }
      }
    },
    "marketState": {
      "type": "object",
      "additionalProperties": true,
      "required": ["price", "observedAt"],
      "properties": {
        "price": {"$ref": "#/$defs/nullableNumberLike"},
        "observedAt": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]}
      }
    },
    "marketLeg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ticker", "display_name", "asset_id", "asset_class", "result_ref", "market_state", "candles"],
      "properties": {
        "ticker": {"type": "string", "minLength": 1, "maxLength": 32},
        "display_name": {"type": "string", "minLength": 1, "maxLength": 80},
        "asset_id": {"anyOf": [{"type": "null"}, {"type": "integer", "minimum": 1}]},
        "asset_class": {"type": "string", "minLength": 1, "maxLength": 32},
        "result_ref": {"type": "string", "minLength": 1},
        "market_state": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/marketState"}]},
        "candles": {"$ref": "#/$defs/toolCandles"}
      }
    },
    "marketVisual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "mode", "role", "title", "subtitle", "claim_statement", "direction", "observation_start", "declared_at", "horizon_end", "success_label", "show_volume", "primary", "warnings"],
      "properties": {
        "kind": {"const": "market_chart"},
        "mode": {"enum": ["single_price", "relative_performance"]},
        "role": {"enum": ["thesis", "evidence"]},
        "title": {"type": "string", "minLength": 1, "maxLength": 48},
        "subtitle": {"type": "string", "minLength": 1, "maxLength": 120},
        "claim_statement": {"type": "string", "minLength": 1, "maxLength": 200},
        "direction": {"enum": ["long", "short", "outperform", "underperform"]},
        "observation_start": {"type": "string", "format": "date-time"},
        "declared_at": {"type": "string", "format": "date-time"},
        "horizon_end": {"anyOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
        "success_label": {"type": "string", "minLength": 1, "maxLength": 100},
        "show_volume": {"type": "boolean"},
        "primary": {"$ref": "#/$defs/marketLeg"},
        "benchmark": {"$ref": "#/$defs/marketLeg"},
        "warnings": {"$ref": "#/$defs/stringSet"}
      }
    }
  }
}
