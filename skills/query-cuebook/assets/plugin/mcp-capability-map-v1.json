{
  "schema_version": "cuebook-mcp-capability-map-v1",
  "server": {
    "id": "cuebook",
    "url": "https://cuebook.xyz/mcp",
    "transport": "http",
    "authentication": "oauth"
  },
  "module_rules": {
    "query": {
      "allowed_access": [
        "read"
      ],
      "may_invoke": []
    },
    "create": {
      "allowed_access": [
        "read",
        "write",
        "external_write"
      ],
      "may_invoke": [
        "query"
      ]
    }
  },
  "available_tools": [
    {
      "tool": "search_assets",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Resolve creator language to a canonical Cuebook asset.",
      "used_by": [
        "query-cuebook",
        "validate-cuebook-projection"
      ]
    },
    {
      "tool": "get_market_state",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Bounded latest market snapshot, freshness, and session state per canonical ticker.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ]
    },
    {
      "tool": "list_asset_cues",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Published Cuebook thesis cards one asset participates in, newest first with keyset cursor.",
      "used_by": [
        "query-cuebook"
      ]
    },
    {
      "tool": "get_cues",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Single cue detail with narrative summary and license-gated citations.",
      "used_by": [
        "query-cuebook"
      ]
    },
    {
      "tool": "list_cues_timeline",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Platform-wide published thesis cards newest first (discover-equivalent).",
      "used_by": [
        "query-cuebook"
      ]
    },
    {
      "tool": "get_paper_portfolio",
      "module": "query",
      "authorization_scope": "cuebook.paper.read",
      "access": "read",
      "purpose": "User simulated portfolio (cash, equity, positions); source marked SIMULATED.",
      "used_by": [
        "query-cuebook"
      ]
    },
    {
      "tool": "preview_paper_order",
      "module": "query",
      "authorization_scope": "cuebook.paper.read",
      "access": "read",
      "purpose": "Read-only market-order preview against the persisted price snapshot; never places an order.",
      "used_by": [
        "query-cuebook"
      ]
    },
    {
      "tool": "place_paper_order",
      "module": "create",
      "authorization_scope": "cuebook.paper.trade",
      "access": "write",
      "purpose": "Submit a simulated market order with mandatory idempotency key; grant-scoped attribution.",
      "used_by": [
        "create-cuebook-content"
      ]
    },
    {
      "tool": "close_paper_position",
      "module": "create",
      "authorization_scope": "cuebook.paper.trade",
      "access": "write",
      "purpose": "Reduce-only convenience close of an open simulated position via the same order command path.",
      "used_by": [
        "create-cuebook-content"
      ]
    },
    {
      "tool": "list_paper_orders",
      "module": "query",
      "authorization_scope": "cuebook.paper.read",
      "access": "read",
      "purpose": "User fill history newest first with placedBy attribution.",
      "used_by": [
        "query-cuebook"
      ]
    },
    {
      "tool": "get_candles",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Sealed OHLCV history (never the forming tip); prices as decimal strings.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack",
        "compute-cuebook-market-indicators"
      ],
      "content_kind": "market_history",
      "default_enabled": false
    },
    {
      "tool": "list_market_calendar",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Macro and earnings anchors in a bounded lookback/horizon window with revision dedupe.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ],
      "content_kind": "calendar",
      "default_enabled": false
    },
    {
      "tool": "list_filings",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Surviving filing artifact versions with license-gated evidence and fact attachments.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ],
      "content_kind": "filings",
      "default_enabled": false
    },
    {
      "tool": "list_asset_disclosures",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Five-provider disclosure co-location records with exact amount payload text.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ],
      "content_kind": "market_intel",
      "default_enabled": false
    },
    {
      "tool": "get_positioning",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Grounding snapshots per topic: options, crypto derivatives, analyst ratings, leverage ratio.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ],
      "content_kind": "market_intel",
      "default_enabled": false
    },
    {
      "tool": "list_asset_events",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Token unlocks, onchain security, and breakout events per asset with per-item license tagging.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ],
      "content_kind": "market_intel",
      "default_enabled": false
    },
    {
      "tool": "list_prediction_markets",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Latest prediction-market snapshots in a clamped 8-day window; resolved markets excluded.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ],
      "content_kind": "prediction_market",
      "default_enabled": false
    },
    {
      "tool": "get_news_cluster",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Publication-attached membership of one news story with per-member license gate.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ],
      "content_kind": "news",
      "default_enabled": false
    },
    {
      "tool": "list_market_briefings",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Published market briefings with fail-closed revision gate; Cuebook interpretation tagged.",
      "used_by": [
        "query-cuebook"
      ],
      "content_kind": "news",
      "default_enabled": false
    },
    {
      "tool": "list_themes",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Qualified theme aggregation with 180-day channel disclosure window.",
      "used_by": [
        "query-cuebook"
      ],
      "content_kind": "noesis_research",
      "default_enabled": false
    },
    {
      "tool": "get_cues_detail",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Narrative head and legs with optional price reactions; alive+published gate.",
      "used_by": [
        "query-cuebook"
      ],
      "content_kind": "noesis_research",
      "default_enabled": false
    },
    {
      "tool": "get_reasoning_graph",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Bounded reasoning graph; judge internals and unpublished lineage never leave.",
      "used_by": [
        "query-cuebook"
      ],
      "content_kind": "noesis_research",
      "default_enabled": false
    },
    {
      "tool": "list_settlements",
      "module": "query",
      "authorization_scope": "read:public",
      "access": "read",
      "purpose": "Settlement outcomes for ever-published narratives (deliberately not alive-gated).",
      "used_by": [
        "query-cuebook",
        "reconcile-market-content-history"
      ],
      "content_kind": "noesis_research",
      "default_enabled": false
    }
  ],
  "required_tools": [
    {
      "tool": "get_frame_capabilities",
      "module": "create",
      "authorization_scope": "read:public",
      "phase": "frame_phase_b",
      "access": "read",
      "purpose": "Read the deployed Frame schema, rendition roles, limits, policy, and enabled actions before uploading.",
      "input_contract": "GetFrameCapabilitiesInputV1",
      "output_contract": "FrameCapabilitiesV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "begin_frame_media_upload",
      "module": "create",
      "authorization_scope": "cuebook.frame.write",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Reserve a signed HTTPS upload for one authored rendition; declare encoded hash, mime, bytes, dimensions, and a distinct UUIDv7.",
      "input_contract": "BeginFrameMediaUploadV1",
      "output_contract": "FrameMediaUploadReservationV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "complete_frame_media_upload",
      "module": "create",
      "authorization_scope": "cuebook.frame.write",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Confirm one signed upload and trigger processing with a command-specific UUIDv7.",
      "input_contract": "CompleteFrameMediaUploadV1",
      "output_contract": "FrameMediaUploadReceiptV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "get_frame_media_status",
      "module": "create",
      "authorization_scope": "cuebook.frame.write",
      "phase": "frame_phase_b",
      "access": "read",
      "purpose": "Poll owner-only processing and encoded/pixel hash receipts; returns no image bytes, delivery URL, or browsing surface.",
      "input_contract": "GetFrameMediaStatusV1",
      "output_contract": "FrameMediaStatusV1 (processing and hash receipts only)",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "register_frame_visual_manifest",
      "module": "create",
      "authorization_scope": "cuebook.frame.write",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Bind the complete visual manifest to the processed media asset after both encoded-byte and canonical-pixel hashes match.",
      "input_contract": "RegisterFrameVisualManifestV1",
      "output_contract": "FrameDraftAssemblyBindingV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "create_frame_draft",
      "module": "create",
      "authorization_scope": "cuebook.frame.write",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Materialize a Skill assembly only after the server returns a registered media/manifest binding.",
      "input_contract": "FrameDraftAssemblyV1 + FrameDraftAssemblyBindingV1",
      "output_contract": "FrameDraftAssemblyResultV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "get_frame_draft",
      "module": "create",
      "authorization_scope": "cuebook.frame.read",
      "phase": "frame_phase_b",
      "access": "read",
      "purpose": "Resume an owner-only materialized draft and its revision; returns no media bytes or standalone visual URL.",
      "input_contract": "GetFrameDraftInputV1",
      "output_contract": "FrameDraftReadV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "update_frame_draft",
      "module": "create",
      "authorization_scope": "cuebook.frame.write",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Revise a draft under optimistic concurrency using the assembly and registered binding with a distinct UUIDv7.",
      "input_contract": "FrameDraftAssemblyV1 + FrameDraftAssemblyBindingV1 + expected_revision",
      "output_contract": "FrameDraftAssemblyResultV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "prepare_frame_publish",
      "module": "create",
      "authorization_scope": "cuebook.frame.publish",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Validate the draft and create a prepared hash, publish token, preview, and first-party consent request without publishing.",
      "input_contract": "PrepareFramePublishInputV1",
      "output_contract": "PreparedFramePublishV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "get_frame_action_consent",
      "module": "create",
      "authorization_scope": "cuebook.frame.publish",
      "phase": "frame_phase_b",
      "access": "read",
      "purpose": "Poll an opaque first-party consent request state; never returns a bearer-like consent token.",
      "input_contract": "GetFrameActionConsentInputV1",
      "output_contract": "FrameActionConsentStatusV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "publish_frame",
      "module": "create",
      "authorization_scope": "cuebook.frame.publish",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Consume approved first-party consent and freeze the Frame, release, visual binding, and Settlement Contract atomically.",
      "input_contract": "PublishFrameInputV1",
      "output_contract": "FramePublicationReceiptV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "get_frame",
      "module": "query",
      "authorization_scope": "read:public",
      "phase": "frame_phase_b",
      "access": "read",
      "purpose": "Read one release-pinned full Frame with its single attached publication visual, settlement, discussion, and canonical URL; never returns media[] or a standalone media result.",
      "input_contract": "FrameRefV1",
      "output_contract": "FrameMcpViewV1 (full Frame plus one attached visual)",
      "used_by": [
        "query-cuebook",
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "create_frame_correction_draft",
      "module": "create",
      "authorization_scope": "cuebook.frame.write",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Create a copy/ref/visual-only correction draft; never accepts a new settlement intent.",
      "input_contract": "CreateFrameCorrectionDraftInputV1",
      "output_contract": "FrameCorrectionDraftV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "prepare_frame_correction_publish",
      "module": "create",
      "authorization_scope": "cuebook.frame.publish",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Prove the economic hash is unchanged and create correction preview plus first-party consent.",
      "input_contract": "PrepareFrameCorrectionPublishInputV1",
      "output_contract": "PreparedFrameCorrectionPublishV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "publish_frame_correction",
      "module": "create",
      "authorization_scope": "cuebook.frame.publish",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Consume correction consent, publish a new content release, and reuse the frozen economic contract.",
      "input_contract": "PublishFrameCorrectionInputV1",
      "output_contract": "FramePublicationReceiptV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "prepare_frame_withdraw",
      "module": "create",
      "authorization_scope": "cuebook.frame.publish",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Create a withdrawal preview and one-time first-party consent request without changing distribution.",
      "input_contract": "PrepareFrameWithdrawInputV1",
      "output_contract": "PreparedFrameWithdrawV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "withdraw_frame",
      "module": "create",
      "authorization_scope": "cuebook.frame.publish",
      "phase": "frame_phase_b",
      "access": "write",
      "purpose": "Consume withdrawal consent and stop distribution without deleting release, settlement, discussion, or audit history.",
      "input_contract": "WithdrawFrameInputV1",
      "output_contract": "FrameWithdrawalReceiptV1",
      "used_by": [
        "create-cuebook-content"
      ],
      "source": "Frame Remote MCP Phase B §6-7"
    },
    {
      "tool": "search_news",
      "module": "query",
      "authorization_scope": "cuebook.query",
      "phase": "pr8",
      "access": "read",
      "purpose": "Lexical news search; semantic mode returns unavailable until PR9.",
      "used_by": [
        "query-cuebook",
        "build-market-research-pack"
      ]
    },
    {
      "tool": "get_creator_feed",
      "module": "query",
      "authorization_scope": "cuebook.query",
      "phase": "r2",
      "access": "read",
      "purpose": "Owned feed of news, calendar, narratives, trade ideas, and authorized trade history.",
      "used_by": [
        "query-cuebook",
        "normalize-cuebook-creator-feed"
      ]
    },
    {
      "tool": "compute_market_metrics",
      "module": "query",
      "authorization_scope": "cuebook.query",
      "phase": "r2",
      "access": "read",
      "purpose": "Versioned derived metrics and composite trigger signals.",
      "used_by": [
        "query-cuebook",
        "compute-cuebook-market-indicators"
      ]
    },
    {
      "tool": "resolve_settlement_binding",
      "module": "query",
      "authorization_scope": "cuebook.query",
      "phase": "superseded_review",
      "access": "read",
      "purpose": "Legacy settlement binding resolution; superseded by the Frame prepare/publish flow.",
      "used_by": [
        "query-cuebook"
      ],
      "superseded_by": "prepare_frame_publish"
    },
    {
      "tool": "save_creator_artifact",
      "module": "create",
      "authorization_scope": "cuebook.create.write",
      "phase": "superseded_review",
      "access": "write",
      "purpose": "Legacy artifact persistence; superseded by the Frame draft/publish tool family.",
      "used_by": [
        "orchestrate-cuebook-creator-workflow",
        "assemble-cuebook-viewpoint-card",
        "prepare-market-content-release"
      ],
      "superseded_by": "create_frame_draft"
    },
    {
      "tool": "register_settlement_claim",
      "module": "create",
      "authorization_scope": "cuebook.create.write",
      "phase": "superseded_review",
      "access": "write",
      "purpose": "Legacy settlement registration; folded into publish_frame's atomic transaction.",
      "used_by": [
        "compile-cuebook-settlement-claim",
        "compile-cuebook-settlement-formula",
        "orchestrate-cuebook-creator-workflow"
      ],
      "superseded_by": "publish_frame"
    },
    {
      "tool": "publish_release",
      "module": "create",
      "authorization_scope": "cuebook.publish",
      "phase": "r2",
      "access": "external_write",
      "purpose": "Send an approved frozen ReleaseBundleV1 through an official platform connector.",
      "used_by": [
        "prepare-market-content-release"
      ]
    },
    {
      "tool": "get_publication_receipt",
      "module": "query",
      "authorization_scope": "cuebook.query",
      "phase": "r2",
      "access": "read",
      "purpose": "Resolve a platform operation into a verified publication receipt or explicit unknown.",
      "used_by": [
        "query-cuebook",
        "reconcile-market-content-history"
      ]
    }
  ],
  "frame_publication_flow": {
    "image_transport": "signed_https_upload_only",
    "skill_may_pull_media": false,
    "status_tool": "get_frame_media_status",
    "status_returns": "processing_and_hash_receipts_only",
    "published_read_tool": "get_frame",
    "published_visual_semantics": "one_visual_attached_to_frame_release",
    "forbidden_tools": [
      "get_frame_media",
      "list_frame_media",
      "publish_frame_image",
      "share_frame_to_agent"
    ],
    "initial_publish_sequence": [
      "get_frame_capabilities",
      "begin_frame_media_upload",
      "https_put_each_role",
      "complete_frame_media_upload",
      "get_frame_media_status",
      "register_frame_visual_manifest",
      "create_or_update_frame_draft",
      "prepare_frame_publish",
      "first_party_consent",
      "get_frame_action_consent",
      "publish_frame",
      "get_frame"
    ],
    "mutation_idempotency": "distinct_lowercase_uuidv7_per_command",
    "replay_policy": "same_key_same_payload_returns_receipt_changed_payload_conflict"
  },
  "release_rules": {
    "credentials_live_in_mcp_connector": true,
    "skills_must_not_collect_credentials": true,
    "server_enforces_authorization_scopes": true,
    "query_scope_cannot_call_write_tools": true,
    "write_tools_require_idempotency_key": true,
    "write_tools_require_explicit_approval": true,
    "frame_images_are_upload_only": true,
    "frame_media_status_returns_receipts_only": true,
    "frame_get_returns_one_attached_visual": true,
    "frame_mutations_use_distinct_uuidv7_keys": true,
    "external_write_requires_exact_artifact_hash": true,
    "external_write_requires_release_approval": true,
    "publish_success_requires_verified_receipt": true,
    "forming_market_bars_cannot_settle": true,
    "protocol_event_horizons_require_authoritative_source": true,
    "registered_claim_requires_formula_hash": true,
    "settlement_outcomes_require_sealed_observations": true,
    "material_news_requires_linked_evidence": true,
    "source_rights_required_for_creation": true,
    "valuation_comparisons_require_compatible_basis": true
  },
  "notes": "Data-expansion tools ship with content_kind default_enabled=false; a disabled tool stays in tools/list and returns unavailable until admin app_config enables it. search_news lands in PR8. Frame tool family activates in Phase B after OAuth owner/client consent."
}
