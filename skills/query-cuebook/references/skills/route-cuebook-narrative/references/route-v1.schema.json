{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuebook.local/schemas/route-v1.schema.json",
  "title": "RouteV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "taxonomy_version", "cue_id", "event_type", "event_confidence", "candidates", "reasoning_lenses", "render_shape", "required_context", "hard_numbers", "abstain", "abstain_reason"],
  "properties": {
    "schema_version": {"const": "route-v1"},
    "taxonomy_version": {"const": "market-narrative-v2"},
    "cue_id": {"type": "string"},
    "event_type": {"type": "string"},
    "event_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "candidates": {"type": "array", "items": {"type": "object", "required": ["event_type", "score"], "properties": {"event_type": {"type": "string"}, "score": {"type": "number"}}, "additionalProperties": false}},
    "reasoning_lenses": {"type": "array", "items": {"type": "string"}},
    "render_shape": {"type": "string"},
    "required_context": {"type": "array", "items": {"type": "object", "required": ["kind", "fields", "why"], "properties": {"kind": {"type": "string"}, "fields": {"type": "array", "items": {"type": "string"}}, "why": {"type": "string"}}, "additionalProperties": false}},
    "hard_numbers": {"type": "array", "items": {"type": "string"}},
    "abstain": {"type": "boolean"},
    "abstain_reason": {"type": "string"}
  }
}
